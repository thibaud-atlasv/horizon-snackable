                       HorizontalAlignment="Center" Margin="0,0,0,6">
              <Run Text="WAVE " /><Run Text="{Binding waveNumber}" />
            </TextBlock>
            <!-- Timer bar -->
            <Grid Width="200" Height="14">
              <Border CornerRadius="7" Background="#201520" Height="14">
                <Border CornerRadius="7" HorizontalAlignment="Left"
                        Background="{Binding timerColorHex}"
                        Width="{Binding timerBarWidth}" Height="14" />
              </Border>
            </Grid>
            <!-- Wave progress bar (thin) -->
            <Grid Width="80" Height="6" Margin="0,6,0,0" HorizontalAlignment="Center">
              <Rectangle Width="80" Height="6" RadiusX="3" RadiusY="3">
                <Rectangle.Fill><ImageBrush ImageSource="{Binding hudWaveBarContourTexture}" Stretch="Fill" /></Rectangle.Fill>
              </Rectangle>
              <Border CornerRadius="3" HorizontalAlignment="Left"
                      Background="{Binding timerColorHex}"
                      Width="{Binding waveBarWidth}" Height="4" Margin="1" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Wave Announcement (center) -->
        <Grid Visibility="{Binding waveAnnouncementVisible, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="{Binding waveAnnouncementText}" FontSize="28" FontWeight="Bold"
                     Foreground="#F0F0F8" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <!-- Elite Warning (center, slightly above) -->
        <Grid Visibility="{Binding eliteWarningVisible, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="⚠ ELITE INCOMING!" FontSize="24" FontWeight="Bold"
                     Foreground="#FF8020" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="0,-60,0,0" />
        </Grid>

        <!-- Boss Warning (center) -->
        <Grid Visibility="{Binding bossWarningVisible, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="⚠ BOSS INCOMING!" FontSize="26" FontWeight="Bold"
                     Foreground="#FF4040" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="0,-100,0,0" />
        </Grid>

        <!-- Boss HP Bar (top, below HUD panel) -->
        <Grid Visibility="{Binding bossHpBarVisible, Converter={StaticResource BoolToVis}}"
              VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,78,0,0">
          <Border Height="14" Width="330" CornerRadius="7" Background="#301010">
            <Border CornerRadius="7" HorizontalAlignment="Left"
                    Background="#D02020"
                    Width="{Binding bossHpBarWidth}" Height="14" />
          </Border>
          <TextBlock Text="{Binding bossHpBarText}" FontSize="9" Foreground="#F0F0F8"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
      </Grid>

      <!-- Layer 3: Pause Menu overlay -->
      <Grid Visibility="{Binding pauseMenuVisible, Converter={StaticResource BoolToVis}}"
            Background="#D912121A">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
          <TextBlock Text="PAUSED" FontSize="36" FontWeight="Bold" Foreground="#F0F0F8"
                     HorizontalAlignment="Center" Margin="0,0,0,30" />
          <Button Content="RESUME" Command="{Binding events.onResumeClicked}"
                  Width="180" Height="50" FontSize="18" FontWeight="Bold"
                  Background="#4080F0" Foreground="White" BorderThickness="0" Margin="0,0,0,12">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,5">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>
          <Button Content="RESTART" Command="{Binding events.onRestartClicked}"
                  Width="180" Height="50" FontSize="18" FontWeight="Bold"
                  Background="#E94560" Foreground="White" BorderThickness="0">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,5">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Layer 3.5: Upgrade Selection Overlay -->
      <Grid Visibility="{Binding upgradeScreenVisible, Converter={StaticResource BoolToVis}}"
            Background="#E0101020">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
          <TextBlock Text="LEVEL UP!" FontSize="28" FontWeight="Bold" Foreground="#FFD740"
                     HorizontalAlignment="Center" Margin="0,0,0,20" />
          <TextBlock Text="Choose an upgrade:" FontSize="14" Foreground="#B0B0C0"
                     HorizontalAlignment="Center" Margin="0,0,0,16" />

          <!-- Upgrade Card 0 -->
          <Button Command="{Binding events.onUpgrade0Clicked}"
                  Visibility="{Binding upgrade0Visible, Converter={StaticResource BoolToVis}}"
                  Width="300" Height="80" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="#40304080" CornerRadius="8" BorderBrush="#6050A0" BorderThickness="2" Padding="12,8">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding upgrade0Name}" FontSize="16" FontWeight="Bold" Foreground="#F0F0F8" />
                      <TextBlock Text="{Binding upgrade0Level}" FontSize="12" Foreground="#80D0FF"
                                 Margin="10,2,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding upgrade0Desc}" FontSize="12" Foreground="#B0B0C0"
                               Margin="0,4,0,0" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>

          <!-- Upgrade Card 1 -->
          <Button Command="{Binding events.onUpgrade1Clicked}"
                  Visibility="{Binding upgrade1Visible, Converter={StaticResource BoolToVis}}"
                  Width="300" Height="80" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="#40304080" CornerRadius="8" BorderBrush="#6050A0" BorderThickness="2" Padding="12,8">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding upgrade1Name}" FontSize="16" FontWeight="Bold" Foreground="#F0F0F8" />
                      <TextBlock Text="{Binding upgrade1Level}" FontSize="12" Foreground="#80D0FF"
                                 Margin="10,2,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding upgrade1Desc}" FontSize="12" Foreground="#B0B0C0"
                               Margin="0,4,0,0" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>

          <!-- Upgrade Card 2 -->
          <Button Command="{Binding events.onUpgrade2Clicked}"
                  Visibility="{Binding upgrade2Visible, Converter={StaticResource BoolToVis}}"
                  Width="300" Height="80" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="#40304080" CornerRadius="8" BorderBrush="#6050A0" BorderThickness="2" Padding="12,8">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding upgrade2Name}" FontSize="16" FontWeight="Bold" Foreground="#F0F0F8" />
                      <TextBlock Text="{Binding upgrade2Level}" FontSize="12" Foreground="#80D0FF"
                                 Margin="10,2,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding upgrade2Desc}" FontSize="12" Foreground="#B0B0C0"
                               Margin="0,4,0,0" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Layer 4: Title screen overlay -->
      <Grid Visibility="{Binding titleVisible, Converter={StaticResource BoolToVis}}"
            Background="#CC12121A">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
          <TextBlock Text="ARENA" FontSize="56" FontWeight="Bold" FontFamily="Teko"
                     Foreground="#F0F0F8" HorizontalAlignment="Center"
                     CharacterSpacing="200" Margin="0,0,0,-10" />
          <TextBlock Text="VERMIN" FontSize="56" FontWeight="Bold" FontFamily="Teko"
                     Foreground="#E94560" HorizontalAlignment="Center"
                     CharacterSpacing="200" Margin="0,0,0,30" />
          <Border Height="2" Width="160" Background="#4080F0"
                  HorizontalAlignment="Center" Margin="0,0,0,30" CornerRadius="1" />
          <Button Content="START" Command="{Binding events.onStartClicked}"
                  Width="180" Height="50" FontSize="20" FontWeight="Bold"
                  Background="#E94560" Foreground="White" BorderThickness="0">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="6" Padding="10,5">
                  <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Layer 5: Death dark overlay (fades in during death animation) -->
      <Grid Visibility="{Binding deathOverlayVisible, Converter={StaticResource BoolToVis}}"
            Background="#12121A" Opacity="{Binding deathOverlayOpacity}"
            IsHitTestVisible="False" />

      <!-- Layer 6: Death screen content -->
      <Grid Visibility="{Binding deathScreenVisible, Converter={StaticResource BoolToVis}}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
          <TextBlock Text="DEFEATED" FontSize="28" FontWeight="Bold" Foreground="#E94560"
                     HorizontalAlignment="Center" Margin="0,0,0,20" />
          <TextBlock Text="{Binding deathWavesText}" FontSize="16" Foreground="#F0F0F8"
                     HorizontalAlignment="Center" Margin="0,0,0,12" />
          <!-- Coin tally -->
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
            <Ellipse Width="14" Height="14" Fill="#F0C030" Stroke="#C08020" StrokeThickness="1" />
            <TextBlock Text="{Binding deathCoinsText}" FontSize="14" Foreground="#F0F0F8"
                       Margin="6,0,0,0" VerticalAlignment="Center" />
          </StackPanel>
          <!-- XP tally -->
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
            <Ellipse Width="14" Height="14" Fill="#30D060" Stroke="#20A040" StrokeThickness="1" />
            <TextBlock Text="{Binding deathXpText}" FontSize="14" Foreground="#F0F0F8"
                       Margin="6,0,0,0" VerticalAlignment="Center" />
          </StackPanel>
          <!-- Retry button -->
          <Button Content="RETRY" Command="{Binding events.onRetryClicked}"
                  Width="180" Height="50" FontSize="18" FontWeight="Bold"
                  Background="#E94560" Foreground="White" BorderThickness="0" Margin="0,0,0,12">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,5">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>
          <!-- Return to menu button -->
          <Button Content="RETURN TO MENU" Command="{Binding events.onReturnToMenuClicked}"
                  Width="180" Height="44" FontSize="14" FontWeight="Bold"
                  Background="#3A3E55" Foreground="White" BorderThickness="0">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,5">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </StackPanel>
      </Grid>
    </Grid>
  </Viewbox>
</Grid>
