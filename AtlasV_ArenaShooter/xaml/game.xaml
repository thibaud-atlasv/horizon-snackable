      <!-- Layer 2: HUD overlay (above sprites, below title/pause) -->
      <Grid Visibility="{Binding hudVisible, Converter={StaticResource BoolToVis}}">

        <!-- === TOP PANEL === -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Stretch"
                Background="#B0101020" CornerRadius="0,0,12,12"
                Padding="10,8,10,10" Margin="0,0,0,0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: HP Bar (full width, prominent) -->
            <Grid Grid.Row="0" Margin="40,0,0,0">
              <Border Height="16" CornerRadius="8" Background="#301010">
                <Border CornerRadius="8" HorizontalAlignment="Left"
                        Background="{Binding hpBarColorHex}"
                        Width="{Binding hpBarWidth}" Height="16" />
              </Border>
              <!-- HP text centered inside bar -->
              <TextBlock Text="{Binding hpText}" FontSize="10" Foreground="#B0FFFFFF"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>

            <!-- Row 1: XP/Level Bar with level label -->
            <Grid Grid.Row="1" Margin="40,5,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" FontSize="11" FontWeight="Bold" Foreground="#80D0FF"
                         VerticalAlignment="Center" Margin="0,0,6,0">
                <Run Text="Lv." /><Run Text="{Binding playerLevel}" />
              </TextBlock>
              <Grid Grid.Column="1">
                <Border Height="10" CornerRadius="5" Background="#1A2A50">
                  <Border CornerRadius="5" HorizontalAlignment="Left"
                          Background="#4080F0"
                          Width="{Binding levelBarWidth}" Height="10" />
                </Border>
                <TextBlock Text="{Binding levelBarText}" FontSize="9" Foreground="#7090B0"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" />
              </Grid>
            </Grid>

            <!-- Row 2: Coins (left) and Enemy Count (right) -->
            <Grid Grid.Row="2" Margin="40,6,0,0">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Rectangle Width="20" Height="20">
                  <Rectangle.Fill><ImageBrush ImageSource="{Binding hudCoinCountTexture}" Stretch="Uniform" /></Rectangle.Fill>
                </Rectangle>
                <TextBlock Text="{Binding coinCountText}" FontSize="13" FontWeight="SemiBold" Foreground="#FFD740"
                           Margin="4,0,0,0" VerticalAlignment="Center" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Rectangle Width="20" Height="20">
                  <Rectangle.Fill><ImageBrush ImageSource="{Binding hudEnnemiCountTexture}" Stretch="Uniform" /></Rectangle.Fill>
                </Rectangle>
                <TextBlock Text="{Binding enemyCountText}" FontSize="13" Foreground="#F0F0F8"
                           Margin="4,0,0,0" VerticalAlignment="Center" />
              </StackPanel>
            </Grid>
          </Grid>
        </Border>

        <!-- Pause Button (top-left, overlapping panel) -->
        <Button Width="44" Height="44" VerticalAlignment="Top" HorizontalAlignment="Left"
                Margin="4,6,0,0" Background="Transparent" BorderThickness="0"
                Command="{Binding events.onPauseClicked}" IsHitTestVisible="True">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Grid>
                <Rectangle Width="44" Height="44">
                  <Rectangle.Fill><ImageBrush ImageSource="{Binding hudPauseButtonTexture}" Stretch="Uniform" /></Rectangle.Fill>
