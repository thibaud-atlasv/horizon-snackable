<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:noesis="clr-namespace:NoesisGUIExtensions"
      mc:Ignorable="d"
      Background="Transparent" d:DesignWidth="900" d:DesignHeight="1600">

    <Page.Resources>
        <!-- Text colors -->
        <SolidColorBrush x:Key="HUDTextColor" Color="#FFFFD700"/>
        <SolidColorBrush x:Key="CenterTextColor" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="CenterTextShadow" Color="#CC000000"/>
        
        <!-- Neon Casino Colors -->
        <SolidColorBrush x:Key="NeonGold" Color="#FFFFD700"/>
        <SolidColorBrush x:Key="NeonHotPink" Color="#FFFF1493"/>
        <SolidColorBrush x:Key="NeonCyan" Color="#FF00FFFF"/>
        <SolidColorBrush x:Key="NeonMagenta" Color="#FFFF00FF"/>
        
        <!-- Heart color -->
        <SolidColorBrush x:Key="HeartColor" Color="#FFFF0000"/>
        
        <!-- Heart path data -->
        <Geometry x:Key="HeartGeometry">M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z</Geometry>
    </Page.Resources>

    <Grid>
        <!-- Main layout: Top bar at top, center text in middle -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- CENTER TEXT: Game state messages (hidden by default) - Casino Neon Style -->
        <Grid x:Name="CenterTextContainer" VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TransformGroup>
                    <TranslateTransform X="{Binding Path=centerTextTranslateX}" Y="{Binding Path=centerTextTranslateY}"/>
                    <ScaleTransform ScaleX="{Binding Path=centerTextScaleX}" ScaleY="{Binding Path=centerTextScaleY}"/>
                    <RotateTransform Angle="{Binding Path=centerTextRotation}"/>
                </TransformGroup>
            </Grid.RenderTransform>
            <Grid.Visibility>
                <Binding Path="showCenterText">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter/>
                    </Binding.Converter>
                </Binding>
            </Grid.Visibility>
            
            <!-- Outer Neon Glow Border - Deep magenta glow -->
            <Border CornerRadius="20" Padding="8" Margin="-12">
                <Border.Background>
                    <RadialGradientBrush>
                        <GradientStop Color="#80FF00FF" Offset="0"/>
                        <GradientStop Color="#40FF1493" Offset="0.5"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>
            
            <!-- Main Border with Neon Gradient Background -->
            <Border CornerRadius="16" Padding="50,30">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#E6000000" Offset="0"/>
                        <GradientStop Color="#CC1A0A2E" Offset="0.3"/>
                        <GradientStop Color="#CC2D0A4E" Offset="0.7"/>
                        <GradientStop Color="#E6000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFF1493" Offset="0"/>
                        <GradientStop Color="#FFFFD700" Offset="0.25"/>
                        <GradientStop Color="#FF00FFFF" Offset="0.5"/>
                        <GradientStop Color="#FFFF00FF" Offset="0.75"/>
                        <GradientStop Color="#FFFF1493" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>4</Border.BorderThickness>
                
                <Grid>
                    <!-- Layer 1: Deep shadow (offset) -->
                    <TextBlock Text="{Binding Path=centerText}" 
                               FontFamily="Roboto" 
                               FontWeight="Bold" 
                               Foreground="#40000000" 
                               TextAlignment="Center" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               FontSize="190"
                               Margin="6,6,0,0">
                        <TextBlock.Visibility>
                            <Binding Path="showCenterText">
                                <Binding.Converter>
                                    <BooleanToVisibilityConverter/>
                                </Binding.Converter>
                            </Binding>
                        </TextBlock.Visibility>
                    </TextBlock>
                    
                    <!-- Layer 2: Outer magenta glow (largest, most diffuse) -->
                    <TextBlock Text="{Binding Path=centerText}" 
                               FontFamily="Roboto" 
                               FontWeight="Bold" 
                               Foreground="#60FF00FF" 
                               TextAlignment="Center" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               FontSize="200">
                        <TextBlock.Visibility>
                            <Binding Path="showCenterText">
                                <Binding.Converter>
                                    <BooleanToVisibilityConverter/>
                                </Binding.Converter>
                            </Binding>
                        </TextBlock.Visibility>
                    </TextBlock>
                    
                    <!-- Layer 3: Hot pink glow (medium) -->
                    <TextBlock Text="{Binding Path=centerText}" 
                               FontFamily="Roboto" 
                               FontWeight="Bold" 
                               Foreground="#80FF1493" 
                               TextAlignment="Center" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               FontSize="195">
                        <TextBlock.Visibility>
                            <Binding Path="showCenterText">
                                <Binding.Converter>
                                    <BooleanToVisibilityConverter/>
                                </Binding.Converter>
                            </Binding>
                        </TextBlock.Visibility>
                    </TextBlock>
                    
                    <!-- Layer 4: Cyan inner glow -->
                    <TextBlock Text="{Binding Path=centerText}" 
                               FontFamily="Roboto" 
                               FontWeight="Bold" 
                               Foreground="#9000FFFF" 
                               TextAlignment="Center" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               FontSize="188">
                        <TextBlock.Visibility>
                            <Binding Path="showCenterText">
                                <Binding.Converter>
                                    <BooleanToVisibilityConverter/>
                                </Binding.Converter>
                            </Binding>
                        </TextBlock.Visibility>
                    </TextBlock>
                    
                    <!-- Layer 5: Main text with gold/white gradient look -->
                    <TextBlock x:Name="CenterText" 
                               Text="{Binding Path=centerText}" 
                               FontFamily="Roboto" 
                               FontWeight="Bold" 
                               TextAlignment="Center" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               FontSize="185">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                <GradientStop Color="#FFFFD700" Offset="0.4"/>
                                <GradientStop Color="#FFFFAA00" Offset="0.7"/>
                                <GradientStop Color="#FFFFD700" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        <TextBlock.Visibility>
                            <Binding Path="showCenterText">
                                <Binding.Converter>
                                    <BooleanToVisibilityConverter/>
                                </Binding.Converter>
                            </Binding>
                        </TextBlock.Visibility>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>

        <!-- HEARTS: Bottom-right corner lives display -->

        <!-- TOP BAR: Score | Hearts - Neon Casino Style -->
        <Border Grid.Row="1" CornerRadius="12" Margin="40,0,40,50">
            <!-- Dark purple gradient background matching CenterTextContainer -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#E6000000" Offset="0"/>
                    <GradientStop Color="#CC1A0A2E" Offset="0.3"/>
                    <GradientStop Color="#CC2D0A4E" Offset="0.7"/>
                    <GradientStop Color="#E6000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <!-- Neon rainbow gradient border -->
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FFFF1493" Offset="0"/>
                    <GradientStop Color="#FFFFD700" Offset="0.25"/>
                    <GradientStop Color="#FF00FFFF" Offset="0.5"/>
                    <GradientStop Color="#FFFF00FF" Offset="0.75"/>
                    <GradientStop Color="#FFFF1493" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>3</Border.BorderThickness>
            
            <Grid Margin="20,12,20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Score (Left) - 5-layer Neon Glow Effect matching CenterTextContainer -->
                <Grid Grid.Column="0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="{Binding Path=scoreScale}" ScaleY="{Binding Path=scoreScale}"/>
                    </Grid.RenderTransform>
                    
                    <!-- Layer 1: Deep shadow (offset) -->
                    <TextBlock Text="{Binding Path=displayScore, StringFormat=F0}"
                               FontFamily="Roboto"
                               FontWeight="Bold"
                               Foreground="#40000000"
                               FontSize="170"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="5,5,0,0"/>
                    
                    <!-- Layer 2: Outer magenta glow (largest, most diffuse) -->
                    <TextBlock Text="{Binding Path=displayScore, StringFormat=F0}"
                               FontFamily="Roboto"
                               FontWeight="Bold"
                               Foreground="#60FF00FF"
                               FontSize="168"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="{Binding Path=scoreGlowOpacity}"/>
                    
                    <!-- Layer 3: Hot pink glow (medium) -->
                    <TextBlock Text="{Binding Path=displayScore, StringFormat=F0}"
                               FontFamily="Roboto"
                               FontWeight="Bold"
                               Foreground="#80FF1493"
                               FontSize="165"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="{Binding Path=scoreGlowOpacity}"/>
                    
                    <!-- Layer 4: Cyan inner glow -->
                    <TextBlock Text="{Binding Path=displayScore, StringFormat=F0}"
                               FontFamily="Roboto"
                               FontWeight="Bold"
                               Foreground="#9000FFFF"
                               FontSize="162"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    
                    <!-- Layer 5: Main text with white-to-gold gradient -->
                    <TextBlock Text="{Binding Path=displayScore, StringFormat=F0}"
                               FontFamily="Roboto"
                               FontWeight="Bold"
                               FontSize="160"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                <GradientStop Color="#FFFFD700" Offset="0.4"/>
                                <GradientStop Color="#FFFFAA00" Offset="0.7"/>
                                <GradientStop Color="#FFFFD700" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Grid>

                <!-- Hearts (Right) - Neon Glow Effect -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        
                        <!-- Heart 1 with layered glow -->
                        <Grid x:Name="Heart1Container" Width="96" Height="96" Margin="8">
                            <!-- Background glow layer (largest, hot pink) -->
                            <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Fill="#60FF1493" 
                                  Width="96" 
                                  Height="96"/>
                            <!-- Second glow layer (magenta) -->
                            <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Fill="#80FF00FF" 
                                  Width="88" 
                                  Height="88"/>
                            <!-- Main heart with gradient -->
                            <Path x:Name="Heart1" 
                                  Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Width="80" 
                                  Height="80">
                                <Path.Fill>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                        <GradientStop Color="#FFFF69B4" Offset="0.3"/>
                                        <GradientStop Color="#FFFF1493" Offset="0.7"/>
                                        <GradientStop Color="#FFFF1493" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.Fill>
                                <b:Interaction.Triggers>
                                    <b:DataTrigger Binding="{Binding Path=lives}" Comparison="GreaterThanOrEqual" Value="1">
                                        <b:ChangePropertyAction TargetName="Heart1Container" PropertyName="Visibility" Value="Visible"/>
                                    </b:DataTrigger>
                                    <b:DataTrigger Binding="{Binding Path=lives}" Comparison="LessThan" Value="1">
                                        <b:ChangePropertyAction TargetName="Heart1Container" PropertyName="Visibility" Value="Collapsed"/>
                                    </b:DataTrigger>
                                </b:Interaction.Triggers>
                            </Path>
                        </Grid>
                        
                        <!-- Heart 2 with layered glow -->
                        <Grid x:Name="Heart2Container" Width="96" Height="96" Margin="8">
                            <!-- Background glow layer (largest, hot pink) -->
                            <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Fill="#60FF1493" 
                                  Width="96" 
                                  Height="96"/>
                            <!-- Second glow layer (magenta) -->
                            <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Fill="#80FF00FF" 
                                  Width="88" 
                                  Height="88"/>
                            <!-- Main heart with gradient -->
                            <Path x:Name="Heart2" 
                                  Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Width="80" 
                                  Height="80">
                                <Path.Fill>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                        <GradientStop Color="#FFFF69B4" Offset="0.3"/>
                                        <GradientStop Color="#FFFF1493" Offset="0.7"/>
                                        <GradientStop Color="#FFFF1493" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.Fill>
                                <b:Interaction.Triggers>
                                    <b:DataTrigger Binding="{Binding Path=lives}" Comparison="GreaterThanOrEqual" Value="2">
                                        <b:ChangePropertyAction TargetName="Heart2Container" PropertyName="Visibility" Value="Visible"/>
                                    </b:DataTrigger>
                                    <b:DataTrigger Binding="{Binding Path=lives}" Comparison="LessThan" Value="2">
                                        <b:ChangePropertyAction TargetName="Heart2Container" PropertyName="Visibility" Value="Collapsed"/>
                                    </b:DataTrigger>
                                </b:Interaction.Triggers>
                            </Path>
                        </Grid>
                        
                        <!-- Heart 3 with layered glow -->
                        <Grid x:Name="Heart3Container" Width="96" Height="96" Margin="8">
                            <!-- Background glow layer (largest, hot pink) -->
                            <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Fill="#60FF1493" 
                                  Width="96" 
                                  Height="96"/>
                            <!-- Second glow layer (magenta) -->
                            <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Fill="#80FF00FF" 
                                  Width="88" 
                                  Height="88"/>
                            <!-- Main heart with gradient -->
                            <Path x:Name="Heart3" 
                                  Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Width="80" 
                                  Height="80">
                                <Path.Fill>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                        <GradientStop Color="#FFFF69B4" Offset="0.3"/>
                                        <GradientStop Color="#FFFF1493" Offset="0.7"/>
                                        <GradientStop Color="#FFFF1493" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.Fill>
                                <b:Interaction.Triggers>
                                    <b:DataTrigger Binding="{Binding Path=lives}" Comparison="GreaterThanOrEqual" Value="3">
                                        <b:ChangePropertyAction TargetName="Heart3Container" PropertyName="Visibility" Value="Visible"/>
                                    </b:DataTrigger>
                                    <b:DataTrigger Binding="{Binding Path=lives}" Comparison="LessThan" Value="3">
                                        <b:ChangePropertyAction TargetName="Heart3Container" PropertyName="Visibility" Value="Collapsed"/>
                                    </b:DataTrigger>
                                </b:Interaction.Triggers>
                            </Path>
                        </Grid>
                        
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
