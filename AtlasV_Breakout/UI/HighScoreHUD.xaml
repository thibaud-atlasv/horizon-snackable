<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="Transparent" d:DesignWidth="900" d:DesignHeight="1600">

    <Page.Resources>
        <!-- Neon Casino Colors -->
        <SolidColorBrush x:Key="NeonGold" Color="#FFFFD700"/>
        <SolidColorBrush x:Key="NeonHotPink" Color="#FFFF1493"/>
        <SolidColorBrush x:Key="NeonCyan" Color="#FF00FFFF"/>
        <SolidColorBrush x:Key="NeonMagenta" Color="#FFFF00FF"/>

        <!-- High Score Entry DataTemplate -->
        <DataTemplate x:Key="HighScoreEntryTemplate">
            <Border CornerRadius="10" Padding="10,0" Margin="0,20">
                <Border.Background>
                    <SolidColorBrush Color="{Binding Path=bgColor}"/>
                </Border.Background>
                <Border.RenderTransform>
                    <TranslateTransform X="{Binding Path=translateX}"/>
                </Border.RenderTransform>
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Rank -->
                <TextBlock Grid.Column="0" 
                           Text="{Binding Path=rank}" 
                           FontWeight="Bold" 
                           FontSize="70" 
                           HorizontalAlignment="Left" 
                           VerticalAlignment="Center" FontFamily="Kallisto">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="{Binding Path=color}"/>
                    </TextBlock.Foreground>
                </TextBlock>

                <!-- Name -->
                <TextBlock Grid.Column="1" 
                           Text="{Binding Path=name}" 
                           FontWeight="Bold" 
                           FontSize="70" 
                           VerticalAlignment="Center" FontFamily="Kallisto" TextAlignment="Center">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="{Binding Path=color}"/>
                    </TextBlock.Foreground>
                </TextBlock>

                <!-- Score -->
                <TextBlock Grid.Column="2" 
                           Text="{Binding Path=score}" 
                           FontWeight="Bold" 
                           FontSize="70" 
                           HorizontalAlignment="Right" 
                           VerticalAlignment="Center" FontFamily="Kallisto">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="{Binding Path=color}"/>
                    </TextBlock.Foreground>
                </TextBlock>

                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <!-- Full Screen Container - Visibility bound to showScreen -->
    <Grid x:Name="FullScreenContainer">
        <Grid.Visibility>
            <Binding Path="showScreen">
                <Binding.Converter>
                    <BooleanToVisibilityConverter/>
                </Binding.Converter>
            </Binding>
        </Grid.Visibility>

        <!-- Dark Overlay Background -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#F0080818" Offset="0"/>
                    <GradientStop Color="#F0020208" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Main Content - Bottom margin to keep GameHUD visible -->
        <Grid Margin="40,150,40,300" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE: "HIGH SCORES" with Multi-Layer Neon Glow -->
            <Grid Grid.Row="0" Margin="0,0,0,40" HorizontalAlignment="Center">
                <!-- Layer 1: Deep shadow (offset) -->
                <TextBlock Text="{Binding Path=titleText}" 
                           FontFamily="Roboto" 
                           FontWeight="Bold" 
                           Foreground="#40000000" 
                           TextAlignment="Center" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           FontSize="100"
                           Margin="6,6,0,0"/>
                
                <!-- Layer 2: Outer magenta glow (largest, most diffuse) -->
                <TextBlock Text="{Binding Path=titleText}" 
                           FontFamily="Roboto" 
                           FontWeight="Bold" 
                           Foreground="#60FF00FF" 
                           TextAlignment="Center" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           FontSize="105"/>
                
                <!-- Layer 3: Hot pink glow (medium) -->
                <TextBlock Text="{Binding Path=titleText}" 
                           FontFamily="Roboto" 
                           FontWeight="Bold" 
                           Foreground="#80FF1493" 
                           TextAlignment="Center" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           FontSize="102"/>
                
                <!-- Layer 4: Cyan inner glow -->
                <TextBlock Text="{Binding Path=titleText}" 
                           FontFamily="Roboto" 
                           FontWeight="Bold" 
                           Foreground="#9000FFFF" 
                           TextAlignment="Center" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           FontSize="98"/>
                
                <!-- Layer 5: Main text with white-to-gold gradient -->
                <TextBlock Text="{Binding Path=titleText}" 
                           FontFamily="Roboto" 
                           FontWeight="Bold" 
                           TextAlignment="Center" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           FontSize="96">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                            <GradientStop Color="#FFFFD700" Offset="0.4"/>
                            <GradientStop Color="#FFFFAA00" Offset="0.7"/>
                            <GradientStop Color="#FFFFD700" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
            </Grid>

            <!-- Score List Panel with Neon Border -->
            <Grid Grid.Row="1">
                <!-- Main Border with Neon Gradient Background and ClipToBounds -->
                <Border CornerRadius="20" Padding="60,50" ClipToBounds="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E6000000" Offset="0"/>
                            <GradientStop Color="#CC0A0A2E" Offset="0.3"/>
                            <GradientStop Color="#CC0A1530" Offset="0.7"/>
                            <GradientStop Color="#E6000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFF1493" Offset="0"/>
                            <GradientStop Color="#FFFFD700" Offset="0.25"/>
                            <GradientStop Color="#FF00FFFF" Offset="0.5"/>
                            <GradientStop Color="#FFFF00FF" Offset="0.75"/>
                            <GradientStop Color="#FFFF1493" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>4</Border.BorderThickness>

                    <!-- ItemsControl bound to entries array -->
                    <ItemsControl ItemsSource="{Binding Path=entries}"
                                  ItemTemplate="{StaticResource HighScoreEntryTemplate}"
                                  VerticalAlignment="Center" FontFamily="Kallisto"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
