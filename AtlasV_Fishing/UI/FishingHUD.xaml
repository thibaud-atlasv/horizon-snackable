<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="Transparent" d:DesignWidth="2000" d:DesignHeight="4000">

    <Page.Resources>
        <!-- UI Colors -->
        <SolidColorBrush x:Key="CounterBackgroundBrush" Color="#B01E3A5F"/>
        <SolidColorBrush x:Key="CounterTextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="CounterAccentBrush" Color="#FFFFC857"/>
        <SolidColorBrush x:Key="WhiteBorder" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="BlackBorder" Color="#FF000000"/>

        <!-- XP Progress Bar Colors -->
        <SolidColorBrush x:Key="XPTrackBrush" Color="#CC2D2A26"/>
        <SolidColorBrush x:Key="XPBorderBrush" Color="#FF8B4513"/>
        <SolidColorBrush x:Key="XPCursor1Brush" Color="#FF4A90D9"/>
        <SolidColorBrush x:Key="XPCursor2Brush" Color="#FF1a2a4a"/>

        <!-- Swipe Hint Show/Hide Storyboards -->
        <Storyboard x:Key="SwipeHintFadeIn">
            <DoubleAnimation Storyboard.TargetName="SwipeHintContainer"
                             Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="SwipeHintFadeOut">
            <DoubleAnimation Storyboard.TargetName="SwipeHintContainer"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Swipe Hint Pulse Animation -->
        <Storyboard x:Key="SwipeHintPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="SwipeHintLeftArrow"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="-25" Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SwipeHintRightArrow"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="25" Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- HUD Show/Hide Storyboards -->
        <Storyboard x:Key="HUDShowAnimation">
            <DoubleAnimation Storyboard.TargetName="HUDRootScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0" To="1" Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="HUDRootScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0" To="1" Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="HUDRoot"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
        </Storyboard>

        <Storyboard x:Key="HUDHideAnimation">
            <DoubleAnimation Storyboard.TargetName="HUDRootScale"
                             Storyboard.TargetProperty="ScaleX"
                             To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="HUDRootScale"
                             Storyboard.TargetProperty="ScaleY"
                             To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="HUDRoot"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.25"/>
        </Storyboard>

        <!-- XP Progress Bar Fade In Animation -->
        <Storyboard x:Key="XPBarFadeIn"/>

        <!-- XP Progress Bar Fade Out Animation -->
        <Storyboard x:Key="XPBarFadeOut"/>

        <!-- Zone Unlocked Pop In Animation (Elastic Scale + Fade) -->
        <Storyboard x:Key="ZoneUnlockedPopIn"/>

        <!-- Zone Unlocked Fade Out Animation -->
        <Storyboard x:Key="ZoneUnlockedFadeOut"/>
    </Page.Resources>

    <!-- Main Layout Grid - 9:16 Portrait Mobile -->
    <Grid Margin="46,0,-46,0">

        <!-- HUDRoot wrapper — animated show/hide via isHudVisible binding -->
        <Grid x:Name="HUDRoot"
              RenderTransformOrigin="0.5,0.5"
              Opacity="0">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="HUDRootScale" ScaleX="0" ScaleY="0"/>
            </Grid.RenderTransform>

            <b:Interaction.Triggers>
                <b:DataTrigger Binding="{Binding isHudVisible}" Value="True">
                    <b:ControlStoryboardAction Storyboard="{StaticResource HUDShowAnimation}"/>
                </b:DataTrigger>
                <b:DataTrigger Binding="{Binding isHudVisible}" Value="False">
                    <b:ControlStoryboardAction Storyboard="{StaticResource HUDHideAnimation}"/>
                </b:DataTrigger>
            </b:Interaction.Triggers>

            <!-- ── Depth Counter (Top Center) ────────────────────────── -->
            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Top" Margin="0,200,0,0">
                <!-- Drop shadow -->
                <Border CornerRadius="72"
                        Padding="54,24,66,24"
                        Opacity="0.4"
                        Margin="0,10,0,0"
                        VerticalAlignment="Top">
                    <Border.Background>
                        <SolidColorBrush Color="#FF000000"/>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Opacity="0">
                        <TextBlock Text="⚓" FontSize="102" Margin="0,0,30,0"/>
                        <TextBlock FontSize="96" FontWeight="Bold" Text="{Binding Path=depthText, FallbackValue=800m}"/>
                    </StackPanel>
                </Border>

                <!-- Outer white border -->
                <Border CornerRadius="72"
                        BorderBrush="{StaticResource WhiteBorder}"
                        BorderThickness="8"
                        Background="Transparent"
                        VerticalAlignment="Top">

                    <!-- Inner black border -->
                    <Border CornerRadius="64"
                            BorderBrush="{StaticResource BlackBorder}"
                            BorderThickness="5"
                            Padding="54,24,66,24">
                        <Border.Background>
                            <SolidColorBrush Color="#EE0C1B33"/>
                        </Border.Background>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚓"
                                       FontSize="102"
                                       VerticalAlignment="Center"
                                       Margin="0,0,30,0"/>
                            <TextBlock Text="{Binding depthText}"
                                       FontSize="96"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Stroke="#FF000000"
                                       StrokeThickness="6"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Grid>

        <!-- NEW ZONE UNLOCKED Message - Above XP Bar -->

        <!-- ── Swipe Hint (center screen, Diving phase only) ──── -->
        <Grid x:Name="SwipeHintContainer"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="0,-200,0,0"
              Opacity="0"
              IsHitTestVisible="False">

            <b:Interaction.Triggers>
                <b:DataTrigger Binding="{Binding isSwipeHintVisible}" Value="True">
                    <b:ControlStoryboardAction Storyboard="{StaticResource SwipeHintFadeIn}"/>
                    <b:ControlStoryboardAction Storyboard="{StaticResource SwipeHintPulse}" ControlStoryboardOption="Play"/>
                </b:DataTrigger>
                <b:DataTrigger Binding="{Binding isSwipeHintVisible}" Value="False">
                    <b:ControlStoryboardAction Storyboard="{StaticResource SwipeHintFadeOut}"/>
                    <b:ControlStoryboardAction Storyboard="{StaticResource SwipeHintPulse}" ControlStoryboardOption="Stop"/>
                </b:DataTrigger>
            </b:Interaction.Triggers>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <!-- Left arrow triangle -->
                <Path x:Name="SwipeHintLeftArrow"
                      Data="M120,0 L0,75 L120,150 Z"
                      Width="120" Height="150"
                      Stretch="Fill"
                      VerticalAlignment="Center"
                      Margin="0,0,50,0"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.Fill>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#FF00E5FF" Offset="0"/>
                            <GradientStop Color="#0000E5FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Path.Fill>
                    <Path.RenderTransform>
                        <TranslateTransform X="0" Y="0"/>
                    </Path.RenderTransform>
                </Path>

                <!-- Center text -->
                <TextBlock Text="Swipe"
                           FontSize="150"
                           FontWeight="Bold"
                           Stroke="#FF000000"
                           StrokeThickness="10"
                           VerticalAlignment="Center">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#FF40E0D0" Offset="0"/>
                            <GradientStop Color="#FF20B2AA" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <!-- Right arrow triangle -->
                <Path x:Name="SwipeHintRightArrow"
                      Data="M0,0 L120,75 L0,150 Z"
                      Width="120" Height="150"
                      Stretch="Fill"
                      VerticalAlignment="Center"
                      Margin="50,0,0,0"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.Fill>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#0000E5FF" Offset="0"/>
                            <GradientStop Color="#FF00E5FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Path.Fill>
                    <Path.RenderTransform>
                        <TranslateTransform X="0" Y="0"/>
                    </Path.RenderTransform>
                </Path>

            </StackPanel>
        </Grid>

        <!-- XP Progress Bar - Bottom of Screen -->
    </Grid>
</Page>
