<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      Background="Transparent" d:DesignWidth="2000" d:DesignHeight="4000"
      IsHitTestVisible="False">

    <Page.Resources>
        <!-- ── Color Palette ──────────────────────────────────────── -->
        <SolidColorBrush x:Key="WhiteBorder" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="BlackBorder" Color="#FF000000"/>
        <SolidColorBrush x:Key="Gold" Color="#FFFFC857"/>

        <!-- ══ Gold Counter Show Animation ══════════════════ -->
        <Storyboard x:Key="GoldShowAnimation">
            <DoubleAnimation Storyboard.TargetName="GoldCounterTranslate"
                             Storyboard.TargetProperty="Y"
                             From="-150" To="0" Duration="0:0:0.35" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="GoldCounterPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2" BeginTime="0:0:0"/>
        </Storyboard>

        <!-- ══ Gold Counter Hide Animation ══════════════════ -->
        <Storyboard x:Key="GoldHideAnimation">
            <DoubleAnimation Storyboard.TargetName="GoldCounterTranslate"
                             Storyboard.TargetProperty="Y"
                             To="-150" Duration="0:0:0.25" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="GoldCounterPanel"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.25" BeginTime="0:0:0"/>
        </Storyboard>

        <!-- ══ Depth Counter Show Animation ══════════════════ -->
        <Storyboard x:Key="DepthShowAnimation">
            <DoubleAnimation Storyboard.TargetName="DepthCounterTranslate"
                             Storyboard.TargetProperty="Y"
                             From="-150" To="0" Duration="0:0:0.35" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DepthCounterPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2" BeginTime="0:0:0"/>
        </Storyboard>

        <!-- ══ Depth Counter Hide Animation ══════════════════ -->
        <Storyboard x:Key="DepthHideAnimation">
            <DoubleAnimation Storyboard.TargetName="DepthCounterTranslate"
                             Storyboard.TargetProperty="Y"
                             To="-150" Duration="0:0:0.25" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DepthCounterPanel"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.25" BeginTime="0:0:0"/>
        </Storyboard>
    </Page.Resources>

    <!-- ═══ Main Layout ═══════════════════════════════════════ -->
    <Grid>
        <!-- ── Gold Counter (Top Center) ─── wrapped in GoldCounterPanel ── -->
        <Grid x:Name="GoldCounterPanel" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="GoldCounterTranslate" Y="-150"/>
            </Grid.RenderTransform>

            <b:Interaction.Triggers>
                <b:DataTrigger Binding="{Binding isGoldVisible}" Value="True">
                    <b:ControlStoryboardAction Storyboard="{StaticResource GoldShowAnimation}"/>
                </b:DataTrigger>
                <b:DataTrigger Binding="{Binding isGoldVisible}" Value="False">
                    <b:ControlStoryboardAction Storyboard="{StaticResource GoldHideAnimation}"/>
                </b:DataTrigger>
            </b:Interaction.Triggers>

            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Top"
                  Margin="0,120,0,0">
                <!-- Drop shadow offset below -->
                <Border CornerRadius="72"
                        Padding="54,24,66,24"
                        Opacity="0.4"
                        Margin="0,10,0,0"
                        VerticalAlignment="Top">
                    <Border.Background>
                        <SolidColorBrush Color="#FF000000"/>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Opacity="0">
                        <Image Source="Textures/gold_icon.png" Width="120" Height="120" Margin="0,0,30,0"/>
                        <TextBlock Text="{Binding goldAmount}" FontSize="120" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Outer white border -->
                <Border CornerRadius="72"
                        BorderBrush="{StaticResource WhiteBorder}"
                        BorderThickness="8"
                        Background="Transparent"
                        VerticalAlignment="Top">

                    <!-- Inner black border -->
                    <Border CornerRadius="64"
                            BorderBrush="{StaticResource BlackBorder}"
                            BorderThickness="5"
                            Padding="54,24,66,24">
                        <Border.Background>
                            <SolidColorBrush Color="#EE0C1B33"/>
                        </Border.Background>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Textures/gold_icon.png"
                                   Width="120" Height="120"
                                   Margin="0,0,30,0"/>
                            <TextBlock Text="{Binding goldAmount}"
                                       FontSize="120"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource Gold}"
                                       Stroke="#FF000000"
                                       StrokeThickness="6"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Grid>

        <!-- ── Depth Counter (Top Center, same position as Gold) ── -->
        <Grid x:Name="DepthCounterPanel" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="DepthCounterTranslate" Y="-150"/>
            </Grid.RenderTransform>

            <b:Interaction.Triggers>
                <b:DataTrigger Binding="{Binding isDepthVisible}" Value="True">
                    <b:ControlStoryboardAction Storyboard="{StaticResource DepthShowAnimation}"/>
                </b:DataTrigger>
                <b:DataTrigger Binding="{Binding isDepthVisible}" Value="False">
                    <b:ControlStoryboardAction Storyboard="{StaticResource DepthHideAnimation}"/>
                </b:DataTrigger>
            </b:Interaction.Triggers>

            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Top"
                  Margin="0,120,0,0">
                <!-- Drop shadow -->
                <Border CornerRadius="72"
                        Padding="54,24,66,24"
                        Opacity="0.4"
                        Margin="0,10,0,0"
                        VerticalAlignment="Top">
                    <Border.Background>
                        <SolidColorBrush Color="#FF000000"/>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Opacity="0">
                        <Path Width="90" Height="100" Stretch="Uniform" Margin="0,0,30,0"
                              VerticalAlignment="Center"
                              Data="M 50,95 L 80,50 L 62,50 L 62,5 L 38,5 L 38,50 L 20,50 Z"/>
                        <TextBlock FontSize="96" FontWeight="Bold" Text="{Binding Path=depthText, FallbackValue=0.0 m}"/>
                    </StackPanel>
                </Border>

                <!-- Outer white border -->
                <Border CornerRadius="72"
                        BorderBrush="{StaticResource WhiteBorder}"
                        BorderThickness="8"
                        Background="Transparent"
                        VerticalAlignment="Top">

                    <!-- Inner black border -->
                    <Border CornerRadius="64"
                            BorderBrush="{StaticResource BlackBorder}"
                            BorderThickness="5"
                            Padding="54,24,66,24">
                        <Border.Background>
                            <SolidColorBrush Color="#EE0C1B33"/>
                        </Border.Background>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="90" Height="100" Stretch="Uniform" Margin="0,0,30,0"
                                  VerticalAlignment="Center"
                                  StrokeThickness="8" StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 50,95 L 80,50 L 62,50 L 62,5 L 38,5 L 38,50 L 20,50 Z">
                                <Path.Stroke>
                                    <SolidColorBrush Color="#FFFFFFFF"/>
                                </Path.Stroke>
                                <Path.Fill>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="#00FFFF" Offset="0"/>
                                        <GradientStop Color="#0066AA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.Fill>
                            </Path>
                            <TextBlock Text="{Binding depthText}"
                                       FontSize="96"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Stroke="#FF000000"
                                       StrokeThickness="6"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
