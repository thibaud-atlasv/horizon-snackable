<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="Transparent" d:DesignWidth="300" d:DesignHeight="300">

    <Page.Resources>

        <!--
            FillBehavior="Stop": when the storyboard ends (1.1s), all animated values
            revert to their base values automatically. This is the clean re-trigger fix —
            no Stop DataTrigger needed. The next True transition always starts from base.
        -->
        <Storyboard x:Key="GoldExplosionStoryboard" FillBehavior="Stop">

            <!-- ── Container explosive pop: 0 → 2.2 → 1 in 0.16s ── -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContainerScale" Storyboard.TargetProperty="ScaleX">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.07" Value="2.2">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.16" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContainerScale" Storyboard.TargetProperty="ScaleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.07" Value="2.2">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.16" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <!-- ── Text scale pop: 0 → 1.5 → 1 in 0.28s ── -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TextScale" Storyboard.TargetProperty="ScaleX">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.5">
                    <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.28" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TextScale" Storyboard.TargetProperty="ScaleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.5">
                    <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.28" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <!-- ── Text floats up 100px over 0.85s (starts at 0.1s) ── -->
            <DoubleAnimation Storyboard.TargetName="TextTranslate" Storyboard.TargetProperty="Y"
                             From="0" To="-100" Duration="0:0:0.85" BeginTime="0:0:0.1">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- ── Text fades out (0.55s → 0.95s) ── -->
            <DoubleAnimation Storyboard.TargetName="TextGroup" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.4" BeginTime="0:0:0.55"/>

            <!-- ════ Coins: fast burst in 0.12s, hold at max, fade 0.3s ════ -->

            <!-- Icon 0 (N) -->
            <DoubleAnimation Storyboard.TargetName="Icon0Translate" Storyboard.TargetProperty="Y"
                             From="0" To="-160" Duration="0:0:0.12" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Icon0Rotate" Storyboard.TargetProperty="Angle"
                             From="0" To="720" Duration="0:0:0.4" BeginTime="0:0:0"/>
            <DoubleAnimation Storyboard.TargetName="Icon0" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3" BeginTime="0:0:0.15"/>

            <!-- Icon 1 (NE) -->
            <DoubleAnimation Storyboard.TargetName="Icon1Translate" Storyboard.TargetProperty="X"
                             From="0" To="113" Duration="0:0:0.12" BeginTime="0:0:0.02">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Icon1Translate" Storyboard.TargetProperty="Y"
                             From="0" To="-113" Duration="0:0:0.12" BeginTime="0:0:0.02">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Icon1Rotate" Storyboard.TargetProperty="Angle"
                             From="0" To="720" Duration="0:0:0.4" BeginTime="0:0:0.02"/>
            <DoubleAnimation Storyboard.TargetName="Icon1" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3" BeginTime="0:0:0.17"/>

            <!-- Icon 2 (E) -->
            <DoubleAnimation Storyboard.TargetName="Icon2Translate" Storyboard.TargetProperty="X"
                             From="0" To="160" Duration="0:0:0.12" BeginTime="0:0:0.04">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Icon2Rotate" Storyboard.TargetProperty="Angle"
                             From="0" To="720" Duration="0:0:0.4" BeginTime="0:0:0.04"/>
            <DoubleAnimation Storyboard.TargetName="Icon2" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3" BeginTime="0:0:0.19"/>

            <!-- Icon 3 (SE) -->
            <DoubleAnimation Storyboard.TargetName="Icon3Translate" Storyboard.TargetProperty="X"
                             From="0" To="113" Duration="0:0:0.12" BeginTime="0:0:0.06">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Icon3Translate" Storyboard.TargetProperty="Y"
                             From="0" To="113" Duration="0:0:0.12" BeginTime="0:0:0.06">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Icon3Rotate" Storyboard.TargetProperty="Angle"
                             From="0" To="720" Duration="0:0:0.4" BeginTime="0:0:0.06"/>
            <DoubleAnimation Storyboard.TargetName="Icon3" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3" BeginTime="0:0:0.21"/>

            <!-- Icon 4 (S) -->
            <DoubleAnimation Storyboard.TargetName="Icon4Translate" Storyboard.TargetProperty="Y"
                             From="0" To="160" Duration="0:0:0.12" BeginTime="0:0:0.08">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Icon4Rotate" Storyboard.TargetProperty="Angle"
                             From="0" To="720" Duration="0:0:0.4" BeginTime="0:0:0.08"/>
            <DoubleAnimation Storyboard.TargetName="Icon4" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3" BeginTime="0:0:0.23"/>

            <!-- Icon 5 (SW) -->
            <DoubleAnimation Storyboard.TargetName="Icon5Translate" Storyboard.TargetProperty="X"
                             From="0" To="-113" Duration="0:0:0.12" BeginTime="0:0:0.10">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Icon5Translate" Storyboard.TargetProperty="Y"
                             From="0" To="113" Duration="0:0:0.12" BeginTime="0:0:0.10">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Icon5Rotate" Storyboard.TargetProperty="Angle"
                             From="0" To="720" Duration="0:0:0.4" BeginTime="0:0:0.10"/>
            <DoubleAnimation Storyboard.TargetName="Icon5" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3" BeginTime="0:0:0.25"/>

            <!-- Icon 6 (W) -->
            <DoubleAnimation Storyboard.TargetName="Icon6Translate" Storyboard.TargetProperty="X"
                             From="0" To="-160" Duration="0:0:0.12" BeginTime="0:0:0.12">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Icon6Rotate" Storyboard.TargetProperty="Angle"
                             From="0" To="720" Duration="0:0:0.4" BeginTime="0:0:0.12"/>
            <DoubleAnimation Storyboard.TargetName="Icon6" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3" BeginTime="0:0:0.27"/>

            <!-- Icon 7 (NW) -->
            <DoubleAnimation Storyboard.TargetName="Icon7Translate" Storyboard.TargetProperty="X"
                             From="0" To="-113" Duration="0:0:0.12" BeginTime="0:0:0.14">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Icon7Translate" Storyboard.TargetProperty="Y"
                             From="0" To="-113" Duration="0:0:0.12" BeginTime="0:0:0.14">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Icon7Rotate" Storyboard.TargetProperty="Angle"
                             From="0" To="720" Duration="0:0:0.4" BeginTime="0:0:0.14"/>
            <DoubleAnimation Storyboard.TargetName="Icon7" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3" BeginTime="0:0:0.29"/>

            <!-- ── Container fade: 0.85s → 1.05s ── -->
            <DoubleAnimation Storyboard.TargetName="RootContainer" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2" BeginTime="0:0:0.85"/>

        </Storyboard>
    </Page.Resources>

    <Viewbox Width="300" Height="300" Stretch="Uniform">
        <Grid x:Name="RootContainer" Width="300" Height="300" Opacity="1"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="ContainerScale" ScaleX="1" ScaleY="1"/>
            </Grid.RenderTransform>

            <b:Interaction.Triggers>
                <b:DataTrigger Binding="{Binding isPlaying}" Value="True">
                    <b:ControlStoryboardAction Storyboard="{StaticResource GoldExplosionStoryboard}"/>
                </b:DataTrigger>
            </b:Interaction.Triggers>

            <!-- ── 8 Gold Icons (50×50, centered at 125,125) ── -->
            <Canvas Width="300" Height="300">
                <Image x:Name="Icon0" Source="Textures/gold_icon.png" Width="50" Height="50"
                       Canvas.Left="125" Canvas.Top="125" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="Icon0Rotate" Angle="0"/>
                            <TranslateTransform x:Name="Icon0Translate" X="0" Y="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                <Image x:Name="Icon1" Source="Textures/gold_icon.png" Width="50" Height="50"
                       Canvas.Left="125" Canvas.Top="125" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="Icon1Rotate" Angle="0"/>
                            <TranslateTransform x:Name="Icon1Translate" X="0" Y="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                <Image x:Name="Icon2" Source="Textures/gold_icon.png" Width="50" Height="50"
                       Canvas.Left="125" Canvas.Top="125" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="Icon2Rotate" Angle="0"/>
                            <TranslateTransform x:Name="Icon2Translate" X="0" Y="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                <Image x:Name="Icon3" Source="Textures/gold_icon.png" Width="50" Height="50"
                       Canvas.Left="125" Canvas.Top="125" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="Icon3Rotate" Angle="0"/>
                            <TranslateTransform x:Name="Icon3Translate" X="0" Y="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                <Image x:Name="Icon4" Source="Textures/gold_icon.png" Width="50" Height="50"
                       Canvas.Left="125" Canvas.Top="125" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="Icon4Rotate" Angle="0"/>
                            <TranslateTransform x:Name="Icon4Translate" X="0" Y="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                <Image x:Name="Icon5" Source="Textures/gold_icon.png" Width="50" Height="50"
                       Canvas.Left="125" Canvas.Top="125" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="Icon5Rotate" Angle="0"/>
                            <TranslateTransform x:Name="Icon5Translate" X="0" Y="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                <Image x:Name="Icon6" Source="Textures/gold_icon.png" Width="50" Height="50"
                       Canvas.Left="125" Canvas.Top="125" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="Icon6Rotate" Angle="0"/>
                            <TranslateTransform x:Name="Icon6Translate" X="0" Y="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                <Image x:Name="Icon7" Source="Textures/gold_icon.png" Width="50" Height="50"
                       Canvas.Left="125" Canvas.Top="125" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="Icon7Rotate" Angle="0"/>
                            <TranslateTransform x:Name="Icon7Translate" X="0" Y="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
            </Canvas>

            <!-- ── Gold value text — pops then floats up ── -->
            <Grid x:Name="TextGroup" HorizontalAlignment="Center" VerticalAlignment="Center"
                  Opacity="1" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="TextScale" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="TextTranslate" X="0" Y="0"/>
                    </TransformGroup>
                </Grid.RenderTransform>
                <TextBlock Text="{Binding goldValue}" FontSize="64" FontWeight="Bold"
                           Foreground="#88000000"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.RenderTransform><TranslateTransform Y="4" X="3"/></TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock Text="{Binding goldValue}" FontSize="64" FontWeight="Bold"
                           Foreground="#FFFFD700" Stroke="#FF000000" StrokeThickness="5"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Viewbox>
</Page>
