    <Viewbox Stretch="Uniform">
        <Canvas Width="800" Height="1200">
            <!-- Slot 0 -->
            <Grid x:Name="Slot0" Canvas.Left="{Binding OffsetX0}" Canvas.Top="{Binding OffsetY0}" Opacity="{Binding Opacity0}" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </TransformGroup>
                </Grid.RenderTransform>
                <b:Interaction.Triggers>
                    <b:DataTrigger Binding="{Binding Visible0}" Value="True">
                        <b:ControlStoryboardAction Storyboard="{StaticResource FloatAnim0}"/>
                    </b:DataTrigger>
                </b:Interaction.Triggers>
                <TextBlock Text="{Binding Text0}" FontSize="48" FontWeight="Bold"
                           Foreground="{StaticResource TextShadow}" Margin="2,2,0,0"/>
                <TextBlock Text="{Binding Text0}" FontSize="48" FontWeight="Bold"
                           Foreground="{Binding Color0}"/>
            </Grid>
