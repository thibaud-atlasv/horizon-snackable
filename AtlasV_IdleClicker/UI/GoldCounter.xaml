<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      Background="Transparent">

    <Page.Resources>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="GoldColor" Color="#FFFFD700"/>
        <SolidColorBrush x:Key="TextShadow" Color="#80000000"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#60000000"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#80FFD700"/>

        <!-- Pulse Animation Storyboard -->
        <Storyboard x:Key="PulseAnimation">
            <!-- Scale X: 1.0 -> 1.1 -> 1.0 -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GoldDisplayPanel"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseIn"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <!-- Scale Y: 1.0 -> 1.1 -> 1.0 -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GoldDisplayPanel"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseIn"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Page.Resources>

    <!-- Main layout - top-aligned gold counter -->
    <Viewbox Stretch="Uniform" VerticalAlignment="Top" HorizontalAlignment="Center">
        <Grid Width="600" Height="120" Margin="0,150,0,0">
            <!-- Background panel with rounded corners -->
            <Border Background="{StaticResource PanelBackground}"
                    BorderThickness="2"
                    CornerRadius="20"
                    Padding="30,10">
                
                <!-- Gold display with RenderTransform for animation -->
                <StackPanel x:Name="GoldDisplayPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5">
                    
                    <!-- RenderTransform for pulse animation -->
                    <StackPanel.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </StackPanel.RenderTransform>

                    <!-- PropertyChangedTrigger to play animation when AnimationTrigger changes -->
                    <b:Interaction.Triggers>
                        <b:PropertyChangedTrigger Binding="{Binding Path=AnimationTrigger}">
                            <b:ControlStoryboardAction Storyboard="{StaticResource PulseAnimation}"/>
                        </b:PropertyChangedTrigger>
                    </b:Interaction.Triggers>
                    
                    <!-- Gold coin icon -->
                    <Image Source="Textures/UI/gold_icon.png"
                           Width="48"
                           Height="48"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>
                    
                    <!-- Gold amount -->
                    <TextBlock Text="{Binding Path=GoldDisplay}"
                               FontSize="56"
                               FontWeight="Bold"
                               Foreground="{StaticResource GoldColor}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Viewbox>
</Page>
