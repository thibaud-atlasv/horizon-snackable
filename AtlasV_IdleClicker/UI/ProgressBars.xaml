<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" Padding="0,0,0,500" BorderThickness="2,2,2,2" BorderBrush="#FFFFFFFF">

    <Page.Resources>
        <SolidColorBrush x:Key="GeneratorColor" Color="#FF3498DB"/>
        <SolidColorBrush x:Key="FrenzyColor" Color="#FFF39C12"/>
        <SolidColorBrush x:Key="InterestColor" Color="#FF27AE60"/>
        <SolidColorBrush x:Key="VaultColor" Color="#FF9B59B6"/>
        <SolidColorBrush x:Key="TrackBackground" Color="#40313131"/>
        <SolidColorBrush x:Key="IconColor" Color="#FFFFFFFF"/>
    </Page.Resources>

    <Grid>
        <!-- Left side bars (Generator, Frenzy) -->
        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Center" Margin="150,0,0,0">
            
            <!-- Generator Bar -->
            <Grid Visibility="{Binding GeneratorVisibility}" Width="96">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Height="750" VerticalAlignment="Bottom" Width="64">
                    <Border Background="{StaticResource TrackBackground}" CornerRadius="16" BorderThickness="2,2,2,2" BorderBrush="#FFFFFFFF"/>
                    <Border Background="{StaticResource GeneratorColor}" CornerRadius="16" 
                            VerticalAlignment="Bottom"
                            Height="{Binding GeneratorFillHeight}" Margin="2,2,2,2"/>
                </Grid>
                
                <Image Grid.Row="1" HorizontalAlignment="Center" Margin="0,12,0,0" Source="/Root;component/Textures/UI/generator.png" Width="128" Height="128"/>
            </Grid>
            
            <Grid Width="60"/>
            
            <!-- Frenzy Bar -->
            <Grid Visibility="{Binding FrenzyVisibility}" Width="96">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Height="750" VerticalAlignment="Bottom" Width="64">
                    <Border Background="{StaticResource TrackBackground}" CornerRadius="16" BorderThickness="2,2,2,2" BorderBrush="#FFFFFFFF"/>
                    <Border Background="{StaticResource FrenzyColor}" CornerRadius="16" 
                            VerticalAlignment="Bottom"
                            Height="{Binding FrenzyFillHeight}"/>
                </Grid>
                
                <Image Grid.Row="1" HorizontalAlignment="Center" Margin="0,12,0,0" Source="/Root;component/Textures/UI/frenzy.png" Width="128" Height="128"/>
            </Grid>
        </StackPanel>
        
        <!-- Right side bars (Interest, Vault) -->
        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Center" Margin="0,0,150,0">
            
            <!-- Interest Bar -->
            <Grid Visibility="{Binding InterestVisibility}" Width="96">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Height="750" VerticalAlignment="Bottom" Width="64">
                    <Border Background="{StaticResource TrackBackground}" CornerRadius="16" BorderThickness="2,2,2,2" BorderBrush="#FFFFFFFF"/>
                    <Border Background="{StaticResource InterestColor}" CornerRadius="16" 
                            VerticalAlignment="Bottom"
                            Height="{Binding InterestFillHeight}"/>
                </Grid>
                
                <Image Grid.Row="1" HorizontalAlignment="Center" Margin="0,12,0,0" Source="/Root;component/Textures/UI/interest.png" Width="128" Height="128"/>
            </Grid>
            
            <Grid Width="60"/>
            
            <!-- Vault Bar -->
            <Grid Visibility="{Binding VaultVisibility}" Width="96">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Height="750" VerticalAlignment="Bottom" Width="64">
                    <Border Background="{StaticResource TrackBackground}" CornerRadius="16" BorderThickness="2,2,2,2" BorderBrush="#FFFFFFFF"/>
                    <Border Background="{StaticResource VaultColor}" CornerRadius="16" 
                            VerticalAlignment="Bottom"
                            Height="{Binding VaultFillHeight}"/>
                </Grid>
                
                <Image Grid.Row="1" HorizontalAlignment="Center" Margin="0,12,0,0" Source="/Root;component/Textures/UI/vault.png" Width="128" Height="128"/>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
