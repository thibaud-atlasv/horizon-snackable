<Page x:Name="Page0" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:noesis="clr-namespace:NoesisGUIExtensions"
      Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Top">

    <Page.Resources>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="ButtonGradientStart" Color="#FF1AB8C3"/>
        <SolidColorBrush x:Key="ButtonGradientEnd" Color="#FF1792EA"/>
        <SolidColorBrush x:Key="ButtonBorder" Color="#FFDBF3F4"/>
        <SolidColorBrush x:Key="ButtonText" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ButtonShadow" Color="#40000000"/>
        <SolidColorBrush x:Key="ButtonHighlight" Color="#80FFFFFF"/>
        <SolidColorBrush x:Key="GlowColor" Color="#801AB8C3"/>
        
        <!-- Tap Press Animation - Scale down quickly, bounce back with overshoot -->
        <Storyboard x:Key="TapPressAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TapButton" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <SplineDoubleKeyFrame KeySpline="0.4,0,0.6,1" Value="1.5" KeyTime="0:0:0"/>
                <SplineDoubleKeyFrame KeySpline="0.4,0,0.6,1" Value="1" KeyTime="0:0:0.500"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TapButton" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <SplineDoubleKeyFrame KeySpline="0.4,0,0.6,1" Value="1.5" KeyTime="0:0:0"/>
                <SplineDoubleKeyFrame KeySpline="0.4,0,0.6,1" Value="1" KeyTime="0:0:0.500"/>
            </DoubleAnimationUsingKeyFrames>
            <PointAnimationUsingKeyFrames Storyboard.TargetName="TapButton" Storyboard.TargetProperty="(UIElement.RenderTransformOrigin)">
                <LinearPointKeyFrame KeyTime="00:00:00" Value="0.5,0.5"/>
            </PointAnimationUsingKeyFrames>
        </Storyboard>
        
        <!-- Tap Button Style -->
        <Style x:Key="TapButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="Grid0">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition From="Pressed" GeneratedDuration="0">
                                            <Storyboard>
                                                <PointAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.RenderTransformOrigin)">
                                                    <LinearPointKeyFrame KeyTime="00:00:00" Value="0.5,0.5"/>
                                                </PointAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                                                    <LinearDoubleKeyFrame KeyTime="00:00:00" Value="1.5"/>
                                                    <LinearDoubleKeyFrame KeyTime="00:00:00.5000000" Value="1"/>
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Grid0" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                                                    <LinearDoubleKeyFrame KeyTime="00:00:00" Value="1.5"/>
                                                    <LinearDoubleKeyFrame KeyTime="00:00:00.5000000" Value="1"/>
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualTransition>
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver"/>
                                    <VisualState x:Name="Pressed"/>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Grid.RenderTransform>
                            <!-- Animated glow ring (behind button) -->
                            <Ellipse x:Name="GlowRing" 
                                     Width="680" Height="680"
                                     Opacity="0.2"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#001AB8C3" Offset="0.6"/>
                                        <GradientStop Color="#801AB8C3" Offset="0.85"/>
                                        <GradientStop Color="#001AB8C3" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            
                            <!-- Button container for scale animation -->
                            <Grid x:Name="ButtonContainer" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                
                                <!-- Outer glow / shadow ring -->
                                <Ellipse Width="640" Height="640"
                                         Fill="{StaticResource ButtonShadow}"
                                         Margin="0,16,0,0"/>
                                
                                <!-- Main button circle with gradient -->
                                <Ellipse x:Name="ButtonBackground" 
                                         Width="600" Height="600">
                                    <Ellipse.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF1AB8C3" Offset="0"/>
                                            <GradientStop Color="#FF1792EA" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                
                                <!-- Inner highlight for 3D effect -->
                                
                                <!-- Border ring -->
                                <Ellipse Width="600" Height="600"
                                         Stroke="{StaticResource ButtonBorder}"
                                         StrokeThickness="4"
                                         Fill="Transparent"/>
                                
                                <!-- Button content (text) -->
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Page.Transform3D>
        <noesis:CompositeTransform3D/>
    </Page.Transform3D>
    <Grid x:Name="Viewbox0" Width="900" Height="1600" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,300,0,0">
        <Button x:Name="TapButton" Style="{StaticResource TapButtonStyle}" Command="{Binding Path=events.buttonClick}" HorizontalAlignment="Center" VerticalAlignment="Top" Width="680" Height="680">
            <b:Interaction.Triggers>
                <!-- Play animation on user click -->
                <b:EventTrigger EventName="Click">
                    <b:ControlStoryboardAction Storyboard="{StaticResource TapPressAnimation}"/>
                </b:EventTrigger>
                <!-- Play animation on programmatic trigger (whenever TriggerAnimation changes value) -->
                <b:PropertyChangedTrigger Binding="{Binding Path=TriggerAnimation}">
                    <b:ControlStoryboardAction Storyboard="{StaticResource TapPressAnimation}"/>
                </b:PropertyChangedTrigger>
            </b:Interaction.Triggers>
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform Y="750"/>
                </TransformGroup>
            </Button.RenderTransform>
            <TextBlock x:Name="TextBlock0" Text="{Binding Path=ButtonLabel}" FontSize="72" FontWeight="Bold" Foreground="{StaticResource ButtonText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>
    </Grid>

    <!-- Main layout - centered button -->
</Page>
