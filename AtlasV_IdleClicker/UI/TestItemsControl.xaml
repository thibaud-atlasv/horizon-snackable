<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <!-- Vertical panel template for ItemsControl -->
        <ItemsPanelTemplate x:Key="VerticalPanel">
            <StackPanel Orientation="Vertical"/>
        </ItemsPanelTemplate>

        <!-- Container style with margin -->
        <Style x:Key="ItemContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Colors -->
        <SolidColorBrush x:Key="PanelBg" Color="#CC222222"/>
        <SolidColorBrush x:Key="ItemBg" Color="#80444444"/>
        <SolidColorBrush x:Key="TextColor" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="AccentColor" Color="#FF00CCFF"/>
    </Page.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="900" Height="1600">
            <!-- Test Panel - positioned on left side -->
            <Border Background="{StaticResource PanelBg}"
                    CornerRadius="16"
                    Padding="20"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="20,200,0,0"
                    Width="350">
                
                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="ItemsControl Test"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentColor}"
                               Margin="0,0,0,16"/>

                    <!-- Status indicator -->
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="16"
                               Foreground="{StaticResource TextColor}"
                               Margin="0,0,0,12"/>

                    <!-- THE TEST: ItemsControl with ItemsSource binding -->
                    <ItemsControl ItemsSource="{Binding Items}"
                                  ItemsPanel="{StaticResource VerticalPanel}"
                                  ItemContainerStyle="{StaticResource ItemContainerStyle}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Each item renders as a bordered text block -->
                                <Border Background="{StaticResource ItemBg}"
                                        CornerRadius="8"
                                        Padding="12,8">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="18"
                                               Foreground="{StaticResource TextColor}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Item count display (to verify binding works) -->
                    <TextBlock Text="{Binding ItemCountText}"
                               FontSize="14"
                               Foreground="{StaticResource AccentColor}"
                               Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Viewbox>
</Page>
