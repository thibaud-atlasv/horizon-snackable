<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      Background="Transparent">

    <Page.Resources>
        <!-- Bool-to-Visibility converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Color Palette - Warehouse Theme (matching WarehouseGauge) -->
        <SolidColorBrush x:Key="PanelBorder" Color="#FF2E7D32"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#FF1A1A1A"/>
        <SolidColorBrush x:Key="HeaderBackground" Color="#FF0D1A0D"/>
        <SolidColorBrush x:Key="HeaderText" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="TextShadow" Color="#80000000"/>
        <SolidColorBrush x:Key="ButtonText" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="DescriptionText" Color="#FFA0D4E4"/>
        <SolidColorBrush x:Key="PriceText" Color="#FFFFD700"/>
        <SolidColorBrush x:Key="PriceBoxBorder" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="PriceBoxBackground" Color="#40000000"/>
        <SolidColorBrush x:Key="ActiveButtonBg" Color="#CC1A1A1A"/>
        <SolidColorBrush x:Key="ActiveButtonBorder" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="InnerButtonBorder" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="DisabledButtonBg" Color="#FF1A1A1A"/>
        <SolidColorBrush x:Key="DisabledButtonBorder" Color="#FF404040"/>
        <SolidColorBrush x:Key="DisabledText" Color="#FF666666"/>

        <!-- Vertical Panel Template for ItemsControl -->
        <ItemsPanelTemplate x:Key="VerticalPanel">
            <Canvas/>
        </ItemsPanelTemplate>

        <!-- Upgrade Item Button Style -->
        <Style x:Key="UpgradeItemButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Outer Border: Green thick border -->
                        <Border x:Name="OuterBorder"
                                BorderBrush="{StaticResource PanelBorder}"
                                BorderThickness="4"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ItemScale" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="ItemTranslate" X="0" Y="0"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <!-- Inner Border: Dark gray border with semi-transparent background -->
                            <Border x:Name="ItemBorder" 
                                    Background="{StaticResource ActiveButtonBg}"
                                    BorderBrush="{StaticResource InnerButtonBorder}"
                                    BorderThickness="3"
                                    CornerRadius="8"
                                    Padding="15">
                                <ContentPresenter x:Name="ContentArea"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{StaticResource DisabledButtonBorder}"/>
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource DisabledButtonBg}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource DisabledButtonBorder}"/>
                                <Setter TargetName="OuterBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>

        <!-- Upgrade Item DataTemplate -->
        <DataTemplate x:Key="UpgradeItemTemplate">
            <Border RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TranslateTransform X="{Binding PositionX}" Y="{Binding PositionY}"/>
                </Border.RenderTransform>
                <Border x:Name="AnimationContainer" 
                        RenderTransformOrigin="0.5,0.5">
                
                <!-- DataTrigger: plays animation when AnimationTrigger > 0 -->
                <b:Interaction.Triggers>
                    <b:DataTrigger Binding="{Binding AnimationTrigger}" Comparison="GreaterThan" Value="0">
                        <b:ControlStoryboardAction>
                            <b:ControlStoryboardAction.Storyboard>
                                <Storyboard>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.0"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.12" Value="1.08">
                                            <EasingDoubleKeyFrame.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0">
                                            <EasingDoubleKeyFrame.EasingFunction>
                                                <QuadraticEase EasingMode="EaseIn"/>
                                            </EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                    </DoubleAnimationUsingKeyFrames>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.0"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.12" Value="1.08">
                                            <EasingDoubleKeyFrame.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0">
                                            <EasingDoubleKeyFrame.EasingFunction>
                                                <QuadraticEase EasingMode="EaseIn"/>
                                            </EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </b:ControlStoryboardAction.Storyboard>
                        </b:ControlStoryboardAction>
                    </b:DataTrigger>
                </b:Interaction.Triggers>
                
                <Button Style="{StaticResource UpgradeItemButtonStyle}"
                        Command="{Binding DataContext.events.UpgradeItemClick, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding UpgradeId}"
                        IsEnabled="{Binding IsEnabled}">
                    <StackPanel HorizontalAlignment="Stretch">
                        <!-- Top: Small Title with shadow -->
                        <Grid HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Normal"
                                       Foreground="{StaticResource TextShadow}" Margin="1,1,0,0"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Normal"
                                       Foreground="{StaticResource ButtonText}"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                        <!-- Middle: Small Description -->
                        <TextBlock Text="{Binding Description}" FontSize="14"
                                   Foreground="{StaticResource DescriptionText}"
                                   TextWrapping="Wrap" Margin="0,4,0,8"
                                   HorizontalAlignment="Center" TextAlignment="Center" Visibility="Collapsed"/>
                        <!-- Bottom: BIG PRICE with gold icon - dominant element, centered -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="Textures/gold_icon.png" 
                                   Width="32" Height="32" 
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                            <Grid>
                                <TextBlock Text="{Binding Price}" FontSize="38" FontWeight="Bold"
                                           Foreground="{StaticResource TextShadow}"
                                           VerticalAlignment="Center" Margin="1,1,0,0"/>
                                <TextBlock Text="{Binding Price}" FontSize="38" FontWeight="Bold"
                                           Foreground="{StaticResource PriceText}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Button>
                </Border>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="900" Height="1600">
            <!-- Upgrade Panel - positioned at bottom, dynamic height -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="UpgradeItemsControl" ItemsSource="{Binding Items}" ItemsPanel="{StaticResource VerticalPanel}" ItemTemplate="{StaticResource UpgradeItemTemplate}"/>
            </ScrollViewer>
        </Grid>
    </Viewbox>
</Page>
