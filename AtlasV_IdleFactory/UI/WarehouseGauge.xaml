<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Width="200" Height="50">
    
    <!-- Outer border for mobile-friendly thick border -->
    <Border BorderBrush="#FF2E7D32" 
            BorderThickness="4" 
            CornerRadius="8"
            Background="#FF1A1A1A">
        
        <!-- Inner container for progress bar -->
        <Grid Margin="4">
            <!-- Background track (dark) -->
            <Border Background="#FF2D2D2D" 
                    CornerRadius="4"/>
            
            <!-- Progress fill (green) - width bound to progress percentage -->
            <Border Background="#FF4CAF50" 
                    CornerRadius="4"
                    HorizontalAlignment="Left">
                <Border.Width>
                    <Binding Path="fillWidth"/>
                </Border.Width>
            </Border>
            
            <!-- Centered text showing stock/capacity -->
            <TextBlock Text="{Binding Path=displayText}"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>
    </Border>
</Grid>
