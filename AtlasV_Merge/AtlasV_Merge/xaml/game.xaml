<Grid Background="Black"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis">

  <Grid.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </Grid.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="480" Height="800">

      <!-- Layer 1: Game canvas (DrawingSurface) -->
      <local:DrawingSurface Width="480" Height="800"
                            Commands="{Binding drawCommands}" />

      <!-- Layer 2: Score HUD — top-left pill with best above current -->
      <Border VerticalAlignment="Top" HorizontalAlignment="Left"
              Margin="36,6,0,0"
              Background="#CCFFE4EC" CornerRadius="16"
              Padding="14,5,14,7"
              BorderBrush="#44FF8FAB" BorderThickness="1">
        <StackPanel>
          <!-- Best score — small, secondary, muted -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,-2">
            <TextBlock Text="BEST " FontSize="10" Foreground="#AA996655"
                       FontFamily="Bangers" FontWeight="Normal" VerticalAlignment="Bottom" />
            <TextBlock Text="{Binding bestScoreText}" FontSize="16" Foreground="#BB885533"
                       FontFamily="Bangers" FontWeight="Normal" VerticalAlignment="Bottom" />
          </StackPanel>
          <!-- Current score — big, bold, primary with scale animation -->
          <Grid Margin="0,-1,0,0">
            <TextBlock Text="{Binding scoreText}" FontSize="34" Foreground="#33664455"
                       FontFamily="Bangers" FontWeight="Normal"
                       Margin="1,1,0,0"
                       RenderTransformOrigin="0,0.5">
              <TextBlock.RenderTransform>
                <ScaleTransform ScaleX="{Binding scoreScale}" ScaleY="{Binding scoreScale}" />
              </TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock Text="{Binding scoreText}" FontSize="34" Foreground="#DD553355"
                       FontFamily="Bangers" FontWeight="Normal"
                       RenderTransformOrigin="0,0.5">
              <TextBlock.RenderTransform>
                <ScaleTransform ScaleX="{Binding scoreScale}" ScaleY="{Binding scoreScale}" />
              </TextBlock.RenderTransform>
            </TextBlock>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Layer 3: Game Over overlay — warm candy themed panel -->
      <Grid Visibility="{Binding gameOverVisible, Converter={StaticResource BoolToVis}}">
        <!-- Semi-transparent warm backdrop -->
        <Grid Background="#DD3D2020" />

        <!-- Centered candy-themed panel -->
        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="#F5FFE4EC" CornerRadius="28"
                Padding="40,28,40,32"
                BorderBrush="#66FF8FAB" BorderThickness="2">
          <StackPanel HorizontalAlignment="Center">
            <!-- GAME OVER title with warm pink color and fake shadow -->
            <Grid HorizontalAlignment="Center" Margin="0,0,0,6">
              <TextBlock Text="GAME OVER" FontSize="46" Foreground="#33664444"
                         FontWeight="Bold" FontFamily="Bangers"
                         HorizontalAlignment="Center" Margin="2,2,0,0" />
              <TextBlock Text="GAME OVER" FontSize="46" Foreground="#FF6B8A"
                         FontWeight="Bold" FontFamily="Bangers"
                         HorizontalAlignment="Center" />
            </Grid>

            <!-- NEW BEST! celebration in warm gold -->
            <TextBlock Text="★ NEW BEST! ★" FontSize="28" Foreground="#FFB347"
                       FontWeight="Bold" FontFamily="Bangers"
                       HorizontalAlignment="Center" Margin="0,0,0,10"
                       Visibility="{Binding isNewBest, Converter={StaticResource BoolToVis}}" />

            <!-- Score display in a soft inner pill -->
            <Border Background="#33FF8FAB" CornerRadius="14" Padding="24,7,24,9"
                    HorizontalAlignment="Center" Margin="0,0,0,4">
              <TextBlock FontSize="26" Foreground="#885533" FontFamily="Bangers"
                         HorizontalAlignment="Center">
                <Run Text="Score: " /><Run Text="{Binding scoreText}" />
              </TextBlock>
            </Border>

            <!-- Best score -->
            <TextBlock FontSize="15" Foreground="#AA996655" FontFamily="Bangers"
                       HorizontalAlignment="Center" Margin="0,2,0,20">
              <Run Text="Best: " /><Run Text="{Binding bestScoreText}" />
            </TextBlock>

            <!-- Play Again button — warm coral/pink, large rounded pill -->
            <Button Content="Play Again"
                    Command="{Binding events.onRestartClicked}"
                    Width="210" Height="54" FontSize="22"
                    Background="#FF7B8A" Foreground="White"
                    FontWeight="Bold" FontFamily="Bangers" BorderThickness="0">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}"
                          CornerRadius="20" Padding="10,5"
                          BorderBrush="#44FFFFFF" BorderThickness="1">
                    <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                  </Border>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </StackPanel>
        </Border>
      </Grid>

    </Grid>
  </Viewbox>
</Grid>
