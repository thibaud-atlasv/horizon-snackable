<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis"
      Background="Black">
    <Viewbox Stretch="Uniform">
        <Grid Width="480" Height="800">
            <!-- Layer 1: DrawingSurface for procedural graphics (grid, glow, logo) -->
            <local:DrawingSurface Width="480" Height="800" Commands="{Binding drawCommands}"/>

            <!-- Layer 2: XAML text overlays on top of DrawingSurface -->

            <!-- === Two-line title with layered glow effects === -->

            <!-- LINE 1: "2D GAME" — Outer purple glow -->
            <TextBlock Text="2D GAME"
                       FontSize="54" FontWeight="Bold" FontFamily="Teko"
                       Foreground="#20A855F7" CharacterSpacing="280"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,296,0,0"/>
            <!-- LINE 1: Outer blue glow -->
            <TextBlock Text="2D GAME"
                       FontSize="54" FontWeight="Bold" FontFamily="Teko"
                       Foreground="#2058A6FF" CharacterSpacing="280"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,297,0,0"/>
            <!-- LINE 1: Mid blue glow -->
            <TextBlock Text="2D GAME"
                       FontSize="54" FontWeight="Bold" FontFamily="Teko"
                       Foreground="#4058A6FF" CharacterSpacing="280"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,299,0,0"/>
            <!-- LINE 1: Inner bright glow -->
            <TextBlock Text="2D GAME"
                       FontSize="54" FontWeight="Bold" FontFamily="Teko"
                       Foreground="#6088CCFF" CharacterSpacing="280"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,300,0,0"/>
            <!-- LINE 1: Main text -->
            <TextBlock Text="2D GAME"
                       FontSize="54" FontWeight="Bold" FontFamily="Teko"
                       Foreground="White" CharacterSpacing="280"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,301,0,0"/>

            <!-- LINE 2: "TEMPLATE" — Outer purple glow -->
            <TextBlock Text="TEMPLATE"
                       FontSize="48" FontWeight="Bold" FontFamily="Teko"
                       Foreground="#20A855F7" CharacterSpacing="240"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,354,0,0"/>
            <!-- LINE 2: Outer blue glow -->
            <TextBlock Text="TEMPLATE"
                       FontSize="48" FontWeight="Bold" FontFamily="Teko"
                       Foreground="#2058A6FF" CharacterSpacing="240"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,355,0,0"/>
            <!-- LINE 2: Mid blue glow -->
            <TextBlock Text="TEMPLATE"
                       FontSize="48" FontWeight="Bold" FontFamily="Teko"
                       Foreground="#4058A6FF" CharacterSpacing="240"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,357,0,0"/>
            <!-- LINE 2: Inner bright glow -->
            <TextBlock Text="TEMPLATE"
                       FontSize="48" FontWeight="Bold" FontFamily="Teko"
                       Foreground="#6088CCFF" CharacterSpacing="240"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,358,0,0"/>
            <!-- LINE 2: Main text -->
            <TextBlock Text="TEMPLATE"
                       FontSize="48" FontWeight="Bold" FontFamily="Teko"
                       Foreground="White" CharacterSpacing="240"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,359,0,0"/>

            <!-- Accent line under title (widened for larger title) -->
            <Border Height="2" Width="200" Background="#58A6FF"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="0,418,0,0" CornerRadius="1"/>

            <!-- Subtitle / Tagline with subtle void tech glow -->
            <!-- Glow layer 1: Outer purple glow -->
            <TextBlock Text="{Binding taglineText}"
                       FontSize="15" FontWeight="Normal" FontFamily="Roboto"
                       Foreground="#10A855F7" CharacterSpacing="80"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,434,0,0"/>
            <!-- Glow layer 2: Mid blue glow -->
            <TextBlock Text="{Binding taglineText}"
                       FontSize="15" FontWeight="Normal" FontFamily="Roboto"
                       Foreground="#1858A6FF" CharacterSpacing="80"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,435,0,0"/>
            <!-- Main tagline text -->
            <TextBlock Text="{Binding taglineText}"
                       FontSize="15" FontWeight="Normal" FontFamily="Roboto"
                       Foreground="#99ACB8CC" CharacterSpacing="80"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,436,0,0"/>
        </Grid>
    </Viewbox>
</Grid>
