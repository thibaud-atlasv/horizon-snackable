<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Title Pop-In Animation -->
        <Storyboard x:Key="TitlePopAnim">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleBlock"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.3"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.15">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleBlock"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.3"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.15">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TitleBlock"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Content Fade-In Animation -->
        <Storyboard x:Key="ContentFadeInAnim">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContentContainer"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContentContainer"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="30"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="30"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Page.Resources>

    <!-- Main Container - Visibility bound to isVisible -->
    <Grid>
        <Grid.Visibility>
            <Binding Path="isVisible">
                <Binding.Converter>
                    <BooleanToVisibilityConverter/>
                </Binding.Converter>
            </Binding>
        </Grid.Visibility>

        <!-- Trigger animations when visible -->
        <b:Interaction.Triggers>
            <b:DataTrigger Binding="{Binding Path=isVisible}" Value="True">
                <b:ControlStoryboardAction Storyboard="{StaticResource TitlePopAnim}"/>
                <b:ControlStoryboardAction Storyboard="{StaticResource ContentFadeInAnim}"/>
            </b:DataTrigger>
        </b:Interaction.Triggers>

        <!-- Radial gradient background matching app style -->

        <Viewbox Stretch="Uniform">
            <Grid Width="480" Height="800" Background="#E6000000">
                <!-- Full-screen semi-transparent dark overlay -->
                <Border Visibility="Collapsed">
                    <Border.Background>
                        <RadialGradientBrush>
                            <GradientStop Color="#1E2A1A4E" Offset="1"/>
                            <GradientStop Offset="0" Color="#96120A2A"/>
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Decorative floating shapes scattered around the card -->
                <!-- Star Orange - Top Left -->
                <Image Source="shape/starfillOrange.png" Width="55" Height="55"
                       Opacity="0.5" IsHitTestVisible="False"
                       HorizontalAlignment="Left" VerticalAlignment="Top"
                       Margin="25,140,0,0" RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                    <Image.RenderTransform>
                        <RotateTransform Angle="-15"/>
                    </Image.RenderTransform>
                </Image>

                <!-- Heart Pink - Top Right -->
                <Image Source="shape/heartPink.png" Width="48" Height="48"
                       Opacity="0.55" IsHitTestVisible="False"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,160,30,0" RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                    <Image.RenderTransform>
                        <RotateTransform Angle="20"/>
                    </Image.RenderTransform>
                </Image>

                <!-- Hexagon Cyan - Left Middle -->
                <Image Source="shape/pentagonCyan.png" Width="50" Height="50"
                       Opacity="0.45" IsHitTestVisible="False"
                       HorizontalAlignment="Left" VerticalAlignment="Center"
                       Margin="15,-50,0,0" RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                    <Image.RenderTransform>
                        <RotateTransform Angle="30"/>
                    </Image.RenderTransform>
                </Image>

                <!-- Triangle Purple - Bottom Left -->
                <Image Source="shape/trianglePurple.png" Width="52" Height="52"
                       Opacity="0.5" IsHitTestVisible="False"
                       HorizontalAlignment="Left" VerticalAlignment="Bottom"
                       Margin="35,0,0,150" RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                    <Image.RenderTransform>
                        <RotateTransform Angle="-25"/>
                    </Image.RenderTransform>
                </Image>

                <!-- Pentagon Yellow - Bottom Right -->
                <Image Source="shape/pentagonYellow.png" Width="58" Height="58"
                       Opacity="0.6" IsHitTestVisible="False"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0,0,25,170" RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                    <Image.RenderTransform>
                        <RotateTransform Angle="12"/>
                    </Image.RenderTransform>
                </Image>

                <!-- Star Orange - Right Middle -->
                <Image Source="shape/starfillOrange.png" Width="42" Height="42"
                       Opacity="0.4" IsHitTestVisible="False"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       Margin="0,80,20,0" RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                    <Image.RenderTransform>
                        <RotateTransform Angle="45"/>
                    </Image.RenderTransform>
                </Image>

                <!-- Heart Pink - Bottom Center -->
                <Image Source="shape/heartPink.png" Width="40" Height="40"
                       Opacity="0.45" IsHitTestVisible="False"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom"
                       Margin="-100,0,0,120" RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                    <Image.RenderTransform>
                        <RotateTransform Angle="-10"/>
                    </Image.RenderTransform>
                </Image>

                <!-- Centered Cartouche Card -->
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Shadow border behind card (offset down-right) -->
                    <Border BorderThickness="50,50,50,50" CornerRadius="50,50,50,50" Background="#64000000" Margin="10,10,-5,-5"/>

                    <!-- Main card with golden border -->
                    <Border Width="360" Padding="24,20,24,24" BorderThickness="50,50,50,50" CornerRadius="50,50,50,50">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Offset="0" Color="#FF8B1FF0"/>
                                <GradientStop Offset="1" Color="#FF350F99"/>
                            </RadialGradientBrush>
                        </Border.Background>
                        <StackPanel>
                            <!-- Title Block with animation transforms -->
                            <Grid x:Name="TitleBlock" RenderTransformOrigin="0.5,0.5" Margin="0,0,0,8">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                <!-- Title with text shadow (layered TextBlock pattern) -->
                                <Grid HorizontalAlignment="Center" Visibility="Collapsed">
                                    <!-- Shadow text layer -->
                                    <TextBlock Text="{Binding Path=title}"
                                               FontWeight="Bold" FontSize="48"
                                               Foreground="#44000000" HorizontalAlignment="Center" FontFamily="Bangers">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform X="2" Y="2"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                    <!-- Main title text with bound color -->
                                    <TextBlock Text="{Binding Path=title}"
                                               FontWeight="Bold" FontSize="48"
                                               HorizontalAlignment="Center" FontFamily="Bangers">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                                <GradientStop Color="#FFFD2032" Offset="0.625"/>
                                                <GradientStop Color="#FFFF9BA8" Offset="0"/>
                                                <GradientStop Color="#FFFD2032" Offset="0.8744397"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Path=title}" FontWeight="Bold" FontSize="48" HorizontalAlignment="Center" FontFamily="Bangers">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                                <GradientStop Offset="0.494" Color="#FFFF1F31"/>
                                                <GradientStop Offset="0" Color="#FFFF7486"/>
                                                <GradientStop Offset="1" Color="#FFFF5C71"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </Grid>
                                <Image Source="/Root;component/Textures/gameover.png" RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="1.45" ScaleY="1.45"/>
                                            <SkewTransform/>
                                            <RotateTransform/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>

                            <!-- Content Container with animation transforms -->
                            <Grid x:Name="ContentContainer" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Grid.RenderTransform>

                                <StackPanel>
                                    <!-- Player Name -->
                                    <Grid HorizontalAlignment="Center" Margin="0,4,0,16">
                                        <!-- Shadow -->
                                        <TextBlock Text="{Binding Path=playerName}"
                                                   FontFamily="Roboto" FontWeight="Bold" FontSize="22"
                                                   Foreground="#33000000" HorizontalAlignment="Center">
                                            <TextBlock.RenderTransform>
                                                <TranslateTransform X="1" Y="1"/>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                        <!-- Main text -->
                                        <TextBlock Text="{Binding Path=playerName}"
                                                   FontFamily="Roboto" FontWeight="Bold" FontSize="22"
                                                   HorizontalAlignment="Center" Foreground="#FFFFFFFF"/>
                                    </Grid>

                                    <!-- Divider line -->
                                    <Border Height="2" Margin="20,0,20,16" CornerRadius="1" Background="#FFFDBA16"/>

                                    <!-- FINAL SCORE label -->
                                    <TextBlock Text="FINAL SCORE"
                                               FontFamily="Roboto" FontWeight="Bold" FontSize="14"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,4" Foreground="#FFFFFFFF"/>

                                    <!-- Score value - BIG -->
                                    <Grid HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <!-- Shadow -->
                                        <TextBlock Text="{Binding Path=yourScore, StringFormat=F0}"
                                                   FontFamily="Roboto" FontWeight="Bold" FontSize="56"
                                                   Foreground="#33000000" HorizontalAlignment="Center">
                                            <TextBlock.RenderTransform>
                                                <TranslateTransform X="2" Y="2"/>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                        <!-- Main score text -->
                                        <TextBlock Text="{Binding Path=yourScore, StringFormat=F0}"
                                                   FontFamily="Roboto" FontWeight="Bold" FontSize="56"
                                                   HorizontalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                                    <GradientStop Color="#FFFFD60E" Offset="1"/>
                                                    <GradientStop Color="#FFF9DD2F"/>
                                                </LinearGradientBrush>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Grid>

                                    <!-- Rank display with DataTrigger coloring -->
                                    <Grid HorizontalAlignment="Center" Margin="0,0,0,16">
                                        <!-- Shadow -->
                                        <TextBlock Text="{Binding Path=yourRankDisplay}"
                                                   FontFamily="Roboto" FontWeight="Bold" FontSize="32"
                                                   Foreground="#33000000" HorizontalAlignment="Center">
                                            <TextBlock.RenderTransform>
                                                <TranslateTransform X="1" Y="1"/>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                        <!-- Main rank text with DataTrigger coloring -->
                                        <TextBlock Text="{Binding Path=yourRankDisplay}"
                                                   FontFamily="Roboto" FontWeight="Bold" FontSize="32"
                                                   HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#78350f"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Path=yourRank}" Value="1">
                                                            <Setter Property="Foreground" Value="#FFD700"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Path=yourRank}" Value="2">
                                                            <Setter Property="Foreground" Value="#C0C0C0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Path=yourRank}" Value="3">
                                                            <Setter Property="Foreground" Value="#CD7F32"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <!-- Divider line -->
                                    <Border Height="1" Margin="40,0,40,12" CornerRadius="1" Background="#FFFDBA16"/>

                                    <!-- BEST SCORE label + value -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                                        <TextBlock Text="BEST SCORE: "
                                                   FontFamily="Roboto" FontWeight="Bold" FontSize="16"
                                                   VerticalAlignment="Center" Foreground="#FFFFFFFF"/>
                                        <TextBlock Text="{Binding Path=bestScore, StringFormat=F0}"
                                                   FontFamily="Roboto" FontSize="20"
                                                   VerticalAlignment="Center" FontWeight="ExtraBlack" Foreground="#FFFFF59F"/>
                                    </StackPanel>

                                    <!-- Loading text - visible when isLoading is true -->
                                    <Grid Margin="0,8,0,8"
                                          Visibility="{Binding Path=isLoading, Converter={StaticResource BoolToVis}}">
                                        <Grid HorizontalAlignment="Center">
                                            <!-- Shadow -->
                                            <TextBlock Text="Submitting..."
                                                       FontFamily="Roboto" FontWeight="Bold" FontSize="18"
                                                       Foreground="#33000000" HorizontalAlignment="Center">
                                                <TextBlock.RenderTransform>
                                                    <TranslateTransform X="1" Y="1"/>
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                            <!-- Main text -->
                                            <TextBlock Text="Submitting..."
                                                       FontFamily="Roboto" FontWeight="Bold" FontSize="18"
                                                       HorizontalAlignment="Center" Foreground="#FFFFFFFF"/>
                                        </Grid>
                                    </Grid>

                                    <!-- Error text - visible when errorMessage is non-empty -->
                                    <Grid Margin="0,8,0,8">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=errorMessage}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid HorizontalAlignment="Center">
                                            <!-- Shadow -->
                                            <TextBlock Text="{Binding Path=errorMessage}"
                                                       FontFamily="Roboto" FontWeight="Bold" FontSize="14"
                                                       Foreground="#33000000" HorizontalAlignment="Center"
                                                       TextWrapping="Wrap" MaxWidth="280" TextAlignment="Center">
                                                <TextBlock.RenderTransform>
                                                    <TranslateTransform X="1" Y="1"/>
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                            <!-- Main error text - reddish -->
                                            <TextBlock Text="{Binding Path=errorMessage}"
                                                       FontFamily="Roboto" FontWeight="Bold" FontSize="14"
                                                       Foreground="#dc2626" HorizontalAlignment="Center"
                                                       TextWrapping="Wrap" MaxWidth="280" TextAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Grid/>
                </Grid>
            </Grid>
        </Viewbox>
    </Grid>
</Page>
