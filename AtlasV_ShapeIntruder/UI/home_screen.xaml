                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.9"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="1.08">
                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:3" Value="0.9">
                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BgShape9"
                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.9"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="1.08">
                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:3" Value="0.9">
                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>

                <!-- Shape 10: Hexagon Purple - Mid Right Upper -->
                <Storyboard x:Key="BgShape10Anim" RepeatBehavior="Forever">
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BgShape10"
                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(TranslateTransform.Y)">
                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.6" Value="7">
                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:5.2" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BgShape10"
                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(RotateTransform.Angle)">
                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:14" Value="360"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BgShape10"
                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.95"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2" Value="1.1">
                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:4" Value="0.95">
                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BgShape10"
                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.95"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2" Value="1.1">
                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <EasingDoubleKeyFrame KeyTime="0:0:4" Value="0.95">
                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>
            </Grid.Resources>

            <!-- Semi-transparent violet border overlay (matching shape_display) -->
            <Border ClipToBounds="True" BorderThickness="10" CornerRadius="20" Opacity="0.444" Margin="0,20,0,6" IsHitTestVisible="False">
                <Border.Background>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFE738E9" Offset="0"/>
                        <GradientStop Offset="1" Color="#FF8139EE"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <!-- Animated Background Shapes -->
            <!-- Shape 1: Heart Pink - Top Left -->
            <Image x:Name="BgShape1" Source="shape/heartPink.png" Width="100" Height="100" 
                   Opacity="0.35" IsHitTestVisible="False"
                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="25,60,0,0"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <RotateTransform Angle="0"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
                <b:Interaction.Triggers>
                    <b:EventTrigger>
                        <b:ControlStoryboardAction Storyboard="{StaticResource BgShape1Anim}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </Image>

            <!-- Shape 2: Star Blue - Top Right -->
            <Image x:Name="BgShape2" Source="shape/starfillBlue.png" Width="110" Height="110" 
                   Opacity="0.38" IsHitTestVisible="False"
                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,80,30,0"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <RotateTransform Angle="15"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
                <b:Interaction.Triggers>
                    <b:EventTrigger>
                        <b:ControlStoryboardAction Storyboard="{StaticResource BgShape2Anim}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </Image>

            <!-- Shape 3: Hexagon Cyan - Left Middle -->
            <Image x:Name="BgShape3" Source="shape/pentagonCyan.png" Width="90" Height="90" 
                   Opacity="0.32" IsHitTestVisible="False"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,100"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <RotateTransform Angle="-10"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
                <b:Interaction.Triggers>
                    <b:EventTrigger>
                        <b:ControlStoryboardAction Storyboard="{StaticResource BgShape3Anim}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </Image>

            <!-- Shape 4: Triangle Yellow - Bottom Left -->
            <Image x:Name="BgShape4" Source="shape/triangleYellow.png" Width="120" Height="120" 
                   Opacity="0.4" IsHitTestVisible="False"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="35,0,0,70"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <RotateTransform Angle="20"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
                <b:Interaction.Triggers>
                    <b:EventTrigger>
                        <b:ControlStoryboardAction Storyboard="{StaticResource BgShape4Anim}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </Image>

            <!-- Shape 5: Circle Green - Bottom Right -->
            <Image x:Name="BgShape5" Source="shape/circleGreen.png" Width="96" Height="96" 
                   Opacity="0.36" IsHitTestVisible="False"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,40,90"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <RotateTransform Angle="0"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
                <b:Interaction.Triggers>
                    <b:EventTrigger>
                        <b:ControlStoryboardAction Storyboard="{StaticResource BgShape5Anim}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </Image>

            <!-- Shape 6: Square Pink - Right Middle -->
            <Image x:Name="BgShape6" Source="shape/squarePink.png" Width="84" Height="84" 
                   Opacity="0.3" IsHitTestVisible="False"
                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,50"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <RotateTransform Angle="25"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
                <b:Interaction.Triggers>
                    <b:EventTrigger>
                        <b:ControlStoryboardAction Storyboard="{StaticResource BgShape6Anim}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </Image>

            <!-- Shape 7: Pentagon Orange - Top Center -->
            <Image x:Name="BgShape7" Source="shape/pentagonOrange.png" Width="104" Height="104" 
                   Opacity="0.33" IsHitTestVisible="False"
                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="80,45,0,0"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <RotateTransform Angle="-5"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
                <b:Interaction.Triggers>
                    <b:EventTrigger>
                        <b:ControlStoryboardAction Storyboard="{StaticResource BgShape7Anim}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </Image>

            <!-- Shape 8: Star Orange - Bottom Center -->
            <Image x:Name="BgShape8" Source="shape/starfillOrange.png" Width="116" Height="116" 
                   Opacity="0.42" IsHitTestVisible="False"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="-60,0,0,50"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <RotateTransform Angle="10"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
                <b:Interaction.Triggers>
                    <b:EventTrigger>
                        <b:ControlStoryboardAction Storyboard="{StaticResource BgShape8Anim}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </Image>

            <!-- Shape 9: Heart Purple - Mid Left Lower -->
            <Image x:Name="BgShape9" Source="shape/heartPurple.png" Width="88" Height="88" 
                   Opacity="0.28" IsHitTestVisible="False"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,180,0,0"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <RotateTransform Angle="-8"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
                <b:Interaction.Triggers>
                    <b:EventTrigger>
                        <b:ControlStoryboardAction Storyboard="{StaticResource BgShape9Anim}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </Image>

            <!-- Shape 10: Hexagon Purple - Mid Right Upper -->
            <Image x:Name="BgShape10" Source="shape/pentagonPurple.png" Width="92" Height="92" 
                   Opacity="0.34" IsHitTestVisible="False"
                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,200,25,0"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <RotateTransform Angle="12"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
                <b:Interaction.Triggers>
                    <b:EventTrigger>
                        <b:ControlStoryboardAction Storyboard="{StaticResource BgShape10Anim}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </Image>

            <!-- Home screen: tap anywhere to start -->
            <Button Command="{Binding events.onHomeScreenTapToStart}"
                    Visibility="{Binding isHomeVisible, Converter={StaticResource BoolToVis}}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Grid>
                <!-- Centered content -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Title: Shape with layered shadow -->
                    <Grid HorizontalAlignment="Center">
                        <!-- Shadow layer -->
                        <TextBlock FontWeight="Bold"
                                   FontSize="100" FontFamily="Bangers" Foreground="#FF1C1227" Text="SPOT">
                            <TextBlock.RenderTransform>
                                <TranslateTransform X="2" Y="2"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <!-- Main text layer -->
                        <TextBlock FontWeight="Bold"
                                   FontSize="100" Foreground="#FFFFFFFF" FontFamily="Bangers" Text="SPOT"/>
                    </Grid>

                    <!-- Title: Intruder with layered shadow -->
                    <Grid HorizontalAlignment="Center" Margin="0,-10,0,0">
                        <!-- Shadow layer -->
                        <TextBlock FontWeight="Bold"
                                   FontSize="100" FontFamily="Bangers" Foreground="#FF1C1227" Text="CHALLENGE">
                            <TextBlock.RenderTransform>
                                <TranslateTransform X="2" Y="2"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <!-- Main text layer -->
                        <TextBlock FontWeight="Bold"
                                   FontSize="100" Foreground="#FFFFFFFF" FontFamily="Bangers" Text="CHALLENGE"/>
                    </Grid>

                    <!-- Vertical spacing -->
                    <Rectangle Height="40"/>

                    <!-- Subtitle -->
                    <TextBlock Text="Spot the missing shape before time runs out."
                               FontSize="18"
                               Foreground="#FFF0E0"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               MaxWidth="350" CharacterSpacing="120"/>

                    <!-- Vertical spacing -->
                    <Rectangle Height="60"/>

                    <!-- Styled PLAY button with 3D shadow -->
                    <Grid HorizontalAlignment="Center">
                        <!-- Shadow behind -->
                        <Border Background="#55000000" CornerRadius="20" Margin="2,6,-3,-4"/>
                        <!-- The PLAY button -->
                        <Button Command="{Binding events.onHomeScreenTapToStart}"
                                Content="PLAY"
                                FontWeight="Bold"
                                HorizontalAlignment="Center" FontFamily="Bangers" FontSize="50"
                                Style="{StaticResource PlayButtonStyle}">
                            <Button.Foreground>
                                <SolidColorBrush Opacity="0.944" Color="#FF0D0213"/>
                            </Button.Foreground>
                        </Button>
                    </Grid>
                </StackPanel>
                </Grid>
            </Button>
        </Grid>
    </Viewbox>
</Grid>
