<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:noesis="clr-namespace:NoesisGUIExtensions"
      mc:Ignorable="d">

  <!-- REQUIRED: BooleanToVisibilityConverter for visibility bindings -->
  <Grid.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    
    <!-- Shape Item Template - extracted for editor editing -->
    <DataTemplate x:Key="ShapeItemTemplate">
      <Grid RenderTransformOrigin="0.5, 0.5" Opacity="{Binding opacity}">
        <Grid.RenderTransform>
          <TransformGroup>
            <ScaleTransform ScaleX="{Binding scale}" ScaleY="{Binding scale}"/>
            <RotateTransform Angle="{Binding rotation}"/>
            <TranslateTransform X="{Binding x}" Y="{Binding y}"/>
          </TransformGroup>
        </Grid.RenderTransform>
        <!-- Layer 1 (color fill): solid color masked by sprite -->
        <Rectangle Width="2" Height="2" IsHitTestVisible="False" Visibility="Collapsed">
          <Rectangle.OpacityMask>
            <ImageBrush ImageSource="{Binding spriteTexture}" Stretch="Uniform"/>
          </Rectangle.OpacityMask>
          <Rectangle.Fill>
            <SolidColorBrush Color="{Binding fillColor}"/>
          </Rectangle.Fill>
        </Rectangle>
        <!-- Layer 2 (multiply blend): sprite image for texture detail -->
        <Image Width="2" Height="2" Stretch="Uniform" IsHitTestVisible="False">
          <Image.Source>
            <Binding Path="spriteTexture"/>
          </Image.Source>
        </Image>
      </Grid>
    </DataTemplate>
  </Grid.Resources>
  <Grid.Background>
    <RadialGradientBrush>
      <GradientStop Color="#FF2A1A4E" Offset="0"/>
      <GradientStop Color="#FF120A2A" Offset="1"/>
    </RadialGradientBrush>
  </Grid.Background>

  <Viewbox Stretch="Uniform">
    <Grid Width="480" Height="800">
      <!-- Background -->
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border ClipToBounds="True" BorderThickness="10,10,10,10" CornerRadius="20,20,20,20" Grid.RowSpan="3" Margin="0,20,0,6">
          <Border.Background>
            <RadialGradientBrush>
              <GradientStop Color="#FFE738E9" Offset="0"/>
              <GradientStop Color="#FF8139EE" Offset="1"/>
            </RadialGradientBrush>
          </Border.Background>
        </Border>

        <!-- Row 0: HUD Banner — score + timer bar -->
        <Grid Grid.Row="0" Margin="16,12,16,4">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Score card: soft yellow bg, golden border, rounded, with fake shadow -->
          <Grid Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,6">
            <!-- Shadow layer (offset down-right) -->
            <Border Background="#44000000" CornerRadius="22" Margin="2,3,0,0"/>
            <!-- Main score card -->
            <Border Background="#fef9c3" BorderBrush="#fbbf24" BorderThickness="3" CornerRadius="22"
                    Padding="24,6,24,6" Margin="0,0,2,3">
              <TextBlock Text="{Binding scoreText}" FontSize="28" FontWeight="Bold" Foreground="#92400e"
                         HorizontalAlignment="Center"/>
            </Border>

            <!-- Floating score popup "+XXX" — floats upward and fades out -->
            <Grid HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-10"
                  IsHitTestVisible="False"
                  Visibility="{Binding scorePopupVisible, Converter={StaticResource BoolToVis}}"
                  Opacity="{Binding scorePopupOpacity}">
              <Grid.RenderTransform>
                <TranslateTransform Y="{Binding scorePopupOffsetY}"/>
              </Grid.RenderTransform>
              <!-- Shadow text layer -->
              <TextBlock Text="{Binding scorePopupText}" FontSize="26" FontWeight="Bold"
                         Foreground="#44000000" HorizontalAlignment="Center"
                         Margin="2,2,0,0"/>
              <!-- Main golden text -->
              <TextBlock Text="{Binding scorePopupText}" FontSize="26" FontWeight="Bold"
                         Foreground="#fbbf24" HorizontalAlignment="Center"/>
            </Grid>
          </Grid>

          <!-- Timer bar -->
          <Border Grid.Row="1" Background="#2a2a3e" CornerRadius="4" Height="10"
                  HorizontalAlignment="Stretch" ClipToBounds="True">
            <Rectangle RadiusX="4" RadiusY="4"
                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                       RenderTransformOrigin="0,0.5" Fill="#FF61ED3A">
              <Rectangle.RenderTransform>
                <ScaleTransform ScaleX="{Binding timerProgress}" ScaleY="1"/>
              </Rectangle.RenderTransform>
            </Rectangle>
          </Border>
        </Grid>
        <Border Grid.Row="1" ClipToBounds="True" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#FF000000" BorderThickness="10,10,10,10" CornerRadius="20,20,20,20" Opacity="0.237" Margin="0,10,0,0" Width="460" Height="460"/>

        <!-- Row 1: Intruder Zone — shapes + scoped overlay -->
        <Border Grid.Row="1"
                CornerRadius="16"
                ClipToBounds="True" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="6,6,6,6" BorderBrush="#FFFF8800" Width="438" Height="438" Padding="1,1,1,1">
          <Border.Background>
            <RadialGradientBrush>
              <GradientStop Offset="0" Color="#FFFFFFFF"/>
              <GradientStop Offset="1" Color="#FFFFC500"/>
            </RadialGradientBrush>
          </Border.Background>
          <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="426" Height="426">
            <!-- Shapes rendered via ItemsControl with Canvas panel -->
            <ItemsControl ItemsSource="{Binding shapes}"
                          ItemTemplate="{StaticResource ShapeItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <Canvas Width="450" Height="450"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- Overlay scoped to Intruder Zone only -->
            <Rectangle Fill="{Binding overlayColor}"
                       Opacity="{Binding overlayOpacity}"
                       RadiusX="16" RadiusY="16"
                       IsHitTestVisible="False"/>

            <!-- Large centered feedback icon: Valid (correct) -->
            <Image Source="Textures/Valid.png"
                   Width="180" Height="180"
                   Stretch="Uniform"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5"
                   IsHitTestVisible="False"
                   Visibility="{Binding feedbackValidVisible, Converter={StaticResource BoolToVis}}">
              <Image.RenderTransform>
                <ScaleTransform ScaleX="{Binding feedbackIconScale}" ScaleY="{Binding feedbackIconScale}"/>
              </Image.RenderTransform>
            </Image>

            <!-- Large centered feedback icon: Invalid (wrong/timeout) -->
            <Image Source="Textures/Invalid.png"
                   Width="180" Height="180"
                   Stretch="Uniform"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5"
                   IsHitTestVisible="False"
                   Visibility="{Binding feedbackInvalidVisible, Converter={StaticResource BoolToVis}}">
              <Image.RenderTransform>
                <ScaleTransform ScaleX="{Binding feedbackIconScale}" ScaleY="{Binding feedbackIconScale}"/>
              </Image.RenderTransform>
            </Image>
          </Grid>
        </Border>

        <!-- Row 2: 2×2 answer button grid -->
        <Grid Grid.Row="2" Height="200" Margin="14,8,14,20">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <!-- Option 0 (top-left) — 3-layer: shadow + color fill + multiply blend -->
          <Grid Grid.Row="0" Grid.Column="0" Margin="6,6,6,6">
            <!-- Shadow behind (stays in place) -->
            <Border Background="#55000000" CornerRadius="12" Margin="2,6,-3,-4"/>
            <!-- Pressable container with Y offset for post-answer state -->
            <Grid>
              <Grid.RenderTransform>
                <TranslateTransform Y="{Binding option0OffsetY}"/>
              </Grid.RenderTransform>
              <Button Command="{Binding events.onAnswerOptionPressed}"
                      CommandParameter="0"
                      BorderBrush="{Binding option0BorderColor}" BorderThickness="5,5,5,5"
                      Background="{Binding Path=option0BgColor}">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <Grid x:Name="Opt0PressGrid">
                      <Border x:Name="Opt0Border" CornerRadius="12"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              Background="{TemplateBinding Background}"/>
                      <Grid Width="90" Height="90" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Stretch="Uniform" IsHitTestVisible="False" Panel.ZIndex="2">
                          <Image.Source>
                            <Binding Path="option0SpriteTexture"/>
                          </Image.Source>
                        </Image>
                      </Grid>
                      <Image Source="Textures/Valid.png" Visibility="{Binding option0CheckVisible, Converter={StaticResource BoolToVis}}" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="50"/>
                      <Image Source="Textures/Invalid.png" Visibility="{Binding option0CrossVisible, Converter={StaticResource BoolToVis}}" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="50"/>
                      <Rectangle x:Name="Opt0Darken" RadiusX="12" RadiusY="12" Fill="#FFFFFF" Opacity="0" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Opt0PressGrid" Property="Margin" Value="0,3,0,-3"/>
                        <Setter TargetName="Opt0Darken" Property="Opacity" Value="0.1"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Button.Template>
              </Button>
            </Grid>
          </Grid>

          <!-- Option 1 (top-right) — 3-layer: shadow + color fill + multiply blend -->
          <Grid Grid.Row="0" Grid.Column="1" Margin="6,6,6,6">
            <!-- Shadow behind (stays in place) -->
            <Border Background="#55000000" CornerRadius="12" Margin="2,6,-3,-4"/>
            <!-- Pressable container with Y offset for post-answer state -->
            <Grid>
              <Grid.RenderTransform>
                <TranslateTransform Y="{Binding option1OffsetY}"/>
              </Grid.RenderTransform>
              <Button Command="{Binding events.onAnswerOptionPressed}"
                      CommandParameter="1"
                      BorderBrush="{Binding option1BorderColor}" BorderThickness="5,5,5,5"
                      Background="{Binding Path=option1BgColor}">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <Grid x:Name="Opt1PressGrid">
                      <Border x:Name="Opt1Border" CornerRadius="12"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              Background="{TemplateBinding Background}"/>
                      <Grid Width="90" Height="90" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Stretch="Uniform" IsHitTestVisible="False" Panel.ZIndex="2">
                          <Image.Source>
                            <Binding Path="option1SpriteTexture"/>
                          </Image.Source>
                        </Image>
                      </Grid>
                      <Image Source="Textures/Valid.png" Visibility="{Binding option1CheckVisible, Converter={StaticResource BoolToVis}}" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="50"/>
                      <Image Source="Textures/Invalid.png" Visibility="{Binding option1CrossVisible, Converter={StaticResource BoolToVis}}" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="50"/>
                      <Rectangle x:Name="Opt1Darken" RadiusX="12" RadiusY="12" Fill="#FFFFFF" Opacity="0" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Opt1PressGrid" Property="Margin" Value="0,3,0,-3"/>
                        <Setter TargetName="Opt1Darken" Property="Opacity" Value="0.1"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Button.Template>
              </Button>
            </Grid>
          </Grid>

          <!-- Option 2 (bottom-left) — 3-layer: shadow + color fill + multiply blend -->
          <Grid Grid.Row="1" Grid.Column="0" Margin="6,6,6,6">
            <!-- Shadow behind (stays in place) -->
            <Border Background="#55000000" CornerRadius="12" Margin="2,6,-3,-4"/>
            <!-- Pressable container with Y offset for post-answer state -->
            <Grid>
              <Grid.RenderTransform>
                <TranslateTransform Y="{Binding option2OffsetY}"/>
              </Grid.RenderTransform>
              <Button Command="{Binding events.onAnswerOptionPressed}"
                      CommandParameter="2"
                      BorderBrush="{Binding option2BorderColor}" BorderThickness="5,5,5,5"
                      Background="{Binding Path=option2BgColor}">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <Grid x:Name="Opt2PressGrid">
                      <Border x:Name="Opt2Border" CornerRadius="12"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              Background="{TemplateBinding Background}"/>
                      <Grid Width="90" Height="90" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Stretch="Uniform" IsHitTestVisible="False" Panel.ZIndex="2">
                          <Image.Source>
                            <Binding Path="option2SpriteTexture"/>
                          </Image.Source>
                        </Image>
                      </Grid>
                      <Image Source="Textures/Valid.png" Visibility="{Binding option2CheckVisible, Converter={StaticResource BoolToVis}}" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="50"/>
                      <Image Source="Textures/Invalid.png" Visibility="{Binding option2CrossVisible, Converter={StaticResource BoolToVis}}" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="50"/>
                      <Rectangle x:Name="Opt2Darken" RadiusX="12" RadiusY="12" Fill="#FFFFFF" Opacity="0" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Opt2PressGrid" Property="Margin" Value="0,3,0,-3"/>
                        <Setter TargetName="Opt2Darken" Property="Opacity" Value="0.1"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Button.Template>
              </Button>
            </Grid>
          </Grid>

          <!-- Option 3 (bottom-right) — 3-layer: shadow + color fill + multiply blend -->
          <Grid Grid.Row="1" Grid.Column="1" Margin="6,6,6,6">
            <!-- Shadow behind (stays in place) -->
            <Border Background="#55000000" CornerRadius="12" Margin="2,6,-3,-4"/>
            <!-- Pressable container with Y offset for post-answer state -->
            <Grid>
              <Grid.RenderTransform>
                <TranslateTransform Y="{Binding option3OffsetY}"/>
              </Grid.RenderTransform>
              <Button Command="{Binding events.onAnswerOptionPressed}"
                      CommandParameter="3"
                      BorderBrush="{Binding option3BorderColor}" BorderThickness="5,5,5,5"
                      Background="{Binding Path=option3BgColor}">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <Grid x:Name="Opt3PressGrid">
                      <Border x:Name="Opt3Border" CornerRadius="12"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              Background="{TemplateBinding Background}"/>
                      <Grid Width="90" Height="90" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Stretch="Uniform" IsHitTestVisible="False" Panel.ZIndex="2">
                          <Image.Source>
                            <Binding Path="option3SpriteTexture"/>
                          </Image.Source>
                        </Image>
                      </Grid>
                      <Image Source="Textures/Valid.png" Visibility="{Binding option3CheckVisible, Converter={StaticResource BoolToVis}}" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="50"/>
                      <Image Source="Textures/Invalid.png" Visibility="{Binding option3CrossVisible, Converter={StaticResource BoolToVis}}" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="50"/>
                      <Rectangle x:Name="Opt3Darken" RadiusX="12" RadiusY="12" Fill="#FFFFFF" Opacity="0" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Opt3PressGrid" Property="Margin" Value="0,3,0,-3"/>
                        <Setter TargetName="Opt3Darken" Property="Opacity" Value="0.1"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Button.Template>
              </Button>
            </Grid>
          </Grid>
        </Grid>
      </Grid>
    </Grid>
  </Viewbox>
</Grid>
