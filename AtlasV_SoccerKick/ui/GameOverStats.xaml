<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      Background="Transparent">

    <!-- Full-screen overlay container with visibility binding -->
    <Grid x:Name="OverlayContainer">
        <Grid.Visibility>
            <Binding Path="OverlayVisible">
                <Binding.Converter>
                    <BooleanToVisibilityConverter/>
                </Binding.Converter>
            </Binding>
        </Grid.Visibility>

        <!-- Semi-transparent dark background filling the whole screen -->
        <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Fill="#CC203822"/>

        <!-- Content container with scale and opacity for entrance animation -->
        <Grid x:Name="CardContainer"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Opacity="{Binding Path=CardOpacity}"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="{Binding Path=CardScaleX}" ScaleY="{Binding Path=CardScaleY}"/>
                </TransformGroup>
            </Grid.RenderTransform>

            <!-- Rounded frame container wrapping the main content -->
            <Border CornerRadius="40" Padding="80,60" BorderBrush="#FFFFC500" BorderThickness="10,10,10,10" Background="#DC093F10">

                <!-- Main content vertical StackPanel -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- END OF MATCH Title - smaller font -->
                    <TextBlock x:Name="TitleText"
                               Text="END OF MATCH"
                               FontFamily="Roboto"
                               FontSize="64"
                               FontWeight="Bold"
                               Foreground="#FFFFFFFF"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,40"/>

                    <!-- Score - golden with black outline using layered TextBlocks -->
                    <Grid x:Name="ScoreDisplay" HorizontalAlignment="Center" Margin="0,0,0,100">
                        <!-- Black outline TextBlocks (8 directions) -->
                        <TextBlock Text="{Binding Path=ScoreText}"
                                   FontFamily="Roboto"
                                   FontSize="260"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   HorizontalAlignment="Center"
                                   Margin="-4,-4,0,0"/>
                        <TextBlock Text="{Binding Path=ScoreText}"
                                   FontFamily="Roboto"
                                   FontSize="260"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   HorizontalAlignment="Center"
                                   Margin="4,-4,0,0"/>
                        <TextBlock Text="{Binding Path=ScoreText}"
                                   FontFamily="Roboto"
                                   FontSize="260"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   HorizontalAlignment="Center"
                                   Margin="-4,4,0,0"/>
                        <TextBlock Text="{Binding Path=ScoreText}"
                                   FontFamily="Roboto"
                                   FontSize="260"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   HorizontalAlignment="Center"
                                   Margin="4,4,0,0"/>
                        <TextBlock Text="{Binding Path=ScoreText}"
                                   FontFamily="Roboto"
                                   FontSize="260"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   HorizontalAlignment="Center"
                                   Margin="0,-4,0,0"/>
                        <TextBlock Text="{Binding Path=ScoreText}"
                                   FontFamily="Roboto"
                                   FontSize="260"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding Path=ScoreText}"
                                   FontFamily="Roboto"
                                   FontSize="260"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   HorizontalAlignment="Center"
                                   Margin="-4,0,0,0"/>
                        <TextBlock Text="{Binding Path=ScoreText}"
                                   FontFamily="Roboto"
                                   FontSize="260"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   HorizontalAlignment="Center"
                                   Margin="4,0,0,0"/>
                        <!-- Golden foreground TextBlock on top -->
                        <TextBlock Text="{Binding Path=ScoreText}"
                                   FontFamily="Roboto"
                                   FontSize="260"
                                   FontWeight="Bold"
                                   Foreground="#FFD700"
                                   HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Star Rating Row -->
                    <StackPanel x:Name="StarRatingRow"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,120">
                        <!-- Star 1 -->
                        <Grid x:Name="Star1Container" Margin="40,0,40,0" RenderTransformOrigin="0.5,0.5">
                            <Grid.Visibility>
                                <Binding Path="Star1Visible">
                                    <Binding.Converter>
                                        <BooleanToVisibilityConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Grid.Visibility>
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="{Binding Path=Star1Scale}" ScaleY="{Binding Path=Star1Scale}"/>
                                </TransformGroup>
                            </Grid.RenderTransform>
                            <Path Data="M 80,0 L 98,58 160,58 110,94 128,152 80,118 32,152 50,94 0,58 62,58 Z"
                                  Fill="{Binding Path=Star1Color}"
                                  Stretch="Uniform"
                                  Width="160"
                                  Height="160"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Star 2 -->
                        <Grid x:Name="Star2Container" Margin="40,0,40,0" RenderTransformOrigin="0.5,0.5">
                            <Grid.Visibility>
                                <Binding Path="Star2Visible">
                                    <Binding.Converter>
                                        <BooleanToVisibilityConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Grid.Visibility>
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="{Binding Path=Star2Scale}" ScaleY="{Binding Path=Star2Scale}"/>
                                </TransformGroup>
                            </Grid.RenderTransform>
                            <Path Data="M 80,0 L 98,58 160,58 110,94 128,152 80,118 32,152 50,94 0,58 62,58 Z"
                                  Fill="{Binding Path=Star2Color}"
                                  Stretch="Uniform"
                                  Width="160"
                                  Height="160"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Star 3 -->
                        <Grid x:Name="Star3Container" Margin="40,0,40,0" RenderTransformOrigin="0.5,0.5">
                            <Grid.Visibility>
                                <Binding Path="Star3Visible">
                                    <Binding.Converter>
                                        <BooleanToVisibilityConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Grid.Visibility>
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="{Binding Path=Star3Scale}" ScaleY="{Binding Path=Star3Scale}"/>
                                </TransformGroup>
                            </Grid.RenderTransform>
                            <Path Data="M 80,0 L 98,58 160,58 110,94 128,152 80,118 32,152 50,94 0,58 62,58 Z"
                                  Fill="{Binding Path=Star3Color}"
                                  Stretch="Uniform"
                                  Width="160"
                                  Height="160"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- 3 Stat Cartouches in a Grid with equal columns -->
                    <Grid x:Name="StatsCartouches" HorizontalAlignment="Center" Margin="0,0,0,120">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Goals Cartouche -->
                        <Border Grid.Column="0"
                                CornerRadius="30"
                                Background="#66000000"
                                Padding="40,30"
                                MinWidth="320">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="GOALS"
                                           FontFamily="Roboto"
                                           FontSize="40"
                                           Foreground="#FFAAAAAA"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16"/>
                                <TextBlock Text="{Binding Path=GoalsText}"
                                           FontFamily="Roboto"
                                           FontSize="72"
                                           FontWeight="Bold"
                                           Foreground="#FFFFFFFF"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Precision Cartouche -->
                        <Border Grid.Column="2"
                                CornerRadius="30"
                                Background="#66000000"
                                Padding="40,30"
                                MinWidth="320">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="PRECISION"
                                           FontFamily="Roboto"
                                           FontSize="40"
                                           Foreground="#FFAAAAAA"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16"/>
                                <TextBlock Text="{Binding Path=PrecisionText}"
                                           FontFamily="Roboto"
                                           FontSize="72"
                                           FontWeight="Bold"
                                           Foreground="#FFFFFFFF"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Best Combo Cartouche -->
                        <Border Grid.Column="4"
                                CornerRadius="30"
                                Background="#66000000"
                                Padding="40,30"
                                MinWidth="320">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="BEST COMBO"
                                           FontFamily="Roboto"
                                           FontSize="40"
                                           Foreground="#FFAAAAAA"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16"/>
                                <TextBlock Text="{Binding Path=BestComboText}"
                                           FontFamily="Roboto"
                                           FontSize="72"
                                           FontWeight="Bold"
                                           Foreground="#FFFFFFFF"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- PLAY AGAIN Button with scale and opacity animations - lower position -->
                    <Grid x:Name="ReplayButtonContainer"
                          HorizontalAlignment="Center"
                          Opacity="{Binding Path=ReplayButtonOpacity}"
                          RenderTransformOrigin="0.5,0.5"
                          Margin="0,120,0,0">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Path=ReplayButtonScale}" ScaleY="{Binding Path=ReplayButtonScale}"/>
                            </TransformGroup>
                        </Grid.RenderTransform>

                        <Button x:Name="ReplayButton"
                                Command="{Binding Path=events.onReplayClickEvent}"
                                Width="800"
                                Height="160"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="ButtonBorder"
                                            Background="#FFFFD700"
                                            BorderBrush="#FFFFFFFF"
                                            BorderThickness="4"
                                            CornerRadius="60"
                                            Width="800"
                                            Height="160">
                                        <TextBlock Text="PLAY AGAIN"
                                                   FontFamily="Roboto"
                                                   FontSize="72"
                                                   FontWeight="Bold"
                                                   Foreground="#FF1A1A1A"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
