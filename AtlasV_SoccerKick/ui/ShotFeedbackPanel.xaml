<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      Background="Transparent">

    <!-- Main container with visibility binding -->
    <Grid x:Name="MainContainer" Margin="1,0,-1,0">
        <Grid.Visibility>
            <Binding Path="IsVisible">
                <Binding.Converter>
                    <BooleanToVisibilityConverter/>
                </Binding.Converter>
            </Binding>
        </Grid.Visibility>

        <!-- Animated content container with transforms and opacity -->
        <Grid x:Name="AnimatedContainer"
              Opacity="{Binding Path=Opacity}"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TransformGroup>
                    <SkewTransform AngleX="{Binding Path=SkewX}"/>
                    <ScaleTransform ScaleX="{Binding Path=ScaleX}" ScaleY="{Binding Path=ScaleY}"/>
                    <RotateTransform Angle="{Binding Path=RotationZ}"/>
                    <TranslateTransform X="{Binding Path=TranslateX}" Y="{Binding Path=TranslateY}"/>
                </TransformGroup>
            </Grid.RenderTransform>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Main feedback text with outline effect -->
                <Grid x:Name="FeedbackTextContainer" HorizontalAlignment="Center">
                    <!-- Text outline/stroke layer (rendered behind) -->
                    <TextBlock x:Name="FeedbackTextOutline"
                               Text="{Binding Path=FeedbackText}"
                               FontFamily="Roboto"
                               FontSize="{Binding Path=FontSize}"
                               FontWeight="Black"
                               Stroke="#FF1A1A1A"
                               StrokeThickness="{Binding Path=StrokeThickness}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- Main text layer with dynamic color -->
                    <TextBlock x:Name="FeedbackTextMain"
                               Text="{Binding Path=FeedbackText}"
                               FontFamily="Roboto"
                               FontSize="{Binding Path=FontSize}"
                               FontWeight="Black"
                               Foreground="{Binding Path=TextColor}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Points text (shown below main text for goals) -->
            </StackPanel>
        </Grid>
        <!-- Points counter — slot-machine roll-up, independent from main sweep transform -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,620,0,0"
              Opacity="{Binding Path=PointsOpacity}"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform ScaleY="{Binding Path=PointsScaleY}"/>
            </Grid.RenderTransform>
            <TextBlock x:Name="PointsTextOutline"
                       Text="{Binding Path=PointsText}"
                       FontFamily="Roboto" FontSize="148" FontWeight="Bold"
                       Stroke="#FF1A1A1A" StrokeThickness="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="PointsText"
                       Text="{Binding Path=PointsText}"
                       FontFamily="Roboto" FontSize="148" FontWeight="Bold"
                       Foreground="#FFFFD508"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Combo text display -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,780,0,0"
              Opacity="{Binding Path=ComboOpacity}">
            <Grid.Visibility>
                <Binding Path="ComboVisible">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter/>
                    </Binding.Converter>
                </Binding>
            </Grid.Visibility>
            <TextBlock Text="{Binding Path=ComboText}"
                       FontWeight="Black"
                       Stroke="#FF1A1A1A" StrokeThickness="8"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="80" CharacterSpacing="-1" FontFamily="Anton" Visibility="Collapsed"/>
            <TextBlock Text="{Binding Path=ComboText}"
                       FontWeight="Black"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="80" CharacterSpacing="-1" FontFamily="Anton" Foreground="#FFB91B1B"/>
        </Grid>
    </Grid>
</Page>
