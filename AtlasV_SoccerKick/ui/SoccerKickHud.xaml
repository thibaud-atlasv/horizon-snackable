<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      Background="Transparent">

    <Page.Resources>
        <!-- Color Resources for sporty theme -->
        <SolidColorBrush x:Key="ScoreTextColor" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ScoreOutlineColor" Color="#FF1A1A1A"/>
        <SolidColorBrush x:Key="ShotActiveColor" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="ShotActiveBorderColor" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ShotInactiveColor" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="ShotInactiveBorderColor" Color="#66FFFFFF"/>
        
        <!-- BooleanToVisibilityConverter for visibility bindings -->
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Page.Resources>

    <!-- Main Full-Width Grid Layout -->
    <Grid>
        <!-- Top Section Container -->
        <Grid VerticalAlignment="Top" Margin="0,140,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Row 0: Shot Indicators (center) and Combo (right) -->
            <Grid Grid.Row="0" Height="173" RenderTransformOrigin="0.5,0.5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="2" ScaleY="2"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Grid.RenderTransform>

                <!-- TOP-CENTER: Shot Indicator Dots (scaled x3) - shifted down 50px -->
                <StackPanel x:Name="ShotIndicators" 
                            Grid.Column="1"
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,50,0,0">
                
                <!-- Shot 1 -->
                <Grid x:Name="Shot1Container" Margin="12,0" RenderTransformOrigin="0.5,0.5" Opacity="{Binding Path=Shot1Opacity}">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="{Binding Path=Shot1Scale}" ScaleY="{Binding Path=Shot1Scale}"/>
                    </Grid.RenderTransform>
                    <Ellipse x:Name="Shot1Dot"
                             Width="60" Height="60"
                             Fill="#FF4CAF50"
                             StrokeThickness="6" Stroke="#FFFFFFFF"/>
                    <b:Interaction.Triggers>
                        <b:DataTrigger Binding="{Binding Path=Shot1Active}" Value="False">
                            <b:ChangePropertyAction TargetName="Shot1Dot" PropertyName="Fill" Value="#33FFFFFF"/>
                            <b:ChangePropertyAction TargetName="Shot1Dot" PropertyName="Stroke" Value="#66FFFFFF"/>
                        </b:DataTrigger>
                        <b:DataTrigger Binding="{Binding Path=Shot1Active}" Value="True">
                            <b:ChangePropertyAction TargetName="Shot1Dot" PropertyName="Fill" Value="#FF4CAF50"/>
                            <b:ChangePropertyAction TargetName="Shot1Dot" PropertyName="Stroke" Value="#FFFFFFFF"/>
                        </b:DataTrigger>
                    </b:Interaction.Triggers>
                </Grid>

                <!-- Shot 2 -->
                <Grid x:Name="Shot2Container" Margin="12,0" RenderTransformOrigin="0.5,0.5" Opacity="{Binding Path=Shot2Opacity}">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="{Binding Path=Shot2Scale}" ScaleY="{Binding Path=Shot2Scale}"/>
                    </Grid.RenderTransform>
                    <Ellipse x:Name="Shot2Dot"
                             Width="60" Height="60"
                             Fill="#FF4CAF50"
                             StrokeThickness="6" Stroke="#FFFFFFFF"/>
                    <b:Interaction.Triggers>
                        <b:DataTrigger Binding="{Binding Path=Shot2Active}" Value="False">
                            <b:ChangePropertyAction TargetName="Shot2Dot" PropertyName="Fill" Value="#33FFFFFF"/>
                            <b:ChangePropertyAction TargetName="Shot2Dot" PropertyName="Stroke" Value="#66FFFFFF"/>
                        </b:DataTrigger>
                        <b:DataTrigger Binding="{Binding Path=Shot2Active}" Value="True">
                            <b:ChangePropertyAction TargetName="Shot2Dot" PropertyName="Fill" Value="#FF4CAF50"/>
                            <b:ChangePropertyAction TargetName="Shot2Dot" PropertyName="Stroke" Value="#FFFFFFFF"/>
                        </b:DataTrigger>
                    </b:Interaction.Triggers>
                </Grid>

                <!-- Shot 3 -->
                <Grid x:Name="Shot3Container" Margin="12,0" RenderTransformOrigin="0.5,0.5" Opacity="{Binding Path=Shot3Opacity}">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="{Binding Path=Shot3Scale}" ScaleY="{Binding Path=Shot3Scale}"/>
                    </Grid.RenderTransform>
                    <Ellipse x:Name="Shot3Dot"
                             Width="60" Height="60"
                             Fill="#FF4CAF50"
                             StrokeThickness="6" Stroke="#FFFFFFFF"/>
                    <b:Interaction.Triggers>
                        <b:DataTrigger Binding="{Binding Path=Shot3Active}" Value="False">
                            <b:ChangePropertyAction TargetName="Shot3Dot" PropertyName="Fill" Value="#33FFFFFF"/>
                            <b:ChangePropertyAction TargetName="Shot3Dot" PropertyName="Stroke" Value="#66FFFFFF"/>
                        </b:DataTrigger>
                        <b:DataTrigger Binding="{Binding Path=Shot3Active}" Value="True">
                            <b:ChangePropertyAction TargetName="Shot3Dot" PropertyName="Fill" Value="#FF4CAF50"/>
                            <b:ChangePropertyAction TargetName="Shot3Dot" PropertyName="Stroke" Value="#FFFFFFFF"/>
                        </b:DataTrigger>
                    </b:Interaction.Triggers>
                </Grid>

                <!-- Shot 4 -->
                <Grid x:Name="Shot4Container" Margin="12,0" RenderTransformOrigin="0.5,0.5" Opacity="{Binding Path=Shot4Opacity}">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="{Binding Path=Shot4Scale}" ScaleY="{Binding Path=Shot4Scale}"/>
                    </Grid.RenderTransform>
                    <Ellipse x:Name="Shot4Dot"
                             Width="60" Height="60"
                             Fill="#FF4CAF50"
                             StrokeThickness="6" Stroke="#FFFFFFFF"/>
                    <b:Interaction.Triggers>
                        <b:DataTrigger Binding="{Binding Path=Shot4Active}" Value="False">
                            <b:ChangePropertyAction TargetName="Shot4Dot" PropertyName="Fill" Value="#33FFFFFF"/>
                            <b:ChangePropertyAction TargetName="Shot4Dot" PropertyName="Stroke" Value="#66FFFFFF"/>
                        </b:DataTrigger>
                        <b:DataTrigger Binding="{Binding Path=Shot4Active}" Value="True">
                            <b:ChangePropertyAction TargetName="Shot4Dot" PropertyName="Fill" Value="#FF4CAF50"/>
                            <b:ChangePropertyAction TargetName="Shot4Dot" PropertyName="Stroke" Value="#FFFFFFFF"/>
                        </b:DataTrigger>
                    </b:Interaction.Triggers>
                </Grid>

                <!-- Shot 5 -->
                <Grid x:Name="Shot5Container" Margin="12,0" RenderTransformOrigin="0.5,0.5" Opacity="{Binding Path=Shot5Opacity}">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="{Binding Path=Shot5Scale}" ScaleY="{Binding Path=Shot5Scale}"/>
                    </Grid.RenderTransform>
                    <Ellipse x:Name="Shot5Dot"
                             Width="60" Height="60"
                             Fill="#FF4CAF50"
                             StrokeThickness="6" Stroke="#FFFFFFFF"/>
                    <b:Interaction.Triggers>
                        <b:DataTrigger Binding="{Binding Path=Shot5Active}" Value="False">
                            <b:ChangePropertyAction TargetName="Shot5Dot" PropertyName="Fill" Value="#33FFFFFF"/>
                            <b:ChangePropertyAction TargetName="Shot5Dot" PropertyName="Stroke" Value="#66FFFFFF"/>
                        </b:DataTrigger>
                        <b:DataTrigger Binding="{Binding Path=Shot5Active}" Value="True">
                            <b:ChangePropertyAction TargetName="Shot5Dot" PropertyName="Fill" Value="#FF4CAF50"/>
                            <b:ChangePropertyAction TargetName="Shot5Dot" PropertyName="Stroke" Value="#FFFFFFFF"/>
                        </b:DataTrigger>
                    </b:Interaction.Triggers>
                </Grid>

                <!-- Shot 6 -->
                <Grid x:Name="Shot6Container" Margin="12,0" RenderTransformOrigin="0.5,0.5" Opacity="{Binding Path=Shot6Opacity}">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="{Binding Path=Shot6Scale}" ScaleY="{Binding Path=Shot6Scale}"/>
                    </Grid.RenderTransform>
                    <Ellipse x:Name="Shot6Dot"
                             Width="60" Height="60"
                             Fill="#FF4CAF50"
                             StrokeThickness="6" Stroke="#FFFFFFFF"/>
                    <b:Interaction.Triggers>
                        <b:DataTrigger Binding="{Binding Path=Shot6Active}" Value="False">
                            <b:ChangePropertyAction TargetName="Shot6Dot" PropertyName="Fill" Value="#33FFFFFF"/>
                            <b:ChangePropertyAction TargetName="Shot6Dot" PropertyName="Stroke" Value="#66FFFFFF"/>
                        </b:DataTrigger>
                        <b:DataTrigger Binding="{Binding Path=Shot6Active}" Value="True">
                            <b:ChangePropertyAction TargetName="Shot6Dot" PropertyName="Fill" Value="#FF4CAF50"/>
                            <b:ChangePropertyAction TargetName="Shot6Dot" PropertyName="Stroke" Value="#FFFFFFFF"/>
                        </b:DataTrigger>
                    </b:Interaction.Triggers>
                </Grid>
            </StackPanel>


            </Grid>

            <!-- Row 1: Score Cartouche Badge - Centered below shot indicators -->
            <Grid x:Name="ScoreCartouche"
                  Grid.Row="1"
                  VerticalAlignment="Top"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="{Binding Path=ScoreScale}" ScaleY="{Binding Path=ScoreScale}"/>
                </Grid.RenderTransform>
                
                <!-- Semi-transparent dark badge background with fixed width and more rounded corners -->
                <Border CornerRadius="40" 
                        Padding="36,24" Width="500" Background="#00000000"/>
                <Grid Margin="0,8,0,0" HorizontalAlignment="Center">
                    <TextBlock x:Name="ScoreTextOutline" Text="{Binding Path=ScoreText}" FontFamily="Roboto" FontWeight="Black" Stroke="#FF1A1A1A" StrokeThickness="12" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="250"/>
                    <TextBlock x:Name="ScoreTextMain" Text="{Binding Path=ScoreText}" FontFamily="Roboto" FontWeight="Black" Foreground="{Binding Path=ScoreColor}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="250"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- CENTER: Instruction Text -->
        <Grid x:Name="InstructionContainer"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="0,200,0,0"
              Opacity="{Binding Path=InstructionOpacity}"
              Visibility="{Binding Path=InstructionVisible, Converter={StaticResource BoolToVisConverter}}">
            
            <!-- RenderTransform for vertical bobbing animation -->
            <Grid.RenderTransform>
                <TranslateTransform Y="{Binding Path=InstructionTranslateY}"/>
            </Grid.RenderTransform>
            
            <!-- Instruction text shadow layer (offset for drop shadow effect) -->
            
            <!-- Instruction text outline layer -->
            <TextBlock x:Name="InstructionTextOutline"
                       Text="{Binding Path=InstructionText}"
                       FontFamily="Roboto"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       Stroke="#FF1A1A1A"
                       StrokeThickness="6"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" FontSize="170"/>
            
            <!-- Instruction main text layer -->
            <TextBlock x:Name="InstructionTextMain"
                       Text="{Binding Path=InstructionText}"
                       FontFamily="Roboto"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" FontSize="170" Foreground="#C8FFFFFF"/>
        </Grid>
    </Grid>
</Page>
