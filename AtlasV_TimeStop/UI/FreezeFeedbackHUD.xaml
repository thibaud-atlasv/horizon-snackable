<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      Background="Transparent">

    <Page.Resources>
        <Storyboard x:Key="FeedbackAnim">
            <!-- Line: Opacity 0->1 over 80ms, hold at 800ms, fade out by 1150ms -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FreezeLine"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0"     Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.08"  Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8"   Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.15"  Value="0">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <!-- GradeText: reset Y=0, pop to -158px, settle at -105px, hold at 800ms, float up to -385px by 1250ms -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GradeGroup"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.12" Value="-158">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="-105">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="-105"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.25" Value="-385">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <!-- ScoreText: reset Y=0, pop to -158px, settle at -105px (slightly delayed), hold at 800ms, float up to -385px by 1250ms -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreGroup"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.04" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.16" Value="-158">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.26" Value="-105">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="-105"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.25" Value="-385">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <!-- GradeText: Scale pop 0.6->1.1->1.0, hold at 800ms, shrink to 0.8 by 1250ms -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GradeGroup"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="1.0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.250" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GradeGroup"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="1.0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.250" Value="1"/>
            </DoubleAnimationUsingKeyFrames>

            <!-- GradeText: Opacity 0->1, hold at 800ms, fade out by 1250ms -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GradeGroup"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.08" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.25" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <!-- ScoreText: Opacity 0->1, delayed 40ms, hold at 800ms, fade out by 1250ms -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreGroup"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.04" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.12" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.25" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreGroup" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame Value="0.6" KeyTime="0:0:0"/>
                <EasingDoubleKeyFrame Value="1.1" KeyTime="0:0:0.180">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.250"/>
                <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.800"/>
                <LinearDoubleKeyFrame Value="1" KeyTime="0:0:1.250"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreGroup" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame Value="0.6" KeyTime="0:0:0"/>
                <EasingDoubleKeyFrame Value="1.1" KeyTime="0:0:0.180">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.250"/>
                <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.800"/>
                <LinearDoubleKeyFrame Value="1" KeyTime="0:0:1.250"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <!-- Gameplay coordinate space: 1920×3640, matches FallingObjCanvas -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="1920" Height="3640">

        <Grid x:Name="FeedbackContainer">
            <b:Interaction.Triggers>
                <b:PropertyChangedTrigger Binding="{Binding Path=animTrigger}">
                    <b:ControlStoryboardAction Storyboard="{StaticResource FeedbackAnim}"/>
                </b:PropertyChangedTrigger>
            </b:Interaction.Triggers>

            <Grid x:Name="FeedbackGroup" VerticalAlignment="Top" HorizontalAlignment="Center">
                <Grid.RenderTransform>
                    <TranslateTransform Y="{Binding Path=lineY}"/>
                </Grid.RenderTransform>

                <!-- Grade Text group: outline copies + colored text share the same animated transform -->
                <Grid x:Name="GradeGroup"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="80,-70,0,0"
                      RenderTransformOrigin="0.5,1"
                      Opacity="0">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform Y="0"/>
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <!-- Outline: top -->
                    <TextBlock Text="{Binding Path=gradeText}" FontFamily="Bangers" FontSize="118" FontWeight="Bold" CharacterSpacing="50" Foreground="#CC000000" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform Y="-3"/></TextBlock.RenderTransform></TextBlock>
                    <!-- Outline: bottom -->
                    <TextBlock Text="{Binding Path=gradeText}" FontFamily="Bangers" FontSize="118" FontWeight="Bold" CharacterSpacing="50" Foreground="#CC000000" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform Y="3"/></TextBlock.RenderTransform></TextBlock>
                    <!-- Outline: left -->
                    <TextBlock Text="{Binding Path=gradeText}" FontFamily="Bangers" FontSize="118" FontWeight="Bold" CharacterSpacing="50" Foreground="#CC000000" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="-3"/></TextBlock.RenderTransform></TextBlock>
                    <!-- Outline: right -->
                    <TextBlock Text="{Binding Path=gradeText}" FontFamily="Bangers" FontSize="118" FontWeight="Bold" CharacterSpacing="50" Foreground="#CC000000" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="3"/></TextBlock.RenderTransform></TextBlock>
                    <!-- Colored text on top -->
                    <TextBlock x:Name="GradeText"
                               Text="{Binding Path=gradeText, FallbackValue=PERFECT}"
                               FontFamily="Bangers"
                               FontSize="118"
                               FontWeight="Bold"
                               CharacterSpacing="50">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{Binding Path=lineColor}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Grid>

                <!-- Horizontal Line -->
                <Rectangle x:Name="FreezeLine"
                           Width="1920"
                           Height="10"
                           Fill="{Binding Path=lineColor}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Opacity="0"/>

                <!-- Score Text group: outline copies + colored text share the same animated transform -->
                <Grid x:Name="ScoreGroup"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,-50,72,0"
                      RenderTransformOrigin="0.5,1"
                      Opacity="0">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform Y="0"/>
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <!-- Outline: top -->
                    <TextBlock Text="{Binding Path=scoreText}" FontFamily="Bangers" FontSize="83" FontWeight="Bold" Foreground="#CC000000" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform Y="-3"/></TextBlock.RenderTransform></TextBlock>
                    <!-- Outline: bottom -->
                    <TextBlock Text="{Binding Path=scoreText}" FontFamily="Bangers" FontSize="83" FontWeight="Bold" Foreground="#CC000000" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform Y="3"/></TextBlock.RenderTransform></TextBlock>
                    <!-- Outline: left -->
                    <TextBlock Text="{Binding Path=scoreText}" FontFamily="Bangers" FontSize="83" FontWeight="Bold" Foreground="#CC000000" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="-3"/></TextBlock.RenderTransform></TextBlock>
                    <!-- Outline: right -->
                    <TextBlock FontFamily="Bangers" FontSize="83" FontWeight="Bold" Foreground="#CC000000" IsHitTestVisible="False" Text="{Binding Path=scoreText, FallbackValue=TEST}"><TextBlock.RenderTransform><TranslateTransform X="3"/></TextBlock.RenderTransform></TextBlock>
                    <!-- Colored text on top -->
                    <TextBlock x:Name="ScoreText"
                               Text="{Binding Path=scoreText, FallbackValue=+1250}"
                               FontFamily="Bangers"
                               FontSize="83"
                               FontWeight="Bold">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{Binding Path=lineColor}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Grid>
            </Grid>
        </Grid>
        </Grid>
    </Grid>
</Page>
