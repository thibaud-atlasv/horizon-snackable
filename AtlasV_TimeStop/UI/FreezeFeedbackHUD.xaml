<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      Background="Transparent">

    <Page.Resources>
        <Storyboard x:Key="FeedbackAnim">
            <!-- Line opacity -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FreezeLine" Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.08" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.15" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <!-- GradeText: TranslateY -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GradeText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.12" Value="-158">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="-105">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="-105"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.25" Value="-385">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <!-- GradeText: ScaleX -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GradeText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.25" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>

            <!-- GradeText: ScaleY -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GradeText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.25" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>

            <!-- GradeText: Opacity -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GradeText" Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.08" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.25" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <!-- ScoreText: TranslateY -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.04" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.16" Value="-158">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.26" Value="-105">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="-105"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.25" Value="-385">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <!-- ScoreText: ScaleX -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.25" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>

            <!-- ScoreText: ScaleY -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.25" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>

            <!-- ScoreText: Opacity -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreText" Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.04" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.12" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.8"  Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.25" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="1920" Height="3640">
            <Grid x:Name="FeedbackContainer">
                <b:Interaction.Triggers>
                    <b:PropertyChangedTrigger Binding="{Binding Path=animTrigger}">
                        <b:ControlStoryboardAction Storyboard="{StaticResource FeedbackAnim}"/>
                    </b:PropertyChangedTrigger>
                </b:Interaction.Triggers>

                <Grid x:Name="FeedbackGroup" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <Grid.RenderTransform>
                        <TranslateTransform Y="{Binding Path=lineY}"/>
                    </Grid.RenderTransform>

                    <!-- Horizontal Line -->
                    <Rectangle x:Name="FreezeLine"
                               Width="1920" Height="10"
                               Fill="{Binding Path=lineColor}"
                               HorizontalAlignment="Center" VerticalAlignment="Top"
                               Opacity="0"/>

                    <!-- Grade Text -->
                    <TextBlock x:Name="GradeText"
                               Text="{Binding Path=gradeText, FallbackValue=PERFECT}"
                               FontFamily="Bangers" FontWeight="Bold"
                               CharacterSpacing="50" FontSize="135"
                               Stroke="#FF000000" StrokeThickness="15"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Margin="80,-70,0,0"
                               Opacity="0"
                               RenderTransformOrigin="0.5,1">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{Binding Path=lineColor}"/>
                        </TextBlock.Foreground>
                        <TextBlock.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform Y="0"/>
                            </TransformGroup>
                        </TextBlock.RenderTransform>
                    </TextBlock>

                    <!-- Score Text -->
                    <TextBlock x:Name="ScoreText"
                               Text="{Binding Path=scoreText, FallbackValue=+1250}"
                               FontFamily="Bangers" FontWeight="Bold"
                               FontSize="125"
                               Stroke="#FF000000" StrokeThickness="15"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               Margin="0,-50,72,0"
                               Opacity="0"
                               RenderTransformOrigin="0.5,1">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{Binding Path=lineColor}"/>
                        </TextBlock.Foreground>
                        <TextBlock.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform Y="0"/>
                            </TransformGroup>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
