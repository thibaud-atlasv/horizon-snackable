<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="Transparent">

    <Page.Resources>
        <!-- Score Pulse Animation - triggered when scoreAnimating becomes true -->
        <Storyboard x:Key="ScorePulseAnim">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreContainer"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1.25">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseIn"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreContainer"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1.25">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseIn"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Center Text Pop-In Animation -->
        <Storyboard x:Key="CenterTextPopAnim">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterText"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.1" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Tap To Start Pulse Animation - looping scale pulse -->
        <Storyboard x:Key="TapToStartPulseAnim" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Hint second line pulse -->
        <Storyboard x:Key="HintPulseAnim" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="HintLine2" Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="0.4">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <Image x:Name="Logo" HorizontalAlignment="Center" Source="/Root;component/Textures/WaitAndSlice_logo.png" VerticalAlignment="Top" Margin="300,450,300,0">
            <Image.Visibility>
                <Binding Path="logoVisible">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter/>
                    </Binding.Converter>
                </Binding>
            </Image.Visibility>
        </Image>

        <!-- Tutorial hint — visible only on Start screen, anchored to bottom -->
        <Grid x:Name="HintContainer" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
              Margin="0,0,0,220">
            <Grid.Visibility>
                <Binding Path="logoVisible">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter/>
                    </Binding.Converter>
                </Binding>
            </Grid.Visibility>
            <b:Interaction.Triggers>
                <b:PropertyChangedTrigger Binding="{Binding Path=logoVisible}">
                    <b:ControlStoryboardAction Storyboard="{StaticResource HintPulseAnim}"/>
                </b:PropertyChangedTrigger>
            </b:Interaction.Triggers>

            <!-- Gradient band -->
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Offset="0"   Color="#00000000"/>
                        <GradientStop Offset="0.15" Color="#CC000000"/>
                        <GradientStop Offset="0.85" Color="#CC000000"/>
                        <GradientStop Offset="1"   Color="#00000000"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <StackPanel Margin="140,40,140,40">
                <TextBlock Text="Tap to slice an object before it reaches the water."
                           FontFamily="Roboto" FontSize="65" FontWeight="Normal"
                           Foreground="#CCFFFFFF"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="HintLine2"
                           Text="The longer you wait, the more points you get."
                           FontFamily="Roboto" FontSize="65" FontWeight="Bold"
                           Foreground="#FFFFFFFF"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           TextWrapping="Wrap" Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>
        <Grid x:Name="ScoreContainer" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5" VerticalAlignment="Top" Margin="0,200,0,200">
            <Grid.Visibility>
                <Binding Path="scoreVisible">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter/>
                    </Binding.Converter>
                </Binding>
            </Grid.Visibility>
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Grid.RenderTransform>
            <b:Interaction.Triggers>
                <b:DataTrigger Binding="{Binding Path=scoreAnimating}" Value="True">
                    <b:ControlStoryboardAction Storyboard="{StaticResource ScorePulseAnim}"/>
                </b:DataTrigger>
            </b:Interaction.Triggers>

            <Image Source="Textures/ScoreUI.png" Stretch="Fill" HorizontalAlignment="Center" VerticalAlignment="Center" Width="571.5" Height="184.5"/>            <Grid>
                <TextBlock Text="{Binding Path=score, StringFormat=F0}" FontFamily="Roboto" FontWeight="Bold" Foreground="#FF9A6721" HorizontalAlignment="Center" VerticalAlignment="Center" CharacterSpacing="-20" TextAlignment="Center" FontSize="150"/>
            </Grid>
        </Grid>
        <Grid x:Name="CenterTextContainer">
            <Grid.Visibility>
                <Binding Path="showCenterText">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter/>
                    </Binding.Converter>
                </Binding>
            </Grid.Visibility>
            <b:Interaction.Triggers>
                <b:PropertyChangedTrigger Binding="{Binding Path=centerText}">
                    <b:ControlStoryboardAction Storyboard="{StaticResource CenterTextPopAnim}"/>
                </b:PropertyChangedTrigger>
                <b:PropertyChangedTrigger Binding="{Binding Path=tapToStartPulsing}">
                    <b:ControlStoryboardAction Storyboard="{StaticResource TapToStartPulseAnim}"/>
                </b:PropertyChangedTrigger>
            </b:Interaction.Triggers>
            <TextBlock x:Name="CenterText"
                       FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center"
                       Text="{Binding Path=centerText, FallbackValue=TAP TO START}"
                       Foreground="{Binding Path=centerTextColor, FallbackValue=#FF0000}"
                       FontFamily="Bangers" CharacterSpacing="75" FontSize="200"
                       Stroke="#FF000000" StrokeThickness="25"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Grid>
        <!-- ═══════════════════════════════════════════════════════════════════
             SCORE DISPLAY - Top of screen, always visible
             ═══════════════════════════════════════════════════════════════════ -->

        <!-- ═══════════════════════════════════════════════════════════════════
             CENTER ANNOUNCEMENT TEXT - Middle of screen
             ═══════════════════════════════════════════════════════════════════ -->
    </Grid>
</Page>
