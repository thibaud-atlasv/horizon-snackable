<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="Transparent" d:DesignWidth="1920" d:DesignHeight="1920">

    <Page.Resources>
        <!-- Title Pop-In Animation -->
        <Storyboard x:Key="TitlePopAnim"/>

        <!-- Content Fade-In Animation -->
        <Storyboard x:Key="ContentFadeInAnim">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContentContainer"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContentContainer"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="45"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="45"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Leaderboard Entry Item Template -->
        <DataTemplate x:Key="LeaderboardEntryTemplate">
            <Grid Height="65" Margin="0,3,0,3">
                <!-- Current Player Highlight Background -->
                <Border x:Name="PlayerHighlightBorder" CornerRadius="12" Background="#40FFD700">
                    <Border.Visibility>
                        <Binding Path="isCurrentPlayer">
                            <Binding.Converter>
                                <BooleanToVisibilityConverter/>
                            </Binding.Converter>
                        </Binding>
                    </Border.Visibility>
                </Border>
                
                <!-- Normal Row Background -->
                <Border CornerRadius="12" Background="#305D3A1A">
                    <Border.Visibility>
                        <Binding Path="isCurrentPlayer">
                            <Binding.Converter>
                                <BooleanToVisibilityConverter Visibility="Hidden"/>
                            </Binding.Converter>
                        </Binding>
                    </Border.Visibility>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>

                    <!-- Rank Display -->
                    <Grid Grid.Column="0" VerticalAlignment="Center">
                        <!-- Shadow removed for golden background -->
                        <!-- Outline -->
                        <TextBlock Text="{Binding Path=rankDisplay}"
                                   FontFamily="Roboto" FontWeight="Bold" Stroke="#40000000" StrokeThickness="5"
                                   Foreground="Transparent"
                                   HorizontalAlignment="Left" VerticalAlignment="Center" TextAlignment="Center" FontSize="50"/>
                        <!-- Main Text - Color based on rank -->
                        <TextBlock Text="{Binding Path=rankDisplay}"
                                   FontFamily="Roboto" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" TextAlignment="Center" FontSize="50">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FF5D3A1A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=rank}" Value="1">
                                            <Setter Property="Foreground" Value="#FFFFD700"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Path=rank}" Value="2">
                                            <Setter Property="Foreground" Value="#FFC0C0C0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Path=rank}" Value="3">
                                            <Setter Property="Foreground" Value="#FFCD7F32"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Player Name -->
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <!-- Shadow removed for golden background -->
                        <!-- Outline -->
                        <TextBlock Text="{Binding Path=playerName}"
                                   FontFamily="Roboto" FontWeight="Bold" Stroke="#40000000" StrokeThickness="3"
                                   Foreground="Transparent"
                                   VerticalAlignment="Center" TextAlignment="Center" Margin="0,3,0,0" FontSize="50"/>
                        <!-- Main Text -->
                        <TextBlock Text="{Binding Path=playerName}"
                                   FontFamily="Roboto" FontWeight="Bold" Foreground="#FF4A2C0F"
                                   VerticalAlignment="Center" TextAlignment="Center" Margin="0,3,0,0" FontSize="50"/>
                    </Grid>

                    <!-- Score -->
                    <Grid Grid.Column="2" VerticalAlignment="Center">
                        <!-- Shadow removed for golden background -->
                        <!-- Outline -->
                        <TextBlock Text="{Binding Path=score, StringFormat=F0}"
                                   FontFamily="Roboto" FontWeight="Bold" Stroke="#40000000" StrokeThickness="3"
                                   Foreground="Transparent"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="50"/>
                        <!-- Main Text -->
                        <TextBlock Text="{Binding Path=score, StringFormat=F0}"
                                   FontFamily="Roboto" FontWeight="Bold" Foreground="#FF4A2C0F"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="50"/>
                    </Grid>
                </Grid>
            </Grid>
        </DataTemplate>

        <!-- Vertical Panel Template for ItemsControl -->
        <ItemsPanelTemplate x:Key="VerticalPanel">
            <StackPanel Orientation="Vertical"/>
        </ItemsPanelTemplate>
    </Page.Resources>

    <!-- Main Container - Visibility bound to isVisible -->
    <Grid>
        <Grid.Visibility>
            <Binding Path="isVisible">
                <Binding.Converter>
                    <BooleanToVisibilityConverter/>
                </Binding.Converter>
            </Binding>
        </Grid.Visibility>

        <!-- Trigger animations when visible -->
        <b:Interaction.Triggers>
            <b:DataTrigger Binding="{Binding Path=isVisible}" Value="True">
                <b:ControlStoryboardAction Storyboard="{StaticResource TitlePopAnim}"/>
                <b:ControlStoryboardAction Storyboard="{StaticResource ContentFadeInAnim}"/>
            </b:DataTrigger>
        </b:Interaction.Triggers>

        <!-- Container Grid for Image + Content Overlay -->
        <Grid MaxWidth="1394" MaxHeight="1656" HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <!-- Background Image -->
            <Image Source="Textures/GameOverBoard.png" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Content Overlay StackPanel -->
            <StackPanel VerticalAlignment="Top" Margin="100,450,150,0">
                
                <!-- ═══════════════════════════════════════════════════════════════════
                     TITLE SECTION - HIDDEN (title baked into image)
                     ═══════════════════════════════════════════════════════════════════ -->

                <!-- ═══════════════════════════════════════════════════════════════════
                     CONTENT CONTAINER - Fades in after title
                     ═══════════════════════════════════════════════════════════════════ -->
                <Grid x:Name="ContentContainer" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Grid.RenderTransform>

                    <StackPanel>
                        <!-- ═══════════════════════════════════════════════════════════════════
                             YOUR SCORE SECTION
                             ═══════════════════════════════════════════════════════════════════ -->
                        <Border CornerRadius="18" Height="325" VerticalAlignment="Center" Margin="0,0,0,30">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- YOUR SCORE Label -->
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Top">
                                    <!-- Main Text -->
                                    <TextBlock Text="YOUR SCORE"
                                               FontFamily="Roboto" FontWeight="Bold" Foreground="#FF5D3A1A"
                                               HorizontalAlignment="Center" FontSize="60"/>
                                </Grid>

                                <!-- Score Value -->
                                <Grid Margin="0,9,0,0">
                                    <!-- Main Text -->
                                    <TextBlock FontFamily="Roboto" FontWeight="Bold" Foreground="#FF4A2C0F"
                                               HorizontalAlignment="Center"
                                               CharacterSpacing="-20" FontSize="120" Text="{Binding Path=yourScore, StringFormat=F0, FallbackValue=Score}"/>
                                </Grid>

                                <!-- Rank Display -->
                            </StackPanel>
                        </Border>
                        <Border Background="#20FFFFFF" CornerRadius="18" MaxHeight="725" BorderThickness="5,5,5,5" Margin="100,-20,100,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Path=entries}" ItemTemplate="{StaticResource LeaderboardEntryTemplate}" ItemsPanel="{StaticResource VerticalPanel}"/>
                            </ScrollViewer>
                        </Border>

                        <!-- ═══════════════════════════════════════════════════════════════════
                             LOADING STATE
                             ═══════════════════════════════════════════════════════════════════ -->
                        <Grid Margin="0,15,0,15">
                            <Grid.Visibility>
                                <Binding Path="isLoading">
                                    <Binding.Converter>
                                        <BooleanToVisibilityConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Grid.Visibility>
                            <!-- Main Text -->
                            <TextBlock Text="Loading..."
                                       FontFamily="Roboto" FontWeight="Bold" FontSize="48"
                                       Foreground="#FF5D3A1A"
                                       HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- ═══════════════════════════════════════════════════════════════════
                             ERROR MESSAGE
                             ═══════════════════════════════════════════════════════════════════ -->
                        <Grid Margin="0,15,0,15">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=errorMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <!-- Main Text -->
                            <TextBlock Text="{Binding Path=errorMessage}"
                                       FontFamily="Roboto" FontWeight="Bold" FontSize="36"
                                       Foreground="#FFFF6666"
                                       HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- ═══════════════════════════════════════════════════════════════════
                             LEADERBOARD HEADER
                             ═══════════════════════════════════════════════════════════════════ -->

                        <!-- ═══════════════════════════════════════════════════════════════════
                             LEADERBOARD ENTRIES LIST
                             ═══════════════════════════════════════════════════════════════════ -->
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
