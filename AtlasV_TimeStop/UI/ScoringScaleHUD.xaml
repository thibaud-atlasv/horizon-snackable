<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      IsHitTestVisible="False">

    <Page.Resources>
        <DataTemplate x:Key="MarkerTemplate">
            <Grid VerticalAlignment="Top" HorizontalAlignment="Right" Width="640">
                <Grid.RenderTransform>
                    <TranslateTransform Y="{Binding Path=markerY}"/>
                </Grid.RenderTransform>

                <!-- Faded line: fade left → solid right -->
                <Rectangle VerticalAlignment="Top" Height="12" Margin="0,-6,160,0">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#00000000"/>
                            <GradientStop Offset="1">
                                <GradientStop.Color><SolidColorBrush Color="{Binding lineColor}"/></GradientStop.Color>
                            </GradientStop>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Solid right cap -->
                <Rectangle VerticalAlignment="Top" Height="12" Width="160"
                           HorizontalAlignment="Right" Margin="0,-6,0,0">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding lineColor}"/>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Label: right-aligned, muted -->
                <TextBlock Text="{Binding label}" FontFamily="Bangers" FontSize="104"
                           HorizontalAlignment="Right" VerticalAlignment="Top"
                           Margin="0,8,0,0" Opacity="0.75">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="{Binding textColor}"/>
                    </TextBlock.Foreground>
                </TextBlock>
            </Grid>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="AbsolutePanel">
            <Grid/>
        </ItemsPanelTemplate>
    </Page.Resources>

    <Grid>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="1920" Height="3640">
            <ItemsControl ItemsSource="{Binding Path=markers}"
                          ItemTemplate="{StaticResource MarkerTemplate}"
                          ItemsPanel="{StaticResource AbsolutePanel}"/>
        </Grid>
    </Grid>
</Page>
