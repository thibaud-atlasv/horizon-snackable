<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <!-- Colors matching TowerShop/GameOverScreen medieval fantasy style -->
        <SolidColorBrush x:Key="GoldBrush" Color="#f5c518"/>
        <SolidColorBrush x:Key="GoldDarkBrush" Color="#c9a000"/>
        <SolidColorBrush x:Key="WoodBrush" Color="#2a1a0e"/>
        <SolidColorBrush x:Key="RedBrush" Color="#e74c3c"/>
        <SolidColorBrush x:Key="CreamBrush" Color="#f5e6c8"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Page.Resources>
    <Page.Visibility>
        <Binding Path="visible">
            <Binding.Converter>
                <BooleanToVisibilityConverter/>
            </Binding.Converter>
        </Binding>
    </Page.Visibility>

    <Grid>
    <!-- Countdown overlay - centered on screen, shown only before wave 1 -->
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
          Visibility="{Binding showCountdown, Converter={StaticResource BoolToVisConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Label -->
        <Grid Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="WAVE INCOMING!" FontFamily="Anton" FontSize="90" FontWeight="Bold" Foreground="Black" Margin="-4,0,0,0"/>
            <TextBlock Text="WAVE INCOMING!" FontFamily="Anton" FontSize="90" FontWeight="Bold" Foreground="Black" Margin="4,0,0,0"/>
            <TextBlock Text="WAVE INCOMING!" FontFamily="Anton" FontSize="90" FontWeight="Bold" Foreground="Black" Margin="0,-4,0,0"/>
            <TextBlock Text="WAVE INCOMING!" FontFamily="Anton" FontSize="90" FontWeight="Bold" Foreground="Black" Margin="0,4,0,0"/>
            <TextBlock Text="WAVE INCOMING!" FontFamily="Anton" FontSize="90" FontWeight="Bold" Foreground="{StaticResource CreamBrush}"/>
        </Grid>
        <!-- Big countdown number -->
        <Grid Grid.Row="1" HorizontalAlignment="Center">
            <TextBlock Text="{Binding countdown, StringFormat=F0}" FontFamily="Anton" FontSize="400" FontWeight="Bold" Foreground="Black" Margin="-6,0,0,0"/>
            <TextBlock Text="{Binding countdown, StringFormat=F0}" FontFamily="Anton" FontSize="400" FontWeight="Bold" Foreground="Black" Margin="6,0,0,0"/>
            <TextBlock Text="{Binding countdown, StringFormat=F0}" FontFamily="Anton" FontSize="400" FontWeight="Bold" Foreground="Black" Margin="0,-6,0,0"/>
            <TextBlock Text="{Binding countdown, StringFormat=F0}" FontFamily="Anton" FontSize="400" FontWeight="Bold" Foreground="Black" Margin="0,6,0,0"/>
            <TextBlock Text="{Binding countdown, StringFormat=F0}" FontFamily="Anton" FontSize="400" FontWeight="Bold" Foreground="{StaticResource GoldBrush}"/>
        </Grid>
    </Grid>

    <!-- Top HUD Bar - Lives (left), Wave (center), and Gold (right) -->
    <Grid VerticalAlignment="Top" Height="280">
        <!-- Dark wood gradient background matching TowerShop bottom bar -->
        <Border CornerRadius="0,0,40,40">
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#F02a1a0e" Offset="0"/>
                    <GradientStop Color="#FF0a0500" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <!-- Gold top border line -->
            <Border BorderThickness="0,6,0,0" BorderBrush="#553B14"/>
        </Border>
        
        <!-- Content: Three sections - left, center, and right aligned -->
        <Grid Margin="80,30,80,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SECTION: Lives Counter Panel -->
            <Border Grid.Column="0" 
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="#CC1a1a2e"
                    BorderBrush="{StaticResource GoldBrush}"
                    BorderThickness="6"
                    CornerRadius="20"
                    Padding="30,15,40,15">
                <Grid>
                    <!-- Corner Ornaments - Top Left -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-20,-8,0,0"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-16,-4,0,0"/>
                    <!-- Corner Ornaments - Top Right -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-8,-20,0"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-4,-16,0"/>
                    <!-- Corner Ornaments - Bottom Left -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-20,0,0,-8"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-16,0,0,-4"/>
                    <!-- Corner Ornaments - Bottom Right -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-20,-8"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-16,-4"/>

                    <!-- Lives Content -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Heart icon with gold outline stroke -->
                        <Viewbox Width="120" Height="120" Margin="0,0,25,0">
                            <Grid>
                                <!-- Gold outline stroke (slightly larger) -->
                                <Path Fill="{StaticResource GoldBrush}"
                                      Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <ScaleTransform ScaleX="1.15" ScaleY="1.15"/>
                                    </Path.RenderTransform>
                                </Path>
                                <!-- Red heart fill -->
                                <Path Fill="{StaticResource RedBrush}"
                                      Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                            </Grid>
                        </Viewbox>
                        <!-- Lives value with outlined text -->
                        <Grid VerticalAlignment="Center">
                            <TextBlock Text="{Binding Path=lives, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="-4,0,0,0"/>
                            <TextBlock Text="{Binding Path=lives, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="4,0,0,0"/>
                            <TextBlock Text="{Binding Path=lives, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="0,-4,0,0"/>
                            <TextBlock Text="{Binding Path=lives, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding Path=lives, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="{StaticResource CreamBrush}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CENTER SECTION: Wave with outlined text -->
            <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,100,0,0">
                <TextBlock Text="{Binding Path=waveText}" 
                           FontSize="80" FontWeight="Bold" Foreground="Black" Margin="-4,0,0,0"/>
                <TextBlock Text="{Binding Path=waveText}" 
                           FontSize="80" FontWeight="Bold" Foreground="Black" Margin="4,0,0,0"/>
                <TextBlock Text="{Binding Path=waveText}" 
                           FontSize="80" FontWeight="Bold" Foreground="Black" Margin="0,-4,0,0"/>
                <TextBlock Text="{Binding Path=waveText}" 
                           FontSize="80" FontWeight="Bold" Foreground="Black" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding Path=waveText}" 
                           FontSize="80" FontWeight="Bold" Foreground="{StaticResource GoldBrush}"/>
            </Grid>

            <!-- RIGHT SECTION: Gold Counter Panel -->
            <Border Grid.Column="2" 
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="#CC1a1a2e"
                    BorderBrush="{StaticResource GoldBrush}"
                    BorderThickness="6"
                    CornerRadius="20"
                    Padding="30,15,40,15">
                <Grid>
                    <!-- Corner Ornaments - Top Left -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-20,-8,0,0"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-16,-4,0,0"/>
                    <!-- Corner Ornaments - Top Right -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-8,-20,0"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-4,-16,0"/>
                    <!-- Corner Ornaments - Bottom Left -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-20,0,0,-8"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-16,0,0,-4"/>
                    <!-- Corner Ornaments - Bottom Right -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-20,-8"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-16,-4"/>

                    <!-- Gold Content -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Gold icon from image -->
                        <Image Source="/Root;component/Textures/gold_icon.png" 
                               Width="120" 
                               Height="120" 
                               Margin="0,0,25,0"
                               VerticalAlignment="Center"/>
                        <!-- Gold value with outlined text -->
                        <Grid VerticalAlignment="Center">
                            <TextBlock Text="{Binding Path=gold, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="-4,0,0,0"/>
                            <TextBlock Text="{Binding Path=gold, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="4,0,0,0"/>
                            <TextBlock Text="{Binding Path=gold, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="0,-4,0,0"/>
                            <TextBlock Text="{Binding Path=gold, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding Path=gold, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="{StaticResource GoldBrush}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </Grid>
</Page>
