<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignWidth="1080" d:DesignHeight="1920">

    <Page.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1a1a2e"/>
        <SolidColorBrush x:Key="GoldBrush" Color="#f5c518"/>
        <SolidColorBrush x:Key="GoldDarkBrush" Color="#c9a000"/>
        <SolidColorBrush x:Key="GoldLightBrush" Color="#ffd84a"/>
        <SolidColorBrush x:Key="TextWhiteBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextGoldBrush" Color="#d4a84a"/>
        <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>
    </Page.Resources>

    <!-- Main Container - Full Screen Overlay -->
    <Grid>
        <Grid.Visibility>
            <Binding Path="visible">
                <Binding.Converter>
                    <BooleanToVisibilityConverter/>
                </Binding.Converter>
            </Binding>
        </Grid.Visibility>
        <Grid.Background>
            <RadialGradientBrush>
                <GradientStop Color="#FF000000" Offset="0"/>
                <GradientStop Offset="1" Color="#FF1A1A2E"/>
            </RadialGradientBrush>
        </Grid.Background>

        <!-- Content Layout -->
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <!-- Row 0: Top spacing -->
                <RowDefinition Height="0.15*"/>
                <!-- Row 1: Logo area -->
                <RowDefinition Height="Auto"/>
                <!-- Row 2: Flexible space -->
                <RowDefinition Height="0.1*"/>
                <!-- Row 3: Button area -->
                <RowDefinition Height="Auto"/>
                <!-- Row 4: Subtitle text -->
                <RowDefinition Height="Auto"/>
                <!-- Row 5: Bottom spacing -->
                <RowDefinition Height="0.2*"/>
            </Grid.RowDefinitions>

            <!-- Row 1: Logo Image - Large and Prominent -->
            <Image Grid.Row="1"
                   Source="/Root;component/KeyArts/GoblinClash_logo.png" Stretch="UniformToFill"/>

            <!-- Row 3: JOUER Button with 3D Medieval Style -->
            <Grid Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Shadow layer for 3D depth effect - offset behind -->
                <Border Margin="16,16,0,0"
                        CornerRadius="32"
                        Width="960"
                        Height="280" Background="#FF000000"/>

                <!-- Main button container -->
                <Button Command="{Binding Path=events.playTap}"
                        Background="{StaticResource TransparentBrush}"
                        BorderThickness="0"
                        Width="960"
                        Height="280"
                        Cursor="Hand" Padding="0,0,0,0">
                    <!-- Outer ornate frame -->
                    <Border CornerRadius="32"
                            BorderThickness="12"
                            Width="960" Height="280" BorderBrush="#FFFDBA12">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#FF070701" Offset="0"/>
                                <GradientStop Color="#FF1D1D1C" Offset="0"/>
                                <GradientStop Offset="0" Color="#FF000000"/>
                                <GradientStop Offset="1" Color="#FF3D2407"/>
                            </RadialGradientBrush>
                        </Border.Background>
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock FontSize="144" FontWeight="Bold" Foreground="Black" Margin="-6,0,0,0" Text="PLAY" FontFamily="Anton"/>
                            <TextBlock FontSize="144" FontWeight="Bold" Foreground="Black" Margin="6,0,0,0" Text="PLAY" FontFamily="Anton"/>
                            <TextBlock FontSize="144" FontWeight="Bold" Foreground="Black" Margin="0,-6,0,0" Text="PLAY" FontFamily="Anton"/>
                            <TextBlock FontSize="144" FontWeight="Bold" Foreground="Black" Margin="0,6,0,0" Text="PLAY" FontFamily="Anton"/>
                            <TextBlock FontSize="144" FontWeight="Bold" Text="PLAY" FontFamily="Anton" Foreground="#FFF5E6C8"/>
                        </Grid>
                    </Border>
                </Button>
                <Grid Margin="20,20,20,20">
                    <Ellipse Width="36" Height="36" Fill="{StaticResource GoldBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,16,0,0"/>
                    <Ellipse Width="20" Height="20" Fill="{StaticResource GoldDarkBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="24,24,0,0"/>
                    <Ellipse Width="36" Height="36" Fill="{StaticResource GoldBrush}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,16,16,0"/>
                    <Ellipse Width="20" Height="20" Fill="{StaticResource GoldDarkBrush}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,24,24,0"/>
                    <Ellipse Width="36" Height="36" Fill="{StaticResource GoldBrush}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16,0,0,16"/>
                    <Ellipse Width="20" Height="20" Fill="{StaticResource GoldDarkBrush}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="24,0,0,24"/>
                    <Ellipse Width="36" Height="36" Fill="{StaticResource GoldBrush}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,16"/>
                    <Ellipse Width="20" Height="20" Fill="{StaticResource GoldDarkBrush}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,24"/>
                </Grid>
            </Grid>

            <!-- Row 4: Subtitle text -->
        </Grid>
    </Grid>
</Page>
