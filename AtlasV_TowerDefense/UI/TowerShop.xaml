<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d">

    <Page.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BackgroundBarBrush" Color="#E62a1a0e"/>
        <SolidColorBrush x:Key="ParchmentLightBrush" Color="#FFf4e4bc"/>
        <SolidColorBrush x:Key="ParchmentDarkBrush" Color="#FFd4c4a0"/>
        <SolidColorBrush x:Key="TextWhiteBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="GoldBrush" Color="#FFf5c518"/>
        <SolidColorBrush x:Key="RedBrush" Color="#FFe74c3c"/>
        <SolidColorBrush x:Key="GoldDarkBrush" Color="#FFc9a000"/>
        <SolidColorBrush x:Key="WoodBrush" Color="#FF2a1a0e"/>

        <!-- Horizontal Panel Template -->
        <ItemsPanelTemplate x:Key="HorizontalPanel">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" ClipToBounds="False"/>
        </ItemsPanelTemplate>

        <!-- Item Container Style -->
        <Style x:Key="TowerItemContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Margin" Value="20,0,20,0"/>
        </Style>

        <!-- Tower Card Item Template -->
        <DataTemplate x:Key="TowerCardTemplate">
            <DataTemplate.Resources>
                <!-- Select Animation Storyboard -->
                <Storyboard x:Key="SelectAnimation">
                    <!-- TranslateTransform.Y to -150 -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardTranslate"
                                                    Storyboard.TargetProperty="Y">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="-50">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <QuadraticEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <!-- ScaleTransform.ScaleX to 1.05 -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardScale"
                                                    Storyboard.TargetProperty="ScaleX">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.2">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <QuadraticEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <!-- ScaleTransform.ScaleY to 1.05 -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardScale"
                                                    Storyboard.TargetProperty="ScaleY">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.2">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <QuadraticEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <!-- GlowBorder.Opacity to 0.9 -->
                </Storyboard>

                <!-- Deselect Animation Storyboard -->
                <Storyboard x:Key="DeselectAnimation">
                    <!-- TranslateTransform.Y back to 0 -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardTranslate"
                                                    Storyboard.TargetProperty="Y">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <QuadraticEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <!-- ScaleTransform.ScaleX back to 1.0 -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardScale"
                                                    Storyboard.TargetProperty="ScaleX">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <QuadraticEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <!-- ScaleTransform.ScaleY back to 1.0 -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardScale"
                                                    Storyboard.TargetProperty="ScaleY">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <QuadraticEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <!-- GlowBorder.Opacity back to 0 -->
                </Storyboard>
            </DataTemplate.Resources>

            <!-- Card container with TransformGroup for animated selection -->
            <Grid x:Name="CardContainer" RenderTransformOrigin="0.5,1.0" ClipToBounds="False" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,10,0">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="CardScale" ScaleX="1.0" ScaleY="1.0"/>
                        <TranslateTransform x:Name="CardTranslate" X="0" Y="0"/>
                    </TransformGroup>
                </Grid.RenderTransform>

                <!-- Main Card - 400x620 always fully visible -->
                <Grid x:Name="CardGrid" Width="400" Height="620" ClipToBounds="False">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="MouseLeftButtonUp">
                            <b:InvokeCommandAction Command="{Binding DataContext.events.towerTap, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                   CommandParameter="{Binding towerId}"/>
                        </b:EventTrigger>
                    </b:Interaction.Triggers>

                    <!-- Drop Shadow Layer (simulated with offset dark border) -->

                    <!-- Second Shadow Layer for depth -->
                    <Border Margin="5,5,5,5"
                            CornerRadius="50,50,50,50" Background="#FF554318"/>

                    <!-- Outer Gold Frame Border -->
                    <Border x:Name="CardBorder"
                            BorderBrush="{StaticResource GoldBrush}"
                            ClipToBounds="False" BorderThickness="8,8,8,8" CornerRadius="50,50,50,50">
                        <!-- Inner Tower Color Border -->
                        <Border ClipToBounds="False" BorderThickness="10,10,10,10" CornerRadius="40,40,40,40">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{Binding Path=secondaryColor, FallbackValue=#FFFFFF}"/>
                            </Border.BorderBrush>

                            <!-- Radial Gradient Background Layer -->
                            <Border ClipToBounds="False" CornerRadius="34,34,34,34">
                                <Border.Background>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#00000000" Offset="0"/>
                                        <GradientStop Offset="1" Color="{Binding Path=towerColor, FallbackValue=#FF0000}"/>
                                    </RadialGradientBrush>
                                </Border.Background>

                                <!-- Tower Image as Full Card Background -->
                                <Border ClipToBounds="False" CornerRadius="50,50,50,50">
                                    <Border.Background>
                                        <ImageBrush Viewbox="0,0.2,1,0" ImageSource="/Root;component/Textures/canon_tower.png" Stretch="Uniform"/>
                                    </Border.Background>

                                    <!-- Semi-transparent overlay for text readability -->
                                    <Border ClipToBounds="False" CornerRadius="50,50,50,50">

                                    <Grid Margin="20,20,20,20">
                                        <Grid.RowDefinitions>
                                            <!-- Row 0: Price at top (Auto) -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- Row 1: Empty space showing background image (*) -->
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Corner Ornaments (span all rows) -->
                                        <!-- Top Left -->
                                        <Ellipse Grid.RowSpan="2" Width="22" Height="22" 
                                                 Fill="{StaticResource GoldBrush}"
                                                 HorizontalAlignment="Left" VerticalAlignment="Top"
                                                 Margin="6,6,0,0"/>
                                        <Ellipse Grid.RowSpan="2" Width="14" Height="14" 
                                                 Fill="{StaticResource GoldDarkBrush}"
                                                 HorizontalAlignment="Left" VerticalAlignment="Top"
                                                 Margin="10,10,0,0"/>

                                        <!-- Top Right -->
                                        <Ellipse Grid.RowSpan="2" Width="22" Height="22" 
                                                 Fill="{StaticResource GoldBrush}"
                                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                                 Margin="0,6,6,0"/>
                                        <Ellipse Grid.RowSpan="2" Width="14" Height="14" 
                                                 Fill="{StaticResource GoldDarkBrush}"
                                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                                 Margin="0,10,10,0"/>

                                        <!-- Bottom Left -->
                                        <Ellipse Grid.Row="1" Width="22" Height="22" 
                                                 Fill="{StaticResource GoldBrush}"
                                                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                 Margin="6,0,0,6"/>
                                        <Ellipse Grid.Row="1" Width="14" Height="14" 
                                                 Fill="{StaticResource GoldDarkBrush}"
                                                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                 Margin="10,0,0,10"/>

                                        <!-- Bottom Right -->
                                        <Ellipse Grid.Row="1" Width="22" Height="22" 
                                                 Fill="{StaticResource GoldBrush}"
                                                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                 Margin="0,0,6,6"/>
                                        <Ellipse Grid.Row="1" Width="14" Height="14" 
                                                 Fill="{StaticResource GoldDarkBrush}"
                                                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                 Margin="0,0,10,10"/>

                                        <!-- Row 0: Price Bar at TOP -->

                                        <!-- Row 1: Empty space showing background image -->
                                        <!-- No content needed - the ImageBrush background shows through -->
                                    </Grid>
                                    </Border>
                                </Border>
                            </Border>
                        </Border>
                    </Border>

                    <!-- Selection Glow Border (brighter when selected) -->
                </Grid>
                <Border x:Name="Disabled" CornerRadius="50,50,50,50" BorderThickness="10,10,10,10" Background="#AF000000" Visibility="Collapsed" IsEnabled="False"/>

                <!-- Ribbon Banner - OUTSIDE the border chain to avoid CornerRadius clipping -->
                <!-- Positioned as sibling of CardGrid, overlays at correct Y position -->
                <Grid VerticalAlignment="Top" 
                      IsHitTestVisible="False"
                      ClipToBounds="False" Width="400" IsEnabled="False" Height="147" Margin="0,130,0,0">
                    <Image Source="/Root;component/Textures/WoodPlank.png" HorizontalAlignment="Center" Stretch="Fill" Width="303" VerticalAlignment="Center"/>
                    <!-- Ribbon shadow with rounded corners -->

                    <!-- Main ribbon body with rounded corners -->
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" FontFamily="Anton" Margin="-3,0,0,0" IsHitTestVisible="False" FontSize="60" Text="{Binding Path=name, FallbackValue=test}"/>
                        <TextBlock Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" FontFamily="Anton" IsHitTestVisible="False" FontSize="60" Text="{Binding Path=name, FallbackValue=test}" Margin="2,0,-1,0"/>
                        <TextBlock Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" FontFamily="Anton" IsHitTestVisible="False" FontSize="60" Text="{Binding Path=name, FallbackValue=test}" Margin="0,-3,1,0"/>
                        <TextBlock Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" FontFamily="Anton" Margin="0,3,0,0" IsHitTestVisible="False" FontSize="60" Text="{Binding Path=name, FallbackValue=test}"/>
                        <TextBlock FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" FontFamily="Anton" Text="{Binding Path=name, FallbackValue=test}" FontSize="60" Foreground="#FFF5E6C8"/>
                    </Grid>

                    <!-- Tower Name Text with outline -->
                </Grid>
                <Border Grid.Row="0" CornerRadius="12,12,0,0" VerticalAlignment="Top" IsEnabled="False" Margin="0,40,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="/Root;component/Textures/gold_icon.png" Width="62" Height="62" Margin="10,10,10,10"/>
                        <Grid VerticalAlignment="Center">
                            <TextBlock Text="{Binding cost, StringFormat=F0}" Foreground="Black" FontWeight="Bold" Margin="-3,0,0,0" IsHitTestVisible="False" FontSize="75"/>
                            <TextBlock Text="{Binding cost, StringFormat=F0}" Foreground="Black" FontWeight="Bold" Margin="3,0,0,0" IsHitTestVisible="False" FontSize="75"/>
                            <TextBlock Text="{Binding cost, StringFormat=F0}" Foreground="Black" FontWeight="Bold" Margin="0,-3,0,0" IsHitTestVisible="False" FontSize="75"/>
                            <TextBlock Text="{Binding cost, StringFormat=F0}" Foreground="Black" FontWeight="Bold" Margin="0,3,0,0" IsHitTestVisible="False" FontSize="75"/>
                            <TextBlock x:Name="CostText" Text="{Binding cost, StringFormat=F0}" Foreground="{StaticResource GoldBrush}" FontWeight="Bold" FontSize="75"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- DataTriggers for state-based styling -->
            <DataTemplate.Triggers>
                <!-- Affordable state - full opacity, gold cost text -->
                <DataTrigger Binding="{Binding state}" Value="affordable">
                    <Setter TargetName="CardContainer" Property="Opacity" Value="1.0"/>
                    <Setter TargetName="CostText" Property="Foreground" Value="{StaticResource GoldBrush}"/>
                    <Setter TargetName="Disabled" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>

                <!-- Too expensive state - red cost text (no opacity change) -->
                <DataTrigger Binding="{Binding state}" Value="too_expensive">
                    <Setter TargetName="CostText" Property="Foreground" Value="{StaticResource RedBrush}"/>
                    <Setter TargetName="Disabled" Property="Visibility" Value="Visible"/>
                </DataTrigger>

                <!-- Selected state - animate glow, scale, and rise using Storyboard -->
                <DataTrigger Binding="{Binding selected}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource SelectAnimation}"/>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard Storyboard="{StaticResource DeselectAnimation}"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Page.Resources>

    <!-- Main Layout - Full width bar at bottom with negative top margin for overflow -->
    <Grid ClipToBounds="False" VerticalAlignment="Bottom" Height="800">
        <Grid.Visibility>
            <Binding Path="visible">
                <Binding.Converter>
                    <BooleanToVisibilityConverter/>
                </Binding.Converter>
            </Binding>
        </Grid.Visibility>

        <!-- Medieval wood/leather background bar (purely decorative, no children that clip) -->
        <Border VerticalAlignment="Bottom"
                CornerRadius="38,38,0,0" Height="400" d:IsLocked="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#F02a1a0e" Offset="0"/>
                    <GradientStop Color="#F81a0a00" Offset="0.3"/>
                    <GradientStop Color="#FF0a0500" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <!-- Decorative gold top border line only -->
            <Border BorderThickness="6,6,6,0" BorderBrush="#FF553B14"/>
        </Border>

        <!-- Tower Items List - FREE from CornerRadius clipping, sibling of background -->
        <ItemsControl ItemsSource="{Binding items}"
                      ItemsPanel="{StaticResource HorizontalPanel}"
                      ItemTemplate="{StaticResource TowerCardTemplate}"
                      ItemContainerStyle="{StaticResource TowerItemContainerStyle}"
                      HorizontalAlignment="Center"
                      ClipToBounds="False" Margin="0,0,0,-650"/>
    </Grid>
</Page>
