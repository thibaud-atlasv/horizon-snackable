<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:noesis="clr-namespace:NoesisGUIExtensions"
      mc:Ignorable="d"
      Background="Transparent" d:DesignWidth="900" d:DesignHeight="1600">

    <Page.Resources>
        <!-- Semi-transparent background for top bar -->
        <SolidColorBrush x:Key="TopBarBackground" Color="#99000000"/>
        
        <!-- Text colors -->
        <SolidColorBrush x:Key="HUDTextColor" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="CenterTextColor" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="CenterTextShadow" Color="#CC000000"/>
        
        <!-- Heart color -->
        <SolidColorBrush x:Key="HeartColor" Color="#FFFF0000"/>
    </Page.Resources>

    <Grid>
        <!-- Main layout: Top bar at top, center text in middle -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- CENTER TEXT: Game state messages (hidden by default) -->
        <Grid x:Name="CenterTextContainer" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid.Visibility>
                <Binding Path="showCenterText">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter/>
                    </Binding.Converter>
                </Binding>
            </Grid.Visibility>
            <Border Background="{StaticResource CenterTextShadow}" CornerRadius="12" Padding="40,24">
                <TextBlock x:Name="CenterText" Text="{Binding Path=centerText}" FontFamily="Roboto" FontWeight="Bold" Foreground="{StaticResource CenterTextColor}" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="150">
                    <TextBlock.Visibility>
                        <Binding Path="showCenterText">
                            <Binding.Converter>
                                <BooleanToVisibilityConverter/>
                            </Binding.Converter>
                        </Binding>
                    </TextBlock.Visibility>
                </TextBlock>
            </Border>
        </Grid>

        <!-- HEARTS: Bottom-right corner lives display -->

        <!-- TOP BAR: Score | Level -->
        <Border Background="{StaticResource TopBarBackground}"
                Padding="20,12" Grid.Row="1">
            <Grid Margin="20,20,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Score (Left) -->

                <!-- Level (Center) -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Level " 
                               FontFamily="Roboto"
                               FontWeight="Bold"
                               Foreground="{StaticResource HUDTextColor}" FontSize="100"/>
                    <TextBlock Text="{Binding Path=level, StringFormat=F0}" 
                               FontFamily="Roboto"
                               FontWeight="Bold"
                               Foreground="{StaticResource HUDTextColor}" FontSize="100"/>
                </StackPanel>

                <!-- Empty right column (lives moved to bottom-right hearts) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Path x:Name="Heart1" Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,8,8,8" Fill="#FFFFADAD" Width="80" Height="80">
                            <b:Interaction.Triggers>
                                <b:DataTrigger Binding="{Binding Path=lives}" Comparison="GreaterThanOrEqual" Value="1">
                                    <b:ChangePropertyAction TargetName="Heart1" PropertyName="Visibility" Value="Visible"/>
                                </b:DataTrigger>
                                <b:DataTrigger Binding="{Binding Path=lives}" Comparison="LessThan" Value="1">
                                    <b:ChangePropertyAction TargetName="Heart1" PropertyName="Visibility" Value="Collapsed"/>
                                </b:DataTrigger>
                            </b:Interaction.Triggers>
                        </Path>
                        <Path x:Name="Heart2" Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,8,8,8" Fill="#FFFFADAD" Width="80" Height="80">
                            <b:Interaction.Triggers>
                                <b:DataTrigger Binding="{Binding Path=lives}" Comparison="GreaterThanOrEqual" Value="2">
                                    <b:ChangePropertyAction TargetName="Heart2" PropertyName="Visibility" Value="Visible"/>
                                </b:DataTrigger>
                                <b:DataTrigger Binding="{Binding Path=lives}" Comparison="LessThan" Value="2">
                                    <b:ChangePropertyAction TargetName="Heart2" PropertyName="Visibility" Value="Collapsed"/>
                                </b:DataTrigger>
                            </b:Interaction.Triggers>
                        </Path>
                        <Path x:Name="Heart3" Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,8,8,8" Fill="#FFFFADAD" Width="80" Height="80">
                            <b:Interaction.Triggers>
                                <b:DataTrigger Binding="{Binding Path=lives}" Comparison="GreaterThanOrEqual" Value="3">
                                    <b:ChangePropertyAction TargetName="Heart3" PropertyName="Visibility" Value="Visible"/>
                                </b:DataTrigger>
                                <b:DataTrigger Binding="{Binding Path=lives}" Comparison="LessThan" Value="3">
                                    <b:ChangePropertyAction TargetName="Heart3" PropertyName="Visibility" Value="Collapsed"/>
                                </b:DataTrigger>
                            </b:Interaction.Triggers>
                        </Path>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
