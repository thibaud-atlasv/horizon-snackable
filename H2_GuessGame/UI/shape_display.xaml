<Grid Background="Black"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- REQUIRED: BooleanToVisibilityConverter for visibility bindings -->
  <Grid.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </Grid.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="480" Height="800">
      <!-- Background -->
      <Rectangle Fill="Black" Width="480" Height="800"/>

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: HUD Banner — score + timer bar -->
        <Grid Grid.Row="0" Margin="16,12,16,4">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Score text -->
          <TextBlock Grid.Row="0"
                     Text="{Binding scoreText}"
                     FontSize="28" FontWeight="Bold" Foreground="White"
                     HorizontalAlignment="Center" Margin="0,0,0,6"/>

          <!-- Timer bar -->
          <Border Grid.Row="1" Background="#2a2a3e" CornerRadius="4" Height="10"
                  HorizontalAlignment="Stretch" ClipToBounds="True">
            <Rectangle Fill="#7c3aed" RadiusX="4" RadiusY="4"
                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                       RenderTransformOrigin="0,0.5">
              <Rectangle.RenderTransform>
                <ScaleTransform ScaleX="{Binding timerProgress}" ScaleY="1"/>
              </Rectangle.RenderTransform>
            </Rectangle>
          </Border>
        </Grid>

        <!-- Row 1: Intruder Zone — shapes + scoped overlay -->
        <Border Grid.Row="1"
                Background="#1e1e2e" CornerRadius="16"
                ClipToBounds="True" Margin="16,16,16,16" Width="450" Height="450">
          <Grid Width="450" Height="450">
            <!-- Shapes rendered via ItemsControl with Canvas panel -->
            <ItemsControl ItemsSource="{Binding shapes}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <Canvas Width="450" Height="450"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid RenderTransformOrigin="0, 0" Opacity="{Binding opacity}">
                    <Path.RenderTransform>
                      <TransformGroup>
                        <ScaleTransform ScaleX="{Binding scale}" ScaleY="{Binding scale}"/>
                        <RotateTransform Angle="{Binding rotation}"/>
                        <TranslateTransform X="{Binding x}" Y="{Binding y}"/>
                      </TransformGroup>
                    </Path.RenderTransform>
                    <Path Data="{Binding pathData}"
                          Fill="{Binding fillColor}"
                          Visibility="{Binding pathVisible, Converter={StaticResource BoolToVis}}"
                          Stretch="None">
                    <Path.RenderTransform>
                      <TransformGroup>
                        <RotateTransform Angle="{Binding rotation}"/>
                      </TransformGroup>
                    </Path.RenderTransform>
                    </Path>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Overlay scoped to Intruder Zone only -->
            <Rectangle Fill="{Binding overlayColor}"
                       Opacity="{Binding overlayOpacity}"
                       RadiusX="16" RadiusY="16"
                       IsHitTestVisible="False"/>
          </Grid>
        </Border>

        <!-- Row 2: 2×2 answer button grid -->
        <Grid Grid.Row="2" Margin="20,8,20,20" Height="200">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <!-- Option 0 (top-left) -->
          <Button Grid.Row="0" Grid.Column="0" Margin="6"
                  Command="{Binding events.onAnswerOptionPressed}"
                  CommandParameter="0"
                  Background="{Binding option0BgColor}" BorderBrush="{Binding option0BorderColor}" BorderThickness="2">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
              </ControlTemplate>
            </Button.Template>
            <Viewbox Stretch="Uniform" Margin="16">
              <Grid Width="40" Height="40">
                <Path Data="{Binding option0.pathData}"
                      Fill="{Binding option0.fillColor}"
                      Stretch="Uniform" Width="30" Height="30"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="{Binding option0.pathVisible, Converter={StaticResource BoolToVis}}"/>
              </Grid>
            </Viewbox>
          </Button>

          <!-- Option 1 (top-right) -->
          <Button Grid.Row="0" Grid.Column="1" Margin="6"
                  Command="{Binding events.onAnswerOptionPressed}"
                  CommandParameter="1"
                  Background="{Binding option1BgColor}" BorderBrush="{Binding option1BorderColor}" BorderThickness="2">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
              </ControlTemplate>
            </Button.Template>
            <Viewbox Stretch="Uniform" Margin="16">
              <Grid Width="40" Height="40">
                <Path Data="{Binding option1.pathData}"
                      Fill="{Binding option1.fillColor}"
                      Stretch="Uniform" Width="30" Height="30"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="{Binding option1.pathVisible, Converter={StaticResource BoolToVis}}"/>
              </Grid>
            </Viewbox>
          </Button>

          <!-- Option 2 (bottom-left) -->
          <Button Grid.Row="1" Grid.Column="0" Margin="6"
                  Command="{Binding events.onAnswerOptionPressed}"
                  CommandParameter="2"
                  Background="{Binding option2BgColor}" BorderBrush="{Binding option2BorderColor}" BorderThickness="2">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
              </ControlTemplate>
            </Button.Template>
            <Viewbox Stretch="Uniform" Margin="16">
              <Grid Width="40" Height="40">
                <Path Data="{Binding option2.pathData}"
                      Fill="{Binding option2.fillColor}"
                      Stretch="Uniform" Width="30" Height="30"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="{Binding option2.pathVisible, Converter={StaticResource BoolToVis}}"/>
              </Grid>
            </Viewbox>
          </Button>

          <!-- Option 3 (bottom-right) -->
          <Button Grid.Row="1" Grid.Column="1" Margin="6"
                  Command="{Binding events.onAnswerOptionPressed}"
                  CommandParameter="3"
                  Background="{Binding option3BgColor}" BorderBrush="{Binding option3BorderColor}" BorderThickness="2">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
              </ControlTemplate>
            </Button.Template>
            <Viewbox Stretch="Uniform" Margin="16">
              <Grid Width="40" Height="40">
                <Path Data="{Binding option3.pathData}"
                      Fill="{Binding option3.fillColor}"
                      Stretch="Uniform" Width="30" Height="30"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="{Binding option3.pathVisible, Converter={StaticResource BoolToVis}}"/>
              </Grid>
            </Viewbox>
          </Button>
        </Grid>
      </Grid>
    </Grid>
  </Viewbox>
</Grid>
