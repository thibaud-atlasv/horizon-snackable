<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      Background="Transparent">

    <Page.Resources>
        <!-- Score Pulse Animation - triggered when scoreAnimating becomes true -->
        <Storyboard x:Key="ScorePulseAnim">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreContainer"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1.25">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseIn"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScoreContainer"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1.25">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseIn"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Center Text Pop-In Animation -->
        <Storyboard x:Key="CenterTextPopAnim">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterTextBlock"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterTextBlock"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterTextBlock"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.1" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <Grid x:Name="CenterTextContainer" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid.Visibility>
                <Binding Path="showCenterText">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter/>
                    </Binding.Converter>
                </Binding>
            </Grid.Visibility>
            <b:Interaction.Triggers>
                <b:PropertyChangedTrigger Binding="{Binding Path=centerText}">
                    <b:ControlStoryboardAction Storyboard="{StaticResource CenterTextPopAnim}"/>
                </b:PropertyChangedTrigger>
            </b:Interaction.Triggers>
            <Grid x:Name="CenterTextBlock" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Grid.RenderTransform>
                <TextBlock Text="{Binding Path=centerText}" FontFamily="Roboto" FontWeight="Bold" Foreground="#60000000" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,4,0,0" TextAlignment="Center" FontSize="100"/>
                <TextBlock Text="{Binding Path=centerText}" FontFamily="Roboto" FontWeight="Bold" Stroke="#FF1A1A2E" StrokeThickness="6" Foreground="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontSize="100"/>
                <TextBlock Text="{Binding Path=centerText}" FontFamily="Roboto" FontWeight="Bold" Foreground="{Binding Path=centerTextColor}" HorizontalAlignment="Center" VerticalAlignment="Center" CharacterSpacing="-30" TextAlignment="Center" FontSize="100"/>
            </Grid>
        </Grid>
        <!-- ═══════════════════════════════════════════════════════════════════
             SCORE DISPLAY - Top of screen, always visible
             ═══════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="ScoreContainer" 
              HorizontalAlignment="Center"
              RenderTransformOrigin="0.5,0.5" VerticalAlignment="Bottom" Margin="0,40,0,40">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Grid.RenderTransform>

            <!-- Score animation trigger -->
            <b:Interaction.Triggers>
                <b:DataTrigger Binding="{Binding Path=scoreAnimating}" Value="True">
                    <b:ControlStoryboardAction Storyboard="{StaticResource ScorePulseAnim}"/>
                </b:DataTrigger>
            </b:Interaction.Triggers>

            <!-- Score text with outline effect using layered TextBlocks -->
            <Grid>
                <!-- Shadow/outline layer (offset) -->
                <TextBlock Text="{Binding Path=score, StringFormat=F0}"
                           FontFamily="Roboto"
                           FontWeight="Bold"
                           Foreground="#40000000"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="3,3,0,0" TextAlignment="Center" FontSize="150"/>
                
                <!-- Outline layer -->
                <TextBlock Text="{Binding Path=score, StringFormat=F0}"
                           FontFamily="Roboto"
                           FontWeight="Bold"
                           Stroke="#FF1A1A2E"
                           StrokeThickness="4"
                           Foreground="Transparent"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" TextAlignment="Center" FontSize="150"/>
                
                <!-- Main score text -->
                <TextBlock Text="{Binding Path=score, StringFormat=F0}"
                           FontFamily="Roboto"
                           FontWeight="Bold"
                           Foreground="#FFFFFFFF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           CharacterSpacing="-20" TextAlignment="Center" FontSize="150"/>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════════
             CENTER ANNOUNCEMENT TEXT - Middle of screen
             ═══════════════════════════════════════════════════════════════════ -->
    </Grid>
</Page>
