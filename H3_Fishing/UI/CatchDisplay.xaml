<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:noesis="clr-namespace:NoesisGUIExtensions">

    <Page.Resources>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="DeepBlue" Color="#FF1a5276"/>
        <SolidColorBrush x:Key="OceanBlue" Color="#FF2980b9"/>
        <SolidColorBrush x:Key="Turquoise" Color="#FF17a2b8"/>
        <SolidColorBrush x:Key="Coral" Color="#FFff6b6b"/>
        <SolidColorBrush x:Key="Orange" Color="#FFffa500"/>
        <SolidColorBrush x:Key="GoldenYellow" Color="#FFffd700"/>
        <SolidColorBrush x:Key="White" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="DimText" Color="#99FFFFFF"/>

        <!-- ============================================ -->
        <!-- ANIMATIONS -->
        <!-- ============================================ -->

        <!-- Main Panel Pop-In Animation (Elastic/Bounce) -->
        <Storyboard x:Key="PanelPopInAnimation">
            <!-- Scale X -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MainPanel"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.55" Value="0.95">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.7" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <!-- Scale Y -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MainPanel"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.55" Value="0.95">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.7" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <!-- Panel Opacity -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MainPanel"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- NEW Badge Animation -->
        <Storyboard x:Key="NewBadgeAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="NewBadge"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="NewBadge"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.5"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="0.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="1.15">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut" Amplitude="0.8"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.65" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="NewBadge"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.5"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="0.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="1.15">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut" Amplitude="0.8"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <LinearDoubleKeyFrame KeyTime="0:0:0.65" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Fish Name Fade In -->
        <Storyboard x:Key="FishNameAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FishNameText"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FishNameText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="20"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="20"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Fish ID Fade In -->
        <Storyboard x:Key="FishIdAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FishIdText"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.6" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Rarity Stars Fade In -->
        <Storyboard x:Key="RarityStarsAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RarityStarsText"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.7" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RarityStarsText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.5"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.7" Value="0.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RarityStarsText"
                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.5"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.7" Value="0.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Catch Count Fade In -->
        <Storyboard x:Key="CatchCountAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CatchCountText"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.9" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Tap to Continue Pulsing Animation -->
        <Storyboard x:Key="TapToContinuePulse" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TapToContinueText"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.4"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="0.9"/>
                <LinearDoubleKeyFrame KeyTime="0:0:2" Value="0.4"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Tap to Continue Initial Delay -->
        <Storyboard x:Key="TapToContinueDelayedFadeIn">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TapToContinueText"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.3" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.6" Value="0.4"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

    </Page.Resources>

    <!-- Full-screen overlay container -->
    <Grid x:Name="RootContainer" Visibility="{Binding Path=visibility}">

        <!-- Semi-transparent dark overlay background -->
        <Rectangle Fill="#CC000000"/>

        <!-- Main content area with Viewbox for scaling -->
        <Viewbox Stretch="Uniform" StretchDirection="Both">
            <Grid Width="400" Height="700">

                <!-- Main Panel with animations -->
                <Border x:Name="MainPanel"
                        Margin="20,80,20,80"
                        Padding="0"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="0" ScaleY="0"/>
                            <TranslateTransform X="0" Y="0"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="Loaded">
                            <b:ControlStoryboardAction Storyboard="{DynamicResource PanelPopInAnimation}"/>
                        </b:EventTrigger>
                    </b:Interaction.Triggers>

                    <!-- Panel Background with gradient -->
                    <Border CornerRadius="24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#E61a5276" Offset="0"/>
                                <GradientStop Color="#E6134561" Offset="0.5"/>
                                <GradientStop Color="#E60d3a4d" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <!-- Soft shadow effect via nested border -->
                        </Border.Effect>

                        <!-- Inner border for glow effect -->
                        <Border CornerRadius="22"
                                Margin="3"
                                BorderThickness="2">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#4017a2b8" Offset="0"/>
                                    <GradientStop Color="#2017a2b8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>      <!-- NEW badge -->
                                    <RowDefinition Height="200"/>       <!-- Space for 3D fish model -->
                                    <RowDefinition Height="Auto"/>      <!-- Fish name -->
                                    <RowDefinition Height="Auto"/>      <!-- Fish ID -->
                                    <RowDefinition Height="Auto"/>      <!-- Rarity stars -->
                                    <RowDefinition Height="Auto"/>      <!-- Catch count -->
                                    <RowDefinition Height="*"/>         <!-- Spacer -->
                                    <RowDefinition Height="Auto"/>      <!-- Tap to continue -->
                                </Grid.RowDefinitions>

                                <!-- NEW! Badge (only visible when isNew is true) -->
                                <Border x:Name="NewBadge"
                                        Grid.Row="0"
                                        HorizontalAlignment="Center"
                                        Margin="0,20,0,0"
                                        Padding="16,6,16,6"
                                        CornerRadius="12"
                                        Opacity="0"
                                        Visibility="{Binding Path=newVisibility}"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            <TranslateTransform X="0" Y="0"/>
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFff6b6b" Offset="0"/>
                                            <GradientStop Color="#FFffa500" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Loaded">
                                            <b:ControlStoryboardAction Storyboard="{DynamicResource NewBadgeAnimation}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>

                                    <TextBlock Text="{Binding Path=newLabel}"
                                               FontFamily="Roboto"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#FFFFFFFF"
                                               HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Space for 3D Fish Model (empty area) -->
                                <Grid Grid.Row="1" Margin="20,10,20,10"/>

                                <!-- Fish Name - Large prominent text -->
                                <Grid Grid.Row="2" HorizontalAlignment="Center" Margin="0,10,0,0">
                                    <!-- Shadow text (offset behind) -->
                                    <TextBlock Text="{Binding Path=fishName}"
                                               FontFamily="Roboto"
                                               FontSize="36"
                                               FontWeight="Bold"
                                               Foreground="#40000000"
                                               HorizontalAlignment="Center"
                                               Margin="2,2,0,0"/>
                                    <!-- Main text -->
                                    <TextBlock x:Name="FishNameText"
                                               Text="{Binding Path=fishName}"
                                               FontFamily="Roboto"
                                               FontSize="36"
                                               FontWeight="Bold"
                                               Foreground="#FFFFFFFF"
                                               HorizontalAlignment="Center"
                                               Opacity="0"
                                               RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                <TranslateTransform X="0" Y="0"/>
                                            </TransformGroup>
                                        </TextBlock.RenderTransform>
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="Loaded">
                                                <b:ControlStoryboardAction Storyboard="{DynamicResource FishNameAnimation}"/>
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>
                                    </TextBlock>
                                </Grid>

                                <!-- Fish ID - Smaller dimmed text -->
                                <TextBlock x:Name="FishIdText"
                                           Grid.Row="3"
                                           Text="{Binding Path=fishId}"
                                           FontFamily="Roboto"
                                           FontSize="18"
                                           FontWeight="Normal"
                                           Foreground="#99FFFFFF"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"
                                           Opacity="0">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Loaded">
                                            <b:ControlStoryboardAction Storyboard="{DynamicResource FishIdAnimation}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                </TextBlock>

                                <!-- Rarity Stars - Golden yellow -->
                                <TextBlock x:Name="RarityStarsText"
                                           Grid.Row="4"
                                           Text="{Binding Path=rarityStars}"
                                           FontFamily="Roboto"
                                           FontSize="32"
                                           Foreground="#FFffd700"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,0"
                                           Opacity="0"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            <TranslateTransform X="0" Y="0"/>
                                        </TransformGroup>
                                    </TextBlock.RenderTransform>
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Loaded">
                                            <b:ControlStoryboardAction Storyboard="{DynamicResource RarityStarsAnimation}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                </TextBlock>

                                <!-- Catch Count Display -->
                                <StackPanel x:Name="CatchCountText"
                                            Grid.Row="5"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,16,0,0"
                                            Opacity="0">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Loaded">
                                            <b:ControlStoryboardAction Storyboard="{DynamicResource CatchCountAnimation}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>

                                    <!-- Catch count container -->
                                    <Border Background="#3017a2b8"
                                            CornerRadius="8"
                                            Padding="12,6,12,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="x "
                                                       FontFamily="Roboto"
                                                       FontSize="20"
                                                       FontWeight="Medium"
                                                       Foreground="#CC17a2b8"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Path=catchCount}"
                                                       FontFamily="Roboto"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       Foreground="#FFFFFFFF"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Spacer -->
                                <Grid Grid.Row="6"/>

                                <!-- Tap to Continue hint -->
                                <TextBlock x:Name="TapToContinueText"
                                           Grid.Row="7"
                                           Text="Tap to continue"
                                           FontFamily="Roboto"
                                           FontSize="16"
                                           FontWeight="Normal"
                                           Foreground="#80FFFFFF"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,24"
                                           Opacity="0">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Loaded">
                                            <b:ControlStoryboardAction Storyboard="{DynamicResource TapToContinueDelayedFadeIn}"/>
                                        </b:EventTrigger>
                                        <b:EventTrigger EventName="Loaded">
                                            <b:ControlStoryboardAction Storyboard="{DynamicResource TapToContinuePulse}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                </TextBlock>

                            </Grid>
                        </Border>
                    </Border>
                </Border>

            </Grid>
        </Viewbox>
    </Grid>
</Page>
