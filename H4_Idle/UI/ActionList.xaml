<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:noesis="clr-namespace:NoesisGUIExtensions"
      Background="Transparent">

    <Page.Resources>
        <!-- Bool-to-Visibility converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Color Palette - Gold & Glow Theme -->
        <SolidColorBrush x:Key="GoldColor" Color="#FFFFD700"/>
        <SolidColorBrush x:Key="TextShadow" Color="#80000000"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#60000000"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#80FFD700"/>
        <SolidColorBrush x:Key="ButtonGradientStart" Color="#FF1AB8C3"/>
        <SolidColorBrush x:Key="ButtonGradientEnd" Color="#FF1792EA"/>
        <SolidColorBrush x:Key="ButtonBorder" Color="#FFFFD700"/>
        <SolidColorBrush x:Key="ButtonText" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="DescriptionText" Color="#FFA0D4E4"/>
        <SolidColorBrush x:Key="DisabledButtonBg" Color="#FF1A1A1A"/>
        <SolidColorBrush x:Key="DisabledButtonBorder" Color="#FF404040"/>
        <SolidColorBrush x:Key="DisabledText" Color="#FF666666"/>
        <SolidColorBrush x:Key="ActiveButtonBg" Color="#FF25354A"/>
        <SolidColorBrush x:Key="PriceBoxBackground" Color="#40000000"/>

        <!-- Vertical Panel Template for ItemsControl -->
        <ItemsPanelTemplate x:Key="VerticalPanel">
            <StackPanel Orientation="Vertical"/>
        </ItemsPanelTemplate>

        <!-- Container Style with margin between items -->
        <Style x:Key="ActionItemContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Action Item Button Style -->
        <Style x:Key="ActionItemButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ItemBorder" 
                                Background="{StaticResource ActiveButtonBg}"
                                BorderBrush="{StaticResource ButtonBorder}"
                                BorderThickness="2"
                                CornerRadius="12"
                                Padding="15"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ItemScale" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="ItemTranslate" X="0" Y="0"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <ContentPresenter x:Name="ContentArea"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource DisabledButtonBg}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource DisabledButtonBorder}"/>
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action Item DataTemplate -->
        <DataTemplate x:Key="ActionItemTemplate">
            <Border x:Name="AnimationContainer" 
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                
                <!-- DataTrigger: plays animation only when AnimationTrigger equals 1 -->
                <b:Interaction.Triggers>
                    <b:DataTrigger Binding="{Binding AnimationTrigger}" Comparison="GreaterThan" Value="0">
                        <b:ControlStoryboardAction>
                            <b:ControlStoryboardAction.Storyboard>
                                <Storyboard>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.0"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.12" Value="1.08">
                                            <EasingDoubleKeyFrame.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0">
                                            <EasingDoubleKeyFrame.EasingFunction>
                                                <QuadraticEase EasingMode="EaseIn"/>
                                            </EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                    </DoubleAnimationUsingKeyFrames>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.0"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.12" Value="1.08">
                                            <EasingDoubleKeyFrame.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0">
                                            <EasingDoubleKeyFrame.EasingFunction>
                                                <QuadraticEase EasingMode="EaseIn"/>
                                            </EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </b:ControlStoryboardAction.Storyboard>
                        </b:ControlStoryboardAction>
                    </b:DataTrigger>
                </b:Interaction.Triggers>
                
                <Button Style="{StaticResource ActionItemButtonStyle}"
                        Command="{Binding DataContext.events.ActionItemClick, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding ActionId}"
                        IsEnabled="{Binding IsEnabled}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left side: Title + Description stacked vertically -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                            <!-- Title with shadow -->
                            <Grid>
                                <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource TextShadow}" Margin="1,1,0,0"/>
                                <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource ButtonText}"/>
                            </Grid>
                            <!-- Description -->
                            <TextBlock Text="{Binding Description}" FontSize="18"
                                       Foreground="{StaticResource DescriptionText}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <!-- Right side: Price box with gold icon -->
                        <Border Grid.Column="1" 
                                Background="{StaticResource PriceBoxBackground}"
                                BorderBrush="{StaticResource GoldColor}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Padding="12,8"
                                MinWidth="100"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image Source="Textures/UI/gold_icon.png" 
                                       Width="24" Height="24" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                                <Grid>
                                    <TextBlock Text="{Binding Price}" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TextShadow}"
                                               VerticalAlignment="Center" Margin="1,1,0,0"/>
                                    <TextBlock Text="{Binding Price}" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource GoldColor}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Button>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="900" Height="1600">
            <!-- Action List Panel - positioned at bottom, dynamic height -->
            <Border Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="2"
                    CornerRadius="20"
                    VerticalAlignment="Bottom"
                    Height="{Binding PanelHeight}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}">
                
                <Grid>
                    <!-- Panel Header -->
                    <Border Background="#40000000"
                            CornerRadius="18,18,0,0"
                            Height="60"
                            VerticalAlignment="Top">
                        <Grid>
                            <TextBlock Text="SHOP" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource TextShadow}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="2,2,0,0"/>
                            <TextBlock Text="SHOP" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource GoldColor}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable Item List with ItemsControl -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,60,0,0"
                                  Padding="15,10">
                        <ItemsControl x:Name="ActionItemsControl"
                                      ItemsSource="{Binding Actions}"
                                      ItemsPanel="{StaticResource VerticalPanel}"
                                      ItemTemplate="{StaticResource ActionItemTemplate}"
                                      ItemContainerStyle="{StaticResource ActionItemContainerStyle}"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Viewbox>
</Page>
