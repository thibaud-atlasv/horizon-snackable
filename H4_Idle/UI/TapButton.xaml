<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="ButtonGradientStart" Color="#FF1AB8C3"/>
        <SolidColorBrush x:Key="ButtonGradientEnd" Color="#FF1792EA"/>
        <SolidColorBrush x:Key="ButtonBorder" Color="#FFDBF3F4"/>
        <SolidColorBrush x:Key="ButtonText" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ButtonShadow" Color="#40000000"/>
        <SolidColorBrush x:Key="ButtonHighlight" Color="#80FFFFFF"/>
        
        <!-- Tap Button Style -->
        <Style x:Key="TapButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Outer glow / shadow ring -->
                            <Ellipse Width="320" Height="320"
                                     Fill="{StaticResource ButtonShadow}"
                                     Margin="0,8,0,0"/>
                            
                            <!-- Main button circle with gradient -->
                            <Ellipse x:Name="ButtonBackground" 
                                     Width="300" Height="300">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF1AB8C3" Offset="0"/>
                                        <GradientStop Color="#FF1792EA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            
                            <!-- Inner highlight for 3D effect -->
                            <Ellipse Width="260" Height="260"
                                     VerticalAlignment="Top"
                                     Margin="0,-10,0,0">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="#60FFFFFF" Offset="0"/>
                                        <GradientStop Color="#00FFFFFF" Offset="0.5"/>
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            
                            <!-- Border ring -->
                            <Ellipse Width="300" Height="300"
                                     Stroke="{StaticResource ButtonBorder}"
                                     StrokeThickness="4"
                                     Fill="Transparent"/>
                            
                            <!-- Button content (text) -->
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <!-- Main layout - centered button -->
    <Viewbox Stretch="Uniform">
        <Grid Width="400" Height="500">
            <!-- Tap Button -->
            <Button Style="{StaticResource TapButtonStyle}"
                    Command="{Binding Path=events.buttonClick}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding Path=ButtonLabel}"
                           FontSize="72"
                           FontWeight="Bold"
                           Foreground="{StaticResource ButtonText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
        </Grid>
    </Viewbox>
</Page>
