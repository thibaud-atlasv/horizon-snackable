<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <!-- Top HUD Bar - Lives (left), Wave (center), and Gold (right) -->
    <Grid VerticalAlignment="Top" Height="200">
        <!-- Background with transparency -->
        <Border Background="#CC1a1a2e" CornerRadius="0,0,40,40"/>
        
        <!-- Content: Three sections - left, center, and right aligned -->
        <Grid Margin="60,30,60,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SECTION: Lives -->
            <StackPanel Grid.Column="0" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <!-- Heart icon using Path -->
                <Viewbox Width="90" Height="90" Margin="0,0,25,0">
                    <Path Fill="#e74c3c"
                          Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </Viewbox>
                <!-- Lives value -->
                <TextBlock Text="{Binding Path=lives, StringFormat=F0}" 
                           FontSize="90" 
                           Foreground="#ffffff" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- CENTER SECTION: Wave -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center" Orientation="Horizontal" Grid.Column="1" Grid.Row="1" Margin="0,100,0,-230">
                <!-- Wave label -->
                <!-- Wave number in X/10 format -->
                <TextBlock Text="{Binding Path=waveText}" 
                           Foreground="#ffffff" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,-10,0,0" FontSize="60"/>
            </StackPanel>

            <!-- RIGHT SECTION: Gold -->
            <StackPanel Grid.Column="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <!-- Gold icon from image -->
                <Image Source="Textures/gold_icon.png" 
                       Width="90" 
                       Height="90" 
                       Margin="0,0,25,0"
                       VerticalAlignment="Center"/>
                <!-- Gold value -->
                <TextBlock Text="{Binding Path=gold, StringFormat=F0}" 
                           FontSize="90" 
                           Foreground="#f5c518" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
