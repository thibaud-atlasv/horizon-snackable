<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Page.Resources>
        <!-- Colors (matching TowerShop) -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1a1a2e"/>
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#2a2a4a"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3a3a5a"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#ffffff"/>
        <SolidColorBrush x:Key="TextDisabledBrush" Color="#555577"/>
        <SolidColorBrush x:Key="GoldBrush" Color="#f5c518"/>
        <SolidColorBrush x:Key="SellButtonBrush" Color="#8B0000"/>
        <SolidColorBrush x:Key="UpgradeHistoryBrush" Color="#a0a0c0"/>

        <!-- BooleanToVisibilityConverter for showUpgrades / showHistory bindings -->
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Page.Resources>

    <!-- Main Layout - Full width bar at bottom, visibility bound to ViewModel -->
    <Grid VerticalAlignment="Bottom">
        <Grid.Visibility>
            <Binding Path="visible">
                <Binding.Converter>
                    <BooleanToVisibilityConverter/>
                </Binding.Converter>
            </Binding>
        </Grid.Visibility>

        <!-- Background Bar -->
        <Border Background="{StaticResource BackgroundBrush}"
                Height="600"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,2,0,0">

            <!-- 4-Column Layout: [Info] [Upgrade1?] [Upgrade2?] [Sell] -->
            <Grid HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Column 0 - Info Panel (always visible) -->
                <Border Grid.Column="0"
                        Background="Transparent"
                        BorderBrush="{Binding towerBorderColor}"
                        BorderThickness="2"
                        Width="360"
                        Height="360"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" Margin="36,0,36,0" Padding="36,36,36,36">
                    <StackPanel VerticalAlignment="Center">
                        <!-- Tower Name -->
                        <TextBlock Text="{Binding towerName}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="54"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,24"/>

                        <!-- Upgrade History Line 1 -->
                        <TextBlock x:Name="UpgradeHistory1Text"
                                   Text="{Binding upgradeHistory1, StringFormat='+ {0}'}"
                                   Foreground="{StaticResource UpgradeHistoryBrush}"
                                   FontSize="42"
                                   HorizontalAlignment="Left"
                                   Margin="0,0,0,6"
                                   Visibility="{Binding showHistory1, Converter={StaticResource BoolToVisConverter}}"/>

                        <!-- Upgrade History Line 2 -->
                        <TextBlock x:Name="UpgradeHistory2Text"
                                   Text="{Binding upgradeHistory2, StringFormat='+ {0}'}"
                                   Foreground="{StaticResource UpgradeHistoryBrush}"
                                   FontSize="42"
                                   HorizontalAlignment="Left"
                                   Margin="0,0,0,6"
                                   Visibility="{Binding showHistory2, Converter={StaticResource BoolToVisConverter}}"/>

                        <!-- Upgrade History Line 3 -->
                        <TextBlock x:Name="UpgradeHistory3Text"
                                   Text="{Binding upgradeHistory3, StringFormat='+ {0}'}"
                                   Foreground="{StaticResource UpgradeHistoryBrush}"
                                   FontSize="42"
                                   HorizontalAlignment="Left"
                                   Margin="0,0,0,6"
                                   Visibility="{Binding showHistory3, Converter={StaticResource BoolToVisConverter}}"/>
                    </StackPanel>
                </Border>

                <!-- Column 1 - Upgrade 1 (hidden when maxed) -->
                <Border Grid.Column="1"
                        Visibility="{Binding showUpgrades, Converter={StaticResource BoolToVisConverter}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" Margin="36,0,36,0">
                    <Button x:Name="Upgrade1Button"
                            Command="{Binding Path=events.upgradeTowerTap}"
                            CommandParameter="0"
                            MinWidth="360"
                            MinHeight="360"
                            Background="{StaticResource ButtonBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" Padding="0,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Upgrade 1 Name -->
                            <TextBlock x:Name="Upgrade1Name"
                                       Grid.Row="0"
                                       Text="{Binding upgrade1Name}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="54"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="0,0,0,18"/>

                            <!-- Upgrade 1 Cost with Gold Icon (hidden when maxed) -->
                            <StackPanel x:Name="Upgrade1CostPanel"
                                        Grid.Row="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <Image Source="Textures/gold_icon.png"
                                       Width="72"
                                       Height="72"
                                       Margin="0,0,18,0"
                                       VerticalAlignment="Center"/>
                                <TextBlock x:Name="Upgrade1CostText"
                                           Text="{Binding upgrade1Cost, StringFormat=F0}"
                                           Foreground="{StaticResource GoldBrush}"
                                           FontSize="48"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- MAX label (shown when maxed) -->
                            <TextBlock x:Name="Upgrade1MaxLabel"
                                       Grid.Row="1"
                                       Text="MAX"
                                       Foreground="{StaticResource TextDisabledBrush}"
                                       FontSize="48"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Button>
                </Border>

                <!-- Column 2 - Upgrade 2 (hidden when maxed) -->
                <Border Grid.Column="2"
                        Visibility="{Binding showUpgrades, Converter={StaticResource BoolToVisConverter}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" Margin="36,0,36,0">
                    <Button x:Name="Upgrade2Button"
                            Command="{Binding Path=events.upgradeTowerTap}"
                            CommandParameter="1"
                            MinWidth="360"
                            MinHeight="360"
                            Background="{StaticResource ButtonBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" Padding="0,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Upgrade 2 Name -->
                            <TextBlock x:Name="Upgrade2Name"
                                       Grid.Row="0"
                                       Text="{Binding upgrade2Name}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="54"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="0,0,0,18"/>

                            <!-- Upgrade 2 Cost with Gold Icon (hidden when maxed) -->
                            <StackPanel x:Name="Upgrade2CostPanel"
                                        Grid.Row="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <Image Source="Textures/gold_icon.png"
                                       Width="72"
                                       Height="72"
                                       Margin="0,0,18,0"
                                       VerticalAlignment="Center"/>
                                <TextBlock x:Name="Upgrade2CostText"
                                           Text="{Binding upgrade2Cost, StringFormat=F0}"
                                           Foreground="{StaticResource GoldBrush}"
                                           FontSize="48"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- MAX label (shown when maxed) -->
                            <TextBlock x:Name="Upgrade2MaxLabel"
                                       Grid.Row="1"
                                       Text="MAX"
                                       Foreground="{StaticResource TextDisabledBrush}"
                                       FontSize="48"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Button>
                </Border>

                <!-- Column 3 - Sell Button (always visible, far right) -->
                <Button x:Name="SellButton"
                        Grid.Column="3"
                        Command="{Binding Path=events.sellTowerTap}"
                        MinWidth="360"
                        MinHeight="360"
                        Background="{StaticResource SellButtonBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" Padding="0,0,0,0" Margin="36,0,36,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Sell Label -->
                        <TextBlock Grid.Row="0"
                                   Text="SELL"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="54"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,18"/>

                        <!-- Sell Value with Gold Icon -->
                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Image Source="Textures/gold_icon.png"
                                   Width="72"
                                   Height="72"
                                   Margin="0,0,18,0"
                                   VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding sellValue, StringFormat=F0}"
                                       Foreground="{StaticResource GoldBrush}"
                                       FontSize="48"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <!-- DataTriggers for Upgrade 1 state -->
        <b:Interaction.Triggers>
            <!-- Upgrade 1: affordable -->
            <b:DataTrigger Binding="{Binding upgrade1State}" Value="affordable">
                <b:ChangePropertyAction TargetName="Upgrade1Button" PropertyName="Opacity" Value="1.0"/>
                <b:ChangePropertyAction TargetName="Upgrade1Name" PropertyName="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <b:ChangePropertyAction TargetName="Upgrade1CostText" PropertyName="Foreground" Value="{StaticResource GoldBrush}"/>
                <b:ChangePropertyAction TargetName="Upgrade1CostPanel" PropertyName="Visibility" Value="Visible"/>
                <b:ChangePropertyAction TargetName="Upgrade1MaxLabel" PropertyName="Visibility" Value="Collapsed"/>
            </b:DataTrigger>

            <!-- Upgrade 1: too_expensive -->
            <b:DataTrigger Binding="{Binding upgrade1State}" Value="too_expensive">
                <b:ChangePropertyAction TargetName="Upgrade1Button" PropertyName="Opacity" Value="0.5"/>
                <b:ChangePropertyAction TargetName="Upgrade1Name" PropertyName="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                <b:ChangePropertyAction TargetName="Upgrade1CostText" PropertyName="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                <b:ChangePropertyAction TargetName="Upgrade1CostPanel" PropertyName="Visibility" Value="Visible"/>
                <b:ChangePropertyAction TargetName="Upgrade1MaxLabel" PropertyName="Visibility" Value="Collapsed"/>
            </b:DataTrigger>

            <!-- Upgrade 1: maxed -->
            <b:DataTrigger Binding="{Binding upgrade1State}" Value="maxed">
                <b:ChangePropertyAction TargetName="Upgrade1Button" PropertyName="Opacity" Value="0.5"/>
                <b:ChangePropertyAction TargetName="Upgrade1Name" PropertyName="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                <b:ChangePropertyAction TargetName="Upgrade1CostPanel" PropertyName="Visibility" Value="Collapsed"/>
                <b:ChangePropertyAction TargetName="Upgrade1MaxLabel" PropertyName="Visibility" Value="Visible"/>
            </b:DataTrigger>

            <!-- Upgrade 2: affordable -->
            <b:DataTrigger Binding="{Binding upgrade2State}" Value="affordable">
                <b:ChangePropertyAction TargetName="Upgrade2Button" PropertyName="Opacity" Value="1.0"/>
                <b:ChangePropertyAction TargetName="Upgrade2Name" PropertyName="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <b:ChangePropertyAction TargetName="Upgrade2CostText" PropertyName="Foreground" Value="{StaticResource GoldBrush}"/>
                <b:ChangePropertyAction TargetName="Upgrade2CostPanel" PropertyName="Visibility" Value="Visible"/>
                <b:ChangePropertyAction TargetName="Upgrade2MaxLabel" PropertyName="Visibility" Value="Collapsed"/>
            </b:DataTrigger>

            <!-- Upgrade 2: too_expensive -->
            <b:DataTrigger Binding="{Binding upgrade2State}" Value="too_expensive">
                <b:ChangePropertyAction TargetName="Upgrade2Button" PropertyName="Opacity" Value="0.5"/>
                <b:ChangePropertyAction TargetName="Upgrade2Name" PropertyName="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                <b:ChangePropertyAction TargetName="Upgrade2CostText" PropertyName="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                <b:ChangePropertyAction TargetName="Upgrade2CostPanel" PropertyName="Visibility" Value="Visible"/>
                <b:ChangePropertyAction TargetName="Upgrade2MaxLabel" PropertyName="Visibility" Value="Collapsed"/>
            </b:DataTrigger>

            <!-- Upgrade 2: maxed -->
            <b:DataTrigger Binding="{Binding upgrade2State}" Value="maxed">
                <b:ChangePropertyAction TargetName="Upgrade2Button" PropertyName="Opacity" Value="0.5"/>
                <b:ChangePropertyAction TargetName="Upgrade2Name" PropertyName="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                <b:ChangePropertyAction TargetName="Upgrade2CostPanel" PropertyName="Visibility" Value="Collapsed"/>
                <b:ChangePropertyAction TargetName="Upgrade2MaxLabel" PropertyName="Visibility" Value="Visible"/>
            </b:DataTrigger>
        </b:Interaction.Triggers>
    </Grid>
</Page>
