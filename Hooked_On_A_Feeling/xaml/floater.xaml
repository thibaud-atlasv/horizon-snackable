<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="Black">

  <Grid.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <!-- Shared Button Style: Action Buttons (dark blue-purple with purple accent) -->
    <Style x:Key="ActionButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="140" />
      <Setter Property="Height" Value="54" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#E8EAD8" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="OuterGlow" BorderBrush="#559B7FCC" BorderThickness="1" CornerRadius="10" Padding="0">
              <Border x:Name="RootBorder" CornerRadius="9" Padding="8,4">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2A4A6C" Offset="0" />
                    <GradientStop Color="#1A3A5C" Offset="0.5" />
                    <GradientStop Color="#0D1E35" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>
                  <Point X="0.5" Y="0.5" />
                </Border.RenderTransformOrigin>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PressScale" Property="ScaleX" Value="0.94" />
                <Setter TargetName="PressScale" Property="ScaleY" Value="0.94" />
                <Setter TargetName="OuterGlow" Property="BorderBrush" Value="#889B7FCC" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Cast Button Style (warm amber/gold) -->
    <Style x:Key="CastButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="220" />
      <Setter Property="Height" Value="64" />
      <Setter Property="FontSize" Value="26" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#080D14" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="OuterGlow" BorderBrush="#88E8A84C" BorderThickness="2" CornerRadius="14" Padding="0">
              <Border x:Name="RootBorder" CornerRadius="12" Padding="12,6">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F5D08A" Offset="0" />
                    <GradientStop Color="#E8A84C" Offset="0.5" />
                    <GradientStop Color="#C08030" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>
                  <Point X="0.5" Y="0.5" />
                </Border.RenderTransformOrigin>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PressScale" Property="ScaleX" Value="0.94" />
                <Setter TargetName="PressScale" Property="ScaleY" Value="0.94" />
                <Setter TargetName="OuterGlow" Property="BorderBrush" Value="#CCF5D08A" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Utility Button Style (moonlight / cool) -->
    <Style x:Key="UtilityButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="56" />
      <Setter Property="Height" Value="56" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#C8D8E8" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="OuterGlow" BorderBrush="#55C8D8E8" BorderThickness="1" CornerRadius="12" Padding="0">
              <Border x:Name="RootBorder" CornerRadius="11" Padding="4">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1A3A5C" Offset="0" />
                    <GradientStop Color="#0D1E35" Offset="0.6" />
                    <GradientStop Color="#080D14" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>
                  <Point X="0.5" Y="0.5" />
                </Border.RenderTransformOrigin>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PressScale" Property="ScaleX" Value="0.93" />
                <Setter TargetName="PressScale" Property="ScaleY" Value="0.93" />
                <Setter TargetName="OuterGlow" Property="BorderBrush" Value="#88C8D8E8" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Lure/Tackle Utility Button (warm lantern) -->
    <Style x:Key="LureButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="56" />
      <Setter Property="Height" Value="56" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#E8A84C" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="OuterGlow" BorderBrush="#55E8A84C" BorderThickness="1" CornerRadius="12" Padding="0">
              <Border x:Name="RootBorder" CornerRadius="11" Padding="4">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2A3020" Offset="0" />
                    <GradientStop Color="#1A2518" Offset="0.6" />
                    <GradientStop Color="#0D1510" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>
                  <Point X="0.5" Y="0.5" />
                </Border.RenderTransformOrigin>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PressScale" Property="ScaleX" Value="0.93" />
                <Setter TargetName="PressScale" Property="ScaleY" Value="0.93" />
                <Setter TargetName="OuterGlow" Property="BorderBrush" Value="#88E8A84C" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Generic Styled Button (for menus, close, etc.) -->
    <Style x:Key="MenuButtonStyle" TargetType="Button">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#C8D8E8" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="RootBorder" CornerRadius="8" Padding="12,6"
                    BorderBrush="#331A3A5C" BorderThickness="1">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Color="#1A3A5C" Offset="0" />
                  <GradientStop Color="#0D1E35" Offset="1" />
                </LinearGradientBrush>
              </Border.Background>
              <Border.RenderTransform>
                <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
              </Border.RenderTransform>
              <Border.RenderTransformOrigin>
                <Point X="0.5" Y="0.5" />
              </Border.RenderTransformOrigin>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PressScale" Property="ScaleX" Value="0.95" />
                <Setter TargetName="PressScale" Property="ScaleY" Value="0.95" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Title Play Button Style (gold, large) -->
    <Style x:Key="PlayButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="200" />
      <Setter Property="Height" Value="54" />
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#080D14" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="OuterGlow" BorderBrush="#88E8A84C" BorderThickness="2" CornerRadius="12" Padding="0">
              <Border x:Name="RootBorder" CornerRadius="10" Padding="10,4">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F5D08A" Offset="0" />
                    <GradientStop Color="#E8A84C" Offset="0.6" />
                    <GradientStop Color="#C08030" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>
                  <Point X="0.5" Y="0.5" />
                </Border.RenderTransformOrigin>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PressScale" Property="ScaleX" Value="0.94" />
                <Setter TargetName="PressScale" Property="ScaleY" Value="0.94" />
                <Setter TargetName="OuterGlow" Property="BorderBrush" Value="#CCF5D08A" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Grid.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="480" Height="800">

      <!-- Layer 1: DrawingSurface for game rendering -->
      <local:DrawingSurface Width="480" Height="800" Commands="{Binding drawCommands}" />

      <!-- Layer 2: HUD overlay (top-left) — Circular portrait icon + name/mood -->
      <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="16,16,16,0" Visibility="Collapsed">
        <!-- Row: Portrait icon + Name + Mood -->
        <StackPanel Orientation="Horizontal">
          <!-- Circular portrait icon with border — uses visibility toggle for each character -->
          <Border BorderBrush="{Binding hudNameColor}" ClipToBounds="True" Width="60" Height="60" CornerRadius="30,30,30,30" BorderThickness="2,2,2,2">
            <Border.Background>
              <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Offset="0" Color="#FF0042FF"/>
                <GradientStop Offset="1" Color="#FF000000"/>
              </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="-2,-2,-2,-2">
              <Grid.Clip>
                <EllipseGeometry Center="30,30" RadiusY="27" RadiusX="27"/>
              </Grid.Clip>
              <Image Stretch="UniformToFill" Margin="0,10,0,0" Width="60" Height="60" Source="{Binding Path=hudPortrait}"/>
            </Grid>
          </Border>
          <StackPanel Margin="10,10,10,10">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding hudNameText}" FontSize="16" FontWeight="Bold" FontFamily="Roboto" VerticalAlignment="Center" Foreground="{Binding hudNameColor}" Stroke="#FF000000" StrokeThickness="2"/>
              <TextBlock Text="{Binding hudMoodText}" FontSize="12" FontWeight="Normal" FontFamily="Roboto" FontStyle="Italic" VerticalAlignment="Center" Margin="6,2,0,0" Foreground="{Binding hudMoodColor}" Stroke="#FF000000" StrokeThickness="2"/>
            </StackPanel>
            <ItemsControl ItemsSource="{Binding progressDots}" Margin="0,6,0,0">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                <Ellipse x:Name="dot" Margin="1,0,1,0"
                             Width="12" Height="12"
                             Fill="{Binding color}"
                             StrokeThickness="1.5" Stroke="#FF4CAF50"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          <!-- Character name in accent color -->
          <!-- Mood in parentheses, italic, smaller, mood color -->
        </StackPanel>
        <!-- Progress dots (dynamic collection via ItemsControl) -->
      </StackPanel>

      <!-- Layer 3: Skip button (top-right) - uses Opacity to prevent layout shifts -->
      <Button Width="80" Height="32"
              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,16,16,0"
              Command="{Binding events.onFloaterSkipBeat}"
              Style="{StaticResource MenuButtonStyle}"
              Opacity="{Binding skipButtonOpacity}"
              IsEnabled="{Binding skipButtonVisible}" Content="SKIP" />

      <!-- Layer 4: Dialogue Panel (XAML-based) — below portrait area -->
      <Grid VerticalAlignment="Top" Visibility="{Binding dialogueVisible, Converter={StaticResource BoolToVis}}" Margin="20,175,20,0">
        <Border Background="#D90D1520" BorderBrush="#2A4060"
                BorderThickness="1" CornerRadius="12" Padding="12">
          <StackPanel VerticalAlignment="Top">
            <!-- Speaker name: hidden during scenery/narration dialogue -->
            <TextBlock Text="{Binding speakerName}"
                       Foreground="{Binding speakerColor}"
                       FontSize="14" FontWeight="Bold" FontFamily="Roboto"
                       Margin="0,0,0,4"
                       Visibility="{Binding speakerNameVisible, Converter={StaticResource BoolToVis}}" />
            <!-- Dialogue text: centered + italic during scenery variant -->
            <TextBlock Text="{Binding dialogueText}"
                       Foreground="#E8EAD8" FontSize="13" FontFamily="Roboto"
                       TextWrapping="Wrap" LineHeight="20"
                       TextAlignment="{Binding dialogueTextAlignment}"
                       FontStyle="{Binding dialogueTextFontStyle}" />
            <!-- Blinking tap indicator (fixed-height container prevents layout shift) -->
            <Grid Height="24">
              <TextBlock Visibility="{Binding tapIndicatorVisible, Converter={StaticResource BoolToVis}}"
                       Foreground="#E8EAD8" FontSize="14"
                       HorizontalAlignment="Right" Margin="0,2,4,0"
                       Opacity="0.8" Text="...">
                <TextBlock.Triggers>
                  <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                      <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0.9" To="0.2" Duration="0:0:0.7"
                                         AutoReverse="True" />
                      </Storyboard>
                    </BeginStoryboard>
                  </EventTrigger>
                </TextBlock.Triggers>
              </TextBlock>
            </Grid>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Layer 5: Action Buttons (XAML circular buttons with ground strip) -->
      <Grid VerticalAlignment="Bottom" Visibility="{Binding actionMenuVisible, Converter={StaticResource BoolToVis}}"
            Opacity="{Binding actionMenuOpacity}" Height="135">
        <Grid.RenderTransform>
          <TranslateTransform Y="{Binding actionMenuTranslateY}" />
        </Grid.RenderTransform>
        <!-- Ground strip gradient background -->
        <Grid.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00050C19" Offset="0.186"/>
            <GradientStop Color="#CC050C19" Offset="0.4"/>
            <GradientStop Color="#CC050C19" Offset="1" />
          </LinearGradientBrush>
        </Grid.Background>

        <!-- Buttons row: evenly spaced -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
          <!-- WAIT button -->
          <StackPanel HorizontalAlignment="Center" Opacity="{Binding actionWaitBtnOpacity}" Margin="8,0,8,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding actionWaitBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="87" Height="87" Margin="0,0,0,2"
                    Command="{Binding events.onFloaterActionSelected}" CommandParameter="wait"
                    IsEnabled="{Binding actionWaitEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="44"
                          Width="87" Height="87">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_icon_wait.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                      <Setter TargetName="BtnBorder" Property="Opacity" Value="0.4" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="WAIT" FontWeight="Bold" Foreground="#DDCDD6DC"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>

          <!-- TWITCH button -->
          <StackPanel HorizontalAlignment="Center" Opacity="{Binding actionTwitchBtnOpacity}" Margin="8,0,8,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding actionTwitchBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="87" Height="87" Margin="0,0,0,2"
                    Command="{Binding events.onFloaterActionSelected}" CommandParameter="twitch"
                    IsEnabled="{Binding actionTwitchEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="44"
                          Width="87" Height="87">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_icon_twitch.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                      <Setter TargetName="BtnBorder" Property="Opacity" Value="0.4" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="TWITCH" FontWeight="Bold" Foreground="#DDE8A840"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>

          <!-- DRIFT button -->
          <StackPanel HorizontalAlignment="Center" Opacity="{Binding actionDriftBtnOpacity}" Margin="8,0,8,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding actionDriftBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="87" Height="87" Margin="0,0,0,2"
                    Command="{Binding events.onFloaterActionSelected}" CommandParameter="drift"
                    IsEnabled="{Binding actionDriftEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="44"
                          Width="87" Height="87">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_icon_drift.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                      <Setter TargetName="BtnBorder" Property="Opacity" Value="0.4" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="DRIFT" FontWeight="Bold" Foreground="#DD48C8B0"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>

          <!-- REEL button -->
          <StackPanel HorizontalAlignment="Center" Opacity="{Binding actionReelBtnOpacity}" Margin="8,0,8,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding actionReelBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="87" Height="87" Margin="0,0,0,2"
                    Command="{Binding events.onFloaterActionSelected}" CommandParameter="reel"
                    IsEnabled="{Binding actionReelEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="44"
                          Width="87" Height="87">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_icon_reel.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                      <Setter TargetName="BtnBorder" Property="Opacity" Value="0.4" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="REEL" FontWeight="Bold" Foreground="#DDC070D0"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>
        </StackPanel>
      </Grid>

      <!-- Layer 5b: Idle Button Bar (Bait / Cast / Journal) - replaces individual buttons -->
      <Grid VerticalAlignment="Bottom" Visibility="{Binding idleBarVisible, Converter={StaticResource BoolToVis}}"
            Opacity="{Binding idleBarOpacity}" Height="145">
        <Grid.RenderTransform>
          <TranslateTransform Y="{Binding idleBarTranslateY}" />
        </Grid.RenderTransform>
        <!-- Ground strip gradient background (same as ActionMenu) -->
        <Grid.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00050C19" Offset="0.186"/>
            <GradientStop Color="#CC050C19" Offset="0.4"/>
            <GradientStop Color="#CC050C19" Offset="1" />
          </LinearGradientBrush>
        </Grid.Background>

        <!-- Buttons row: Bait (left), Cast (center, bigger), Journal (right) -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
          <!-- BAIT button -->
          <StackPanel HorizontalAlignment="Center" Opacity="{Binding idleBaitBtnOpacity}" Margin="10,0,10,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding idleBaitBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="87" Height="87" Margin="0,0,0,2"
                    Command="{Binding events.onInventoryOpen}"
                    IsEnabled="{Binding idleBaitBtnEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="44"
                          Width="87" Height="87">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_icon_tacklebox.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="BAIT" FontWeight="Bold" Foreground="#DDE8A840"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>

          <!-- CAST button (15% bigger + higher position) -->
          <StackPanel HorizontalAlignment="Center" Opacity="{Binding idleCastBtnOpacity}" Margin="10,0,10,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding idleCastBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="100" Height="100" Margin="0,-10,0,2"
                    Command="{Binding events.onFloaterCastStart}"
                    IsEnabled="{Binding idleCastBtnEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="50"
                          Width="100" Height="100">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_icon_cast.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="CAST" FontWeight="Bold" Foreground="#DDCDD6DC"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>

          <!-- JOURNAL button -->
          <StackPanel HorizontalAlignment="Center" Opacity="{Binding idleJournalBtnOpacity}" Margin="10,0,10,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding idleJournalBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="87" Height="87" Margin="0,0,0,2"
                    Command="{Binding events.onJournalOpen}"
                    IsEnabled="{Binding idleJournalBtnEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="44"
                          Width="87" Height="87">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_icon_journal.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="JOURNAL" FontWeight="Bold" Foreground="#DD48C8B0"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>
        </StackPanel>
      </Grid>

      <!-- Layer 6: Title Screen -->
      <Grid Visibility="{Binding titleVisible, Converter={StaticResource BoolToVis}}">
        <Button Content="Start" Width="200" Height="54" FontSize="20" FontWeight="Bold"
                Foreground="#FFFFFF" BorderThickness="0"
                VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,60"
                Command="{Binding events.onFloaterStartGame}">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border x:Name="OuterGlow" BorderBrush="#884A627A" BorderThickness="2" CornerRadius="12" Padding="0">
                <Border x:Name="RootBorder" CornerRadius="10" Padding="10,4"
                        BorderBrush="#66799AB0" BorderThickness="1">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#344A627A" Offset="0" />
                      <GradientStop Color="#4A627A" Offset="0.5" />
                      <GradientStop Color="#5E7A94" Offset="1" />
                    </LinearGradientBrush>
                  </Border.Background>
                  <Border.RenderTransform>
                    <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                  </Border.RenderTransform>
                  <Border.RenderTransformOrigin>
                    <Point X="0.5" Y="0.5" />
                  </Border.RenderTransformOrigin>
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="PressScale" Property="ScaleX" Value="0.94" />
                  <Setter TargetName="PressScale" Property="ScaleY" Value="0.94" />
                  <Setter TargetName="OuterGlow" Property="BorderBrush" Value="#AA4A627A" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Button.Template>
        </Button>
      </Grid>

      <!-- Layer 7: Departure overlay -->
      <Grid Visibility="{Binding departureVisible, Converter={StaticResource BoolToVis}}"
            Background="#AA080D14">
        <TextBlock Text="{Binding departureText}" FontSize="18" FontFamily="Roboto"
                   Foreground="#C8D8E8" HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextWrapping="Wrap" TextAlignment="Center" Margin="40" />
      </Grid>

      <!-- Layer 7b: Tier Transition Notification -->
      <Border Visibility="{Binding tierTransitionVisible, Converter={StaticResource BoolToVis}}"
              Background="#CC0D1520" BorderBrush="#9B7FCC" BorderThickness="1"
              CornerRadius="12" Padding="20,12"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              MaxWidth="320">
        <TextBlock Text="{Binding tierTransitionText}"
                   Foreground="#E8EAD8" FontSize="16" FontFamily="Roboto"
                   TextAlignment="Center" TextWrapping="Wrap" />
      </Border>

      <!-- Layer 7c: No-Lure Warning -->

      <!-- Layer 7d: Catch Sequence (2-choice overlay) -->
      <Grid Visibility="{Binding catchChoiceVisible, Converter={StaticResource BoolToVis}}"
            Background="#CC080D14">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
          <Button Content="Reel" Width="240" Height="56" Margin="0,8"
                  Command="{Binding events.onFloaterCatchChoice}" CommandParameter="reel"
                  Foreground="White" FontSize="22" FontWeight="Bold"
                  Style="{StaticResource MenuButtonStyle}" />
          <Button Content="{Binding catchChoiceReleaseLabel}" Width="240" Height="56" Margin="0,8"
                  Command="{Binding events.onFloaterCatchChoice}" CommandParameter="release"
                  Foreground="White" FontSize="22" FontWeight="Bold"
                  Style="{StaticResource MenuButtonStyle}" />
        </StackPanel>
      </Grid>

      <!-- Layer 7e: Ending Overlay -->
      <Grid Visibility="{Binding endingVisible, Converter={StaticResource BoolToVis}}"
            Background="#EE080D14">
        <TextBlock Text="{Binding endingText}" FontSize="16" FontFamily="Roboto"
                   Foreground="#C8D8E8" HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextWrapping="Wrap" TextAlignment="Center" Margin="40"
                   LineHeight="24" />
      </Grid>

      <!-- Layer 8: Idle (between casts) -->
      <Grid Visibility="{Binding idleVisible, Converter={StaticResource BoolToVis}}"
            Background="#88080D14">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
          <TextBlock Text="{Binding idlePromptText}" FontSize="18" FontFamily="Roboto"
                     Foreground="#C8D8E8" HorizontalAlignment="Center" Margin="0,0,0,20" />
          <Button Content="Cast Again" Style="{StaticResource CastButtonStyle}"
                  Width="180" Height="50" FontSize="18"
                  Command="{Binding events.onFloaterNewCast}" />
        </StackPanel>
      </Grid>

      <!-- Layer 9: Inventory (Tackle Box) Overlay -->
      <Grid Visibility="{Binding inventoryVisible, Converter={StaticResource BoolToVis}}"
            Background="#EE080D14">
        <Grid Margin="24,60,24,60">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Tackle Box" FontSize="22" FontWeight="Bold"
                       Foreground="#E8A84C" FontFamily="Teko" HorizontalAlignment="Center" />
            <TextBlock Text="Select a lure to equip" FontSize="13"
                       Foreground="#8A9AB0" FontFamily="Roboto" HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
          </StackPanel>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <Border Margin="0,4" CornerRadius="8" Padding="10,8" Background="#1A3A5C">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Border Grid.Column="0" Width="36" Height="36" Background="#C0392B" CornerRadius="6" />
                  <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Red Spinner" FontSize="14" FontWeight="Bold" Foreground="#E8EAD8" />
                    <TextBlock Text="Attracts all fish" FontSize="11" Foreground="#8A9AB0" />
                  </StackPanel>
                  <Button Grid.Column="2" Content="Equip" Width="60" Height="30" FontSize="11"
                          Command="{Binding events.onInventoryEquip}" CommandParameter="red_spinner"
                          Style="{StaticResource MenuButtonStyle}" />
                </Grid>
              </Border>
              <Border Margin="0,4" CornerRadius="8" Padding="10,8" Background="#1A3A5C">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Border Grid.Column="0" Width="36" Height="36" Background="#F39C12" CornerRadius="6" />
                  <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Gold Teardrop" FontSize="14" FontWeight="Bold" Foreground="#E8EAD8" />
                    <TextBlock Text="Cautious fish" FontSize="11" Foreground="#8A9AB0" />
                  </StackPanel>
                  <Button Grid.Column="2" Content="Equip" Width="60" Height="30" FontSize="11"
                          Command="{Binding events.onInventoryEquip}" CommandParameter="gold_teardrop"
                          Style="{StaticResource MenuButtonStyle}" />
                </Grid>
              </Border>
              <Border Margin="0,4" CornerRadius="8" Padding="10,8" Background="#1A3A5C">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Border Grid.Column="0" Width="36" Height="36" Background="#27AE60" CornerRadius="6" />
                  <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Feather Fly" FontSize="14" FontWeight="Bold" Foreground="#E8EAD8" />
                    <TextBlock Text="Surface dwellers" FontSize="11" Foreground="#8A9AB0" />
                  </StackPanel>
                  <Button Grid.Column="2" Content="Equip" Width="60" Height="30" FontSize="11"
                          Command="{Binding events.onInventoryEquip}" CommandParameter="feather_fly"
                          Style="{StaticResource MenuButtonStyle}" />
                </Grid>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <StackPanel Grid.Row="2" Margin="0,12,0,0" HorizontalAlignment="Center">
            <TextBlock FontSize="12" Foreground="#8A9AB0" HorizontalAlignment="Center">
              <Run Text="Equipped: " />
              <Run Text="{Binding equippedLureName}" Foreground="#E8A84C" FontWeight="Bold" />
            </TextBlock>
          </StackPanel>

          <Button Grid.Row="3" Content="Close" Width="140" Height="40"
                  Command="{Binding events.onInventoryClose}" Margin="0,12,0,0"
                  Style="{StaticResource MenuButtonStyle}" />
        </Grid>
      </Grid>

      <!-- Layer 10: Journal Overlay (Redesigned - 3 tabs: Fish, Collection, Stats) -->
      <Grid Visibility="{Binding journalVisible, Converter={StaticResource BoolToVis}}"
            Background="#F5080D14">
        <Grid Margin="12,36,12,36">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Journal title + met counter -->
          <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,6">
            <TextBlock Text="Journal" FontSize="28" FontWeight="Bold"
                       Foreground="#E8A84C" FontFamily="Teko" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding journalMetCounter}" FontSize="11"
                       Foreground="#8A9AB0" FontFamily="Roboto" HorizontalAlignment="Center"
                       Margin="0,2,0,0" />
          </StackPanel>

          <!-- Tab bar (3 tabs: Fish, Collection, Stats) -->
          <Border Grid.Row="1" Background="#0D1520" CornerRadius="10" Padding="4,4" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <Button Content="Fish" Width="110" Height="32" Margin="4,0"
                      Command="{Binding events.onJournalTabSwitch}" CommandParameter="0"
                      Style="{StaticResource MenuButtonStyle}" FontSize="13" />
              <Button Content="Collection" Width="110" Height="32" Margin="4,0"
                      Command="{Binding events.onJournalTabSwitch}" CommandParameter="1"
                      Style="{StaticResource MenuButtonStyle}" FontSize="13" />
              <Button Content="Stats" Width="110" Height="32" Margin="4,0"
                      Command="{Binding events.onJournalTabSwitch}" CommandParameter="2"
                      Style="{StaticResource MenuButtonStyle}" FontSize="13" />
            </StackPanel>
          </Border>

          <!-- Gold separator -->
          <Border Grid.Row="2" Height="1" Margin="20,0,20,8">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#00E8A84C" Offset="0" />
                <GradientStop Color="#AAE8A84C" Offset="0.5" />
                <GradientStop Color="#00E8A84C" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>

          <!-- Tab content area -->
          <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <Grid>
              <!-- Tab 1: Characters (Fish) — Portrait Cards Grid -->
              <StackPanel Visibility="{Binding journalTab1Visible, Converter={StaticResource BoolToVis}}">
                <!-- Nereia Card -->
                <Border Background="#D90D1520" BorderBrush="{Binding charDetailAccentColor}"
                        BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="70" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Circular Portrait -->
                    <Border Grid.Column="0" Width="60" Height="60" CornerRadius="30"
                            BorderBrush="#9B7FCC" BorderThickness="2" ClipToBounds="True">
                      <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                          <GradientStop Color="#1A3A5C" Offset="0" />
                          <GradientStop Color="#0D1E35" Offset="1" />
                        </LinearGradientBrush>
                      </Border.Background>
                      <Grid Margin="-2,-2,-2,-2">
                        <Grid.Clip>
                          <EllipseGeometry Center="30,30" RadiusX="28" RadiusY="28" />
                        </Grid.Clip>
                        <TextBlock Text="?" FontSize="28" FontWeight="Bold" Foreground="#3A4A5A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Image Source="sprites/nereia_neutral.png" Stretch="UniformToFill"
                               Width="60" Height="60" Margin="0,8,0,0"
                               Visibility="{Binding nereiaCardUnlocked, Converter={StaticResource BoolToVis}}" />
                      </Grid>
                    </Border>
                    <!-- Info -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                      <TextBlock Text="{Binding nereiaCardName}" FontSize="15" FontWeight="Bold"
                                 Foreground="#C8D8E8" />
                      <TextBlock Text="{Binding nereiaCardSpecies}" FontSize="11"
                                 Foreground="#8A9AB0" Margin="0,2,0,0" />
                      <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="&#x2661;" FontSize="11" Foreground="#9B7FCC" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding nereiaCardTier}" FontSize="11" Foreground="#9B7FCC" />
                        <TextBlock Text=" casts" FontSize="11" Foreground="#8A9AB0" />
                      </StackPanel>
                    </StackPanel>
                    <!-- View Details Button -->
                    <Button Grid.Column="2" Content="Details" Width="60" Height="28" FontSize="10"
                            Command="{Binding events.onCharacterDetailOpen}" CommandParameter="nereia"
                            Style="{StaticResource MenuButtonStyle}"
                            Visibility="{Binding nereiaCardUnlocked, Converter={StaticResource BoolToVis}}" />
                  </Grid>
                </Border>

                <!-- Kasha Card -->
                <Border Background="#D90D1520" BorderBrush="#2A4060"
                        BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="70" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Circular Portrait -->
                    <Border Grid.Column="0" Width="60" Height="60" CornerRadius="30"
                            BorderBrush="#D33A2C" BorderThickness="2" ClipToBounds="True">
                      <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                          <GradientStop Color="#1A3A5C" Offset="0" />
                          <GradientStop Color="#0D1E35" Offset="1" />
                        </LinearGradientBrush>
                      </Border.Background>
                      <Grid Margin="-2,-2,-2,-2">
                        <Grid.Clip>
                          <EllipseGeometry Center="30,30" RadiusX="28" RadiusY="28" />
                        </Grid.Clip>
                        <TextBlock Text="?" FontSize="28" FontWeight="Bold" Foreground="#3A4A5A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Image Source="sprites/char_veiltail_neutral.png" Stretch="UniformToFill"
                               Width="60" Height="60" Margin="0,8,0,0"
                               Visibility="{Binding kashaCardUnlocked, Converter={StaticResource BoolToVis}}" />
                      </Grid>
                    </Border>
                    <!-- Info -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                      <TextBlock Text="{Binding kashaCardName}" FontSize="15" FontWeight="Bold"
                                 Foreground="#C8D8E8" />
                      <TextBlock Text="{Binding kashaCardSpecies}" FontSize="11"
                                 Foreground="#8A9AB0" Margin="0,2,0,0" />
                      <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="&#x2661;" FontSize="11" Foreground="#D33A2C" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding kashaCardTier}" FontSize="11" Foreground="#D33A2C" />
                        <TextBlock Text=" casts" FontSize="11" Foreground="#8A9AB0" />
                      </StackPanel>
                    </StackPanel>
                    <!-- View Details Button -->
                    <Button Grid.Column="2" Content="Details" Width="60" Height="28" FontSize="10"
                            Command="{Binding events.onCharacterDetailOpen}" CommandParameter="kasha"
                            Style="{StaticResource MenuButtonStyle}"
                            Visibility="{Binding kashaCardUnlocked, Converter={StaticResource BoolToVis}}" />
                  </Grid>
                </Border>
              </StackPanel>

              <!-- Tab 2: Collection (CG Gallery - 3-Column Grid, clean cards) -->
              <StackPanel Visibility="{Binding journalTab2Visible, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding cgCollectionProgress}" FontSize="14" FontWeight="Bold"
                           Foreground="#E8A84C" Margin="0,0,0,10" />

                <!-- 3-Column CG Grid -->
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <!-- Card: Portrait Nereia -->
                  <Button Grid.Column="0" Margin="4,4"
                          Command="{Binding events.onCGItemTapped}" CommandParameter="portrait_nereia"
                          IsEnabled="{Binding cgPortraitNereiaUnlocked}">
                    <Button.Template>
                      <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" ClipToBounds="True"
                                BorderBrush="#2A4060" BorderThickness="1">
                          <Grid>
                            <Grid.RowDefinitions>
                              <RowDefinition Height="*" />
                              <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <!-- Square image area -->
                            <Border Grid.Row="0" Height="120" Background="#0D1520">
                              <Grid>
                                <Image Source="sprites/nereia_neutral.png" Stretch="UniformToFill"
                                       Visibility="{Binding cgPortraitNereiaUnlocked, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="?" FontSize="32" FontWeight="Bold" Foreground="#3A4A5A"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                              </Grid>
                            </Border>
                            <!-- Name label -->
                            <Border Grid.Row="1" Background="#0D1520" Padding="4,6">
                              <TextBlock Text="{Binding cgPortraitNereiaName}" FontSize="13" FontWeight="SemiBold"
                                         Foreground="#C8D8E8" HorizontalAlignment="Center"
                                         TextTrimming="CharacterEllipsis" />
                            </Border>
                          </Grid>
                        </Border>
                      </ControlTemplate>
                    </Button.Template>
                  </Button>

                  <!-- Card: Portrait Kasha -->
                  <Button Grid.Column="1" Margin="4,4"
                          Command="{Binding events.onCGItemTapped}" CommandParameter="portrait_kasha"
                          IsEnabled="{Binding cgPortraitKashaUnlocked}">
                    <Button.Template>
                      <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" ClipToBounds="True"
                                BorderBrush="#2A4060" BorderThickness="1">
                          <Grid>
                            <Grid.RowDefinitions>
                              <RowDefinition Height="*" />
                              <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Height="120" Background="#0D1520">
                              <Grid>
                                <Image Source="sprites/char_veiltail_neutral.png" Stretch="UniformToFill"
                                       Visibility="{Binding cgPortraitKashaUnlocked, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="?" FontSize="32" FontWeight="Bold" Foreground="#3A4A5A"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                              </Grid>
                            </Border>
                            <Border Grid.Row="1" Background="#0D1520" Padding="4,6">
                              <TextBlock Text="{Binding cgPortraitKashaName}" FontSize="13" FontWeight="SemiBold"
                                         Foreground="#C8D8E8" HorizontalAlignment="Center"
                                         TextTrimming="CharacterEllipsis" />
                            </Border>
                          </Grid>
                        </Border>
                      </ControlTemplate>
                    </Button.Template>
                  </Button>

                  <!-- Card: Ending Nereia Reel -->
                  <Button Grid.Column="2" Margin="4,4"
                          Command="{Binding events.onCGItemTapped}" CommandParameter="ending_nereia_reel"
                          IsEnabled="{Binding cgEndingNereiaReelUnlocked}">
                    <Button.Template>
                      <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" ClipToBounds="True"
                                BorderBrush="#2A4060" BorderThickness="1">
                          <Grid>
                            <Grid.RowDefinitions>
                              <RowDefinition Height="*" />
                              <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Height="120" Background="#0D1520">
                              <Grid>
                                <Image Source="sprites/nereia_love_end.png" Stretch="UniformToFill"
                                       Visibility="{Binding cgEndingNereiaReelUnlocked, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="?" FontSize="32" FontWeight="Bold" Foreground="#3A4A5A"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                              </Grid>
                            </Border>
                            <Border Grid.Row="1" Background="#0D1520" Padding="4,6">
                              <TextBlock Text="{Binding cgEndingNereiaReelName}" FontSize="13" FontWeight="SemiBold"
                                         Foreground="#C8D8E8" HorizontalAlignment="Center"
                                         TextTrimming="CharacterEllipsis" />
                            </Border>
                          </Grid>
                        </Border>
                      </ControlTemplate>
                    </Button.Template>
                  </Button>
                </Grid>
              </StackPanel>

              <!-- Tab 3: Stats & Badges -->
              <StackPanel Visibility="{Binding journalTab3Visible, Converter={StaticResource BoolToVis}}">
                <Border Background="#D90D1520" BorderBrush="#2A4060" BorderThickness="1"
                        CornerRadius="12" Padding="14,12" Margin="0,0,0,10">
                  <StackPanel>
                    <TextBlock Text="Statistics" FontSize="14" FontWeight="Bold"
                               Foreground="#E8A84C" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding journalStatsText}"
                               Foreground="#C8D8E8" FontSize="12" FontFamily="Roboto"
                               TextWrapping="Wrap" LineHeight="20" />
                  </StackPanel>
                </Border>
                <Border Background="#D90D1520" BorderBrush="#2A4060" BorderThickness="1"
                        CornerRadius="12" Padding="14,12">
                  <StackPanel>
                    <TextBlock Text="Badges" FontSize="14" FontWeight="Bold"
                               Foreground="#E8A84C" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding journalBadgesText}"
                               Foreground="#C8D8E8" FontSize="12" FontFamily="Roboto"
                               TextWrapping="Wrap" LineHeight="20" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>
          </ScrollViewer>

          <StackPanel Grid.Row="4" Margin="0,10,0,0" HorizontalAlignment="Center">
            <Button Content="Close" Width="140" Height="38"
                    Command="{Binding events.onJournalClose}"
                    Style="{StaticResource MenuButtonStyle}" />
            <Button Content="Reset Save" Width="110" Height="28"
                    Command="{Binding events.onResetSavePressed}" Margin="0,6,0,0"
                    Background="#44661111" Foreground="#CC9999" FontSize="10"
                    BorderThickness="1" BorderBrush="#663333" />
          </StackPanel>
        </Grid>
      </Grid>

      <!-- Layer 10a: Character Detail Overlay -->
      <Grid Visibility="{Binding charDetailVisible, Converter={StaticResource BoolToVis}}"
            Background="#F5080D14">
        <Grid Margin="20,50,20,50">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Header: Large portrait + name/species -->
          <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,14">
            <!-- Large circular portrait -->
            <Border Width="90" Height="90" CornerRadius="45"
                    BorderBrush="{Binding charDetailAccentColor}" BorderThickness="3"
                    HorizontalAlignment="Center" ClipToBounds="True">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Color="#1A3A5C" Offset="0" />
                  <GradientStop Color="#0D1E35" Offset="1" />
                </LinearGradientBrush>
              </Border.Background>
              <Grid Margin="-3,-3,-3,-3">
                <Grid.Clip>
                  <EllipseGeometry Center="45,45" RadiusX="42" RadiusY="42" />
                </Grid.Clip>
                <Image Source="sprites/nereia_neutral.png" Stretch="UniformToFill"
                       Width="90" Height="90" Margin="0,12,0,0"
                       Visibility="{Binding charDetailShowNereia, Converter={StaticResource BoolToVis}}" />
                <Image Source="sprites/char_veiltail_neutral.png" Stretch="UniformToFill"
                       Width="90" Height="90" Margin="0,12,0,0"
                       Visibility="{Binding charDetailShowKasha, Converter={StaticResource BoolToVis}}" />
              </Grid>
            </Border>
            <TextBlock Text="{Binding charDetailName}" FontSize="22" FontWeight="Bold"
                       Foreground="#C8D8E8" HorizontalAlignment="Center" Margin="0,8,0,0" />
            <TextBlock Text="{Binding charDetailSpecies}" FontSize="13"
                       Foreground="#8A9AB0" HorizontalAlignment="Center" Margin="0,2,0,0" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
              <TextBlock Text="♡ " FontSize="12" Foreground="{Binding charDetailAccentColor}" />
              <TextBlock Text="{Binding charDetailTierName}" FontSize="12"
                         Foreground="{Binding charDetailAccentColor}" FontWeight="SemiBold" />
              <TextBlock Text="  ·  " FontSize="12" Foreground="#5A6A7A" />
              <TextBlock Text="{Binding charDetailCasts}" FontSize="12" Foreground="#8A9AB0" />
              <TextBlock Text=" casts" FontSize="12" Foreground="#8A9AB0" />
            </StackPanel>
          </StackPanel>

          <!-- Scrollable content -->
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <!-- Observations -->
              <Border Background="#D90D1520" BorderBrush="#2A4060" BorderThickness="1"
                      CornerRadius="12" Padding="14,10" Margin="0,0,0,10">
                <StackPanel>
                  <TextBlock Text="🔍 Observations" FontSize="13" FontWeight="Bold"
                             Foreground="#E8A84C" Margin="0,0,0,6" />
                  <TextBlock Text="{Binding charDetailObservations}"
                             Foreground="#C8D8E8" FontSize="12" FontFamily="Roboto"
                             TextWrapping="Wrap" LineHeight="18" />
                </StackPanel>
              </Border>
              <!-- Quest -->
              <Border Background="#D90D1520" BorderBrush="#2A4060" BorderThickness="1"
                      CornerRadius="12" Padding="14,10">
                <StackPanel>
                  <TextBlock Text="📜 Personal Quest" FontSize="13" FontWeight="Bold"
                             Foreground="#E8A84C" Margin="0,0,0,4" />
                  <TextBlock Text="{Binding charDetailQuestName}" FontSize="12"
                             Foreground="#C8D8E8" FontWeight="SemiBold" Margin="0,0,0,4" />
                  <TextBlock Text="{Binding charDetailQuestHint}"
                             Foreground="#8A9AB0" FontSize="11" FontFamily="Roboto"
                             TextWrapping="Wrap" FontStyle="Italic" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <!-- Back button -->
          <Button Grid.Row="2" Content="← Back" Width="120" Height="36"
                  Command="{Binding events.onCharacterDetailClose}"
                  HorizontalAlignment="Center" Margin="0,10,0,0"
                  Style="{StaticResource MenuButtonStyle}" />
        </Grid>
      </Grid>

      <!-- Layer 10b: Reset Save Confirmation Overlay -->
      <Grid Visibility="{Binding resetConfirmVisible, Converter={StaticResource BoolToVis}}"
            Background="#DD080D14">
        <Border Background="#FF1A1020" BorderBrush="#9B7FCC" BorderThickness="2"
                CornerRadius="12" Padding="24,20"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="320">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="Reset Save Data?" FontSize="20" FontWeight="Bold"
                       Foreground="#E8EAD8" HorizontalAlignment="Center" Margin="0,0,0,12" />
            <TextBlock Text="This will permanently erase all progress, affection, journal entries, and unlocks. This cannot be undone."
                       FontSize="13" Foreground="#AA9999" TextWrapping="Wrap"
                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <Button Content="Cancel" Width="110" Height="38" Margin="0,0,12,0"
                      Command="{Binding events.onResetSaveCancel}"
                      Background="#333344" Foreground="#E8EAD8" FontSize="14" BorderThickness="0" />
              <Button Content="Reset" Width="110" Height="38"
                      Command="{Binding events.onResetSaveConfirm}"
                      Background="#661111" Foreground="#FF6666" FontSize="14" FontWeight="Bold" BorderThickness="0" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
      <!-- Layer 11: CG Fullscreen Viewer -->
      <Grid Visibility="{Binding cgViewerVisible, Converter={StaticResource BoolToVis}}"
            Background="#EE000000">
        <!-- Tap outside to close -->
        <Button Width="480" Height="800" Opacity="0"
                Command="{Binding events.onCGViewerDismiss}" />
        <!-- Centered image at full width -->
        <Image Source="{Binding cgViewerImagePath}" Stretch="Uniform"
               HorizontalAlignment="Center" VerticalAlignment="Center"
               Width="440" Margin="20,60,20,80" />
        <!-- Close button at bottom -->
        <Button Content="✕ Close" Width="140" Height="40"
                Command="{Binding events.onCGViewerDismiss}"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,30" Background="#333344" Foreground="#E8EAD8"
                FontSize="14" BorderThickness="0" />
      </Grid>

    </Grid>
  </Viewbox>
</Grid>
