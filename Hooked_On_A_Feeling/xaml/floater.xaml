<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="Black">

  <Grid.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <!-- Shared Button Style: Action Buttons (dark blue-purple with purple accent) -->
    <Style x:Key="ActionButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="140" />
      <Setter Property="Height" Value="54" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#E8EAD8" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="OuterGlow" BorderBrush="#559B7FCC" BorderThickness="1" CornerRadius="10" Padding="0">
              <Border x:Name="RootBorder" CornerRadius="9" Padding="8,4">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2A4A6C" Offset="0" />
                    <GradientStop Color="#1A3A5C" Offset="0.5" />
                    <GradientStop Color="#0D1E35" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>
                  <Point X="0.5" Y="0.5" />
                </Border.RenderTransformOrigin>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PressScale" Property="ScaleX" Value="0.94" />
                <Setter TargetName="PressScale" Property="ScaleY" Value="0.94" />
                <Setter TargetName="OuterGlow" Property="BorderBrush" Value="#889B7FCC" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Cast Button Style (warm amber/gold) -->
    <Style x:Key="CastButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="220" />
      <Setter Property="Height" Value="64" />
      <Setter Property="FontSize" Value="26" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#080D14" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="OuterGlow" BorderBrush="#88E8A84C" BorderThickness="2" CornerRadius="14" Padding="0">
              <Border x:Name="RootBorder" CornerRadius="12" Padding="12,6">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F5D08A" Offset="0" />
                    <GradientStop Color="#E8A84C" Offset="0.5" />
                    <GradientStop Color="#C08030" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>
                  <Point X="0.5" Y="0.5" />
                </Border.RenderTransformOrigin>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PressScale" Property="ScaleX" Value="0.94" />
                <Setter TargetName="PressScale" Property="ScaleY" Value="0.94" />
                <Setter TargetName="OuterGlow" Property="BorderBrush" Value="#CCF5D08A" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Utility Button Style (moonlight / cool) -->
    <Style x:Key="UtilityButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="56" />
      <Setter Property="Height" Value="56" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#C8D8E8" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="OuterGlow" BorderBrush="#55C8D8E8" BorderThickness="1" CornerRadius="12" Padding="0">
              <Border x:Name="RootBorder" CornerRadius="11" Padding="4">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1A3A5C" Offset="0" />
                    <GradientStop Color="#0D1E35" Offset="0.6" />
                    <GradientStop Color="#080D14" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>
                  <Point X="0.5" Y="0.5" />
                </Border.RenderTransformOrigin>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PressScale" Property="ScaleX" Value="0.93" />
                <Setter TargetName="PressScale" Property="ScaleY" Value="0.93" />
                <Setter TargetName="OuterGlow" Property="BorderBrush" Value="#88C8D8E8" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Lure/Tackle Utility Button (warm lantern) -->
    <Style x:Key="LureButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="56" />
      <Setter Property="Height" Value="56" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#E8A84C" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="OuterGlow" BorderBrush="#55E8A84C" BorderThickness="1" CornerRadius="12" Padding="0">
              <Border x:Name="RootBorder" CornerRadius="11" Padding="4">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2A3020" Offset="0" />
                    <GradientStop Color="#1A2518" Offset="0.6" />
                    <GradientStop Color="#0D1510" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>
                  <Point X="0.5" Y="0.5" />
                </Border.RenderTransformOrigin>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PressScale" Property="ScaleX" Value="0.93" />
                <Setter TargetName="PressScale" Property="ScaleY" Value="0.93" />
                <Setter TargetName="OuterGlow" Property="BorderBrush" Value="#88E8A84C" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Generic Styled Button (for menus, close, etc.) -->
    <Style x:Key="MenuButtonStyle" TargetType="Button">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#C8D8E8" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="RootBorder" CornerRadius="8" Padding="12,6"
                    BorderBrush="#331A3A5C" BorderThickness="1">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Color="#1A3A5C" Offset="0" />
                  <GradientStop Color="#0D1E35" Offset="1" />
                </LinearGradientBrush>
              </Border.Background>
              <Border.RenderTransform>
                <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
              </Border.RenderTransform>
              <Border.RenderTransformOrigin>
                <Point X="0.5" Y="0.5" />
              </Border.RenderTransformOrigin>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PressScale" Property="ScaleX" Value="0.95" />
                <Setter TargetName="PressScale" Property="ScaleY" Value="0.95" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Title Play Button Style (gold, large) -->
    <Style x:Key="PlayButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="200" />
      <Setter Property="Height" Value="54" />
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#080D14" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="OuterGlow" BorderBrush="#88E8A84C" BorderThickness="2" CornerRadius="12" Padding="0">
              <Border x:Name="RootBorder" CornerRadius="10" Padding="10,4">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F5D08A" Offset="0" />
                    <GradientStop Color="#E8A84C" Offset="0.6" />
                    <GradientStop Color="#C08030" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>
                  <Point X="0.5" Y="0.5" />
                </Border.RenderTransformOrigin>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PressScale" Property="ScaleX" Value="0.94" />
                <Setter TargetName="PressScale" Property="ScaleY" Value="0.94" />
                <Setter TargetName="OuterGlow" Property="BorderBrush" Value="#CCF5D08A" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Grid.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="480" Height="800">

      <!-- Layer 1: DrawingSurface for game rendering -->
      <local:DrawingSurface x:Name="GameCanvas" Width="480" Height="800" Commands="{Binding drawCommands}" />

      <!-- Layer 2: HUD overlay (top-left) — Circular portrait icon + name/mood -->
      <StackPanel x:Name="HudOverlay" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="16,16,16,0" Visibility="Collapsed" d:IsHidden="True">
        <!-- Row: Portrait icon + Name + Mood -->
        <StackPanel Orientation="Horizontal">
          <!-- Circular portrait icon with border — uses visibility toggle for each character -->
          <Border BorderBrush="{Binding hudNameColor}" ClipToBounds="True" Width="60" Height="60" CornerRadius="30,30,30,30" BorderThickness="2,2,2,2">
            <Border.Background>
              <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Offset="0" Color="#FF0042FF"/>
                <GradientStop Offset="1" Color="#FF000000"/>
              </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="-2,-2,-2,-2">
              <Grid.Clip>
                <EllipseGeometry Center="30,30" RadiusY="27" RadiusX="27"/>
              </Grid.Clip>
              <Image Stretch="UniformToFill" Margin="0,10,0,0" Width="60" Height="60">
                <Image.Source>
                  <Binding Path="hudPortrait"/>
                </Image.Source>
              </Image>
            </Grid>
          </Border>
          <StackPanel Margin="10,10,10,10">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding hudNameText}" FontSize="16" FontWeight="Bold" FontFamily="Roboto" VerticalAlignment="Center" Foreground="{Binding hudNameColor}" Stroke="#FF000000" StrokeThickness="2"/>
              <TextBlock Text="{Binding hudMoodText}" FontSize="12" FontWeight="Normal" FontFamily="Roboto" FontStyle="Italic" VerticalAlignment="Center" Margin="6,2,0,0" Foreground="{Binding hudMoodColor}" Stroke="#FF000000" StrokeThickness="2"/>
            </StackPanel>
            <ItemsControl ItemsSource="{Binding progressDots}" Margin="0,6,0,0">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                <Ellipse x:Name="dot" Margin="1,0,1,0"
                             Width="12" Height="12"
                             Fill="{Binding color}"
                             StrokeThickness="1.5" Stroke="#FF4CAF50"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          <!-- Character name in accent color -->
          <!-- Mood in parentheses, italic, smaller, mood color -->
        </StackPanel>
        <!-- Progress dots (dynamic collection via ItemsControl) -->
      </StackPanel>

      <!-- Layer 3: Skip button (top-right) - uses Opacity to prevent layout shifts -->
      <Button x:Name="SkipButton" Width="80" Height="32"
              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,16,16,0"
              Command="{Binding events.onFloaterSkipBeat}"
              Style="{StaticResource MenuButtonStyle}"
              Opacity="{Binding skipButtonOpacity}"
              IsEnabled="{Binding skipButtonVisible}" Content="SKIP" d:IsHidden="True" />

      <!-- Layer 4: Dialogue Panel (XAML-based) — below portrait area -->
      <Grid x:Name="DialoguePanel" VerticalAlignment="Top" Visibility="{Binding dialogueVisible, Converter={StaticResource BoolToVis}}" Margin="20,175,20,0">
        <Border x:Name="DialoguePanelBorder" Background="#D90D1520" BorderBrush="#2A4060"
                BorderThickness="1" CornerRadius="12" Padding="12">
          <StackPanel VerticalAlignment="Top">
            <!-- Speaker name: hidden during scenery/narration dialogue -->
            <TextBlock x:Name="SpeakerNameText" Text="{Binding speakerName}"
                       Foreground="{Binding speakerColor}"
                       FontSize="14" FontWeight="Bold" FontFamily="Roboto"
                       Margin="0,0,0,4"
                       Visibility="{Binding speakerNameVisible, Converter={StaticResource BoolToVis}}" />
            <!-- Dialogue text: centered + italic during scenery variant -->
            <TextBlock x:Name="DialogueText" Text="{Binding dialogueText}"
                       Foreground="#E8EAD8" FontSize="13" FontFamily="Roboto"
                       TextWrapping="Wrap" LineHeight="20"
                       TextAlignment="{Binding dialogueTextAlignment}"
                       FontStyle="{Binding dialogueTextFontStyle}" />
            <!-- Blinking tap indicator (fixed-height container prevents layout shift) -->
            <Grid Height="24">
              <TextBlock x:Name="TapIndicator" Visibility="{Binding tapIndicatorVisible, Converter={StaticResource BoolToVis}}"
                       Foreground="#E8EAD8" FontSize="14"
                       HorizontalAlignment="Right" Margin="0,2,4,0"
                       Opacity="0.8" Text="...">
                <TextBlock.Triggers>
                  <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                      <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0.9" To="0.2" Duration="0:0:0.7"
                                         AutoReverse="True" />
                      </Storyboard>
                    </BeginStoryboard>
                  </EventTrigger>
                </TextBlock.Triggers>
              </TextBlock>
            </Grid>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Layer 4b: Affection Gauge (right side, during dialogue) -->
      <Grid x:Name="GaugeRoot" HorizontalAlignment="Right" VerticalAlignment="Center"
            Visibility="{Binding gaugeVisible, Converter={StaticResource BoolToVis}}"
            Margin="0,0,10,0" Width="60" Height="260" Opacity="0.95" d:IsHidden="True">
        <!-- Gauge container with labels to the right -->
        <Grid x:Name="GaugeContainer" VerticalAlignment="Center" HorizontalAlignment="Left" Width="60" Height="220">
          <!-- "Bond" label above gauge bar -->
          <TextBlock x:Name="GaugeTitle" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Text="Line Tension" TextAlignment="Center" Foreground="#FFCBD4DD" Margin="-22,-14,0,0"/>

          <!-- Gauge glow (soft radial glow behind the gauge bar) -->

          <!-- Gauge outer border (1px gradient: pink top → purple middle → cyan bottom) -->
          <Border x:Name="GaugeOuterBorder" Width="21" Height="210" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                  Margin="2,0,0,0" CornerRadius="8,8,8,8" BorderThickness="1.5,1.5,1.5,1.5">
            <Border.BorderBrush>
              <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#EE6688" Offset="0" />
                <GradientStop Color="#B06AE8" Offset="0.5" />
                <GradientStop Color="#55AAEE" Offset="1" />
              </LinearGradientBrush>
            </Border.BorderBrush>
            <!-- Black background (unfilled portion) -->
            <Border.Background>
              <SolidColorBrush x:Name="GaugeBackground" Color="#0D1520" />
            </Border.Background>

            <!-- Inner content: filled gradient + segment lines -->
            <Grid x:Name="GaugeInnerContent" ClipToBounds="True">
              <!-- Gradient fill portion (anchored to bottom, height = gaugeFillHeight) -->
              <Border x:Name="GaugeFillBorder" VerticalAlignment="Bottom" Height="{Binding gaugeFillHeight}" CornerRadius="5,5,5,5">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                    <GradientStop Color="#8855AAEE" Offset="0" />
                    <GradientStop Color="#AAB06AE8" Offset="0.42" />
                    <GradientStop Color="#AAEE5588" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
              </Border>

              <!-- Segment divider lines (7 lines: 3 above middle, 1 middle @105px, 3 below middle) -->
              <!-- Upper/lower halves each split into 4 equal segments of 26.25px -->
              <Border x:Name="SegmentLine1" Background="#55C8D8E8" VerticalAlignment="Top" Margin="3,26.25,3,0" Opacity="0.5" Height="2" CornerRadius="1,1,1,1"/>
              <Border x:Name="SegmentLine2" Background="#55C8D8E8" VerticalAlignment="Top" Margin="3,52.5,3,0" Opacity="0.5" Height="2" CornerRadius="1,1,1,1"/>
              <Border x:Name="SegmentLine3" Background="#55C8D8E8" VerticalAlignment="Top" Margin="3,78.75,3,0" Opacity="0.5" Height="2" CornerRadius="1,1,1,1"/>
              <Border x:Name="SegmentLine4" Background="#99FFFFFF" VerticalAlignment="Top" Margin="1,105,1,0" Opacity="0.5" Height="2" CornerRadius="1,1,1,1"/>
              <Border x:Name="SegmentLine5" Background="#55C8D8E8" VerticalAlignment="Top" Margin="3,131.25,3,0" Opacity="0.5" Height="2" CornerRadius="1,1,1,1"/>
              <Border x:Name="SegmentLine6" Background="#55C8D8E8" VerticalAlignment="Top" Margin="3,157.5,3,0" Opacity="0.5" Height="2" CornerRadius="1,1,1,1"/>
              <Border x:Name="SegmentLine7" Background="#55C8D8E8" VerticalAlignment="Top" Margin="3,183.75,3,0" Opacity="0.5" Height="2" CornerRadius="1,1,1,1"/>
            </Grid>
          </Border>

          <!-- Labels: High / Ideal / Low — with 1px black stroke -->
          <TextBlock x:Name="LabelHigh" Text="High" FontSize="9" Foreground="#EE6688" FontWeight="Normal"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Stroke="#FF000000" StrokeThickness="1" Margin="28,0,0,190"/>
          <TextBlock x:Name="LabelIdeal" FontSize="9" Foreground="#C8A0FF" FontWeight="Normal"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Stroke="#FF000000" StrokeThickness="1" Margin="28,0,0,98" Text="Mid" />
          <TextBlock x:Name="LabelLow" Text="Low" FontSize="9" Foreground="#77BBEE" FontWeight="Normal"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Stroke="#FF000000" StrokeThickness="1" Margin="28,0,0,6" />

          <!-- Cursor glow (soft ellipse glow behind the marker) -->

          <!-- Cursor/Marker: rounded rectangle wider than gauge -->
          <Border x:Name="GaugeCursor" Width="26" Height="7"
                  HorizontalAlignment="Left" VerticalAlignment="Bottom"
                  Margin="0,0,0,12" CornerRadius="3.5"
                  Background="#FFAEB1D6" BorderBrush="#C8CAC3DF" BorderThickness="1.5">
            <Border.RenderTransform>
              <TranslateTransform Y="{Binding gaugeMarkerTranslateY}" />
            </Border.RenderTransform>
          </Border>
        </Grid>
      </Grid>

      <!-- Layer 5: Action Buttons (XAML circular buttons with ground strip) -->
      <Grid x:Name="ActionMenu" VerticalAlignment="Bottom" Visibility="{Binding actionMenuVisible, Converter={StaticResource BoolToVis}}"
            Opacity="{Binding actionMenuOpacity}" Height="135" d:IsHidden="True">
        <Grid.RenderTransform>
          <TranslateTransform Y="{Binding actionMenuTranslateY}" />
        </Grid.RenderTransform>
        <!-- Ground strip gradient background -->
        <Grid.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00050C19" Offset="0.186"/>
            <GradientStop Color="#CC050C19" Offset="0.4"/>
            <GradientStop Color="#CC050C19" Offset="1" />
          </LinearGradientBrush>
        </Grid.Background>

        <!-- Buttons row: evenly spaced -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
          <!-- WAIT button -->
          <StackPanel x:Name="ActionButtonWaitContainer" HorizontalAlignment="Center" Opacity="{Binding actionWaitBtnOpacity}" Margin="8,0,8,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding actionWaitBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="87" Height="87" Margin="0,0,0,2"
                    Command="{Binding events.onFloaterActionSelected}" CommandParameter="wait"
                    IsEnabled="{Binding actionWaitEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="44"
                          Width="87" Height="87">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_icon_wait.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                      <Setter TargetName="BtnBorder" Property="Opacity" Value="0.4" />
                      <Setter Property="IsHitTestVisible" Value="False" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="WAIT" FontWeight="Bold" Foreground="#DDCDD6DC"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>

          <!-- TWITCH button -->
          <StackPanel x:Name="ActionButtonTwitchContainer" HorizontalAlignment="Center" Opacity="{Binding actionTwitchBtnOpacity}" Margin="8,0,8,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding actionTwitchBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="87" Height="87" Margin="0,0,0,2"
                    Command="{Binding events.onFloaterActionSelected}" CommandParameter="twitch"
                    IsEnabled="{Binding actionTwitchEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="44"
                          Width="87" Height="87">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_icon_twitch.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                      <Setter TargetName="BtnBorder" Property="Opacity" Value="0.4" />
                      <Setter Property="IsHitTestVisible" Value="False" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="TWITCH" FontWeight="Bold" Foreground="#DDE8A840"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>

          <!-- DRIFT button -->
          <StackPanel x:Name="ActionButtonDriftContainer" HorizontalAlignment="Center" Opacity="{Binding actionDriftBtnOpacity}" Margin="8,0,8,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding actionDriftBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="87" Height="87" Margin="0,0,0,2"
                    Command="{Binding events.onFloaterActionSelected}" CommandParameter="drift"
                    IsEnabled="{Binding actionDriftEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="44"
                          Width="87" Height="87">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_icon_drift.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                      <Setter TargetName="BtnBorder" Property="Opacity" Value="0.4" />
                      <Setter Property="IsHitTestVisible" Value="False" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="DRIFT" FontWeight="Bold" Foreground="#DD48C8B0"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>

          <!-- REEL button -->
          <StackPanel x:Name="ActionButtonReelContainer" HorizontalAlignment="Center" Opacity="{Binding actionReelBtnOpacity}" Margin="8,0,8,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding actionReelBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="87" Height="87" Margin="0,0,0,2"
                    Command="{Binding events.onFloaterActionSelected}" CommandParameter="reel"
                    IsEnabled="{Binding actionReelEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="44"
                          Width="87" Height="87">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_icon_reel.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                      <Setter TargetName="BtnBorder" Property="Opacity" Value="0.4" />
                      <Setter Property="IsHitTestVisible" Value="False" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="REEL" FontWeight="Bold" Foreground="#DDC070D0"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>
        </StackPanel>
      </Grid>

      <!-- Layer 5b: Idle Button Bar (Bait / Cast / Journal) - replaces individual buttons -->
      <Grid x:Name="IdleBar" VerticalAlignment="Bottom" Visibility="{Binding idleBarVisible, Converter={StaticResource BoolToVis}}"
            Opacity="{Binding idleBarOpacity}" Height="145">
        <Grid.RenderTransform>
          <TranslateTransform Y="{Binding idleBarTranslateY}" />
        </Grid.RenderTransform>
        <!-- Ground strip gradient background (same as ActionMenu) -->
        <Grid.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00050C19" Offset="0.186"/>
            <GradientStop Color="#CC050C19" Offset="0.4"/>
            <GradientStop Color="#CC050C19" Offset="1" />
          </LinearGradientBrush>
        </Grid.Background>

        <!-- Buttons row: Bait (left), Cast (center, bigger), Journal (right) -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
          <!-- BAIT button -->
          <StackPanel HorizontalAlignment="Center" Opacity="{Binding idleBaitBtnOpacity}" Margin="10,0,10,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding idleBaitBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="87" Height="87" Margin="0,0,0,2"
                    Command="{Binding events.onInventoryOpen}"
                    IsEnabled="{Binding idleBaitBtnEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="44"
                          Width="87" Height="87">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_bg_bait.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="TACKLE BOX" FontWeight="Bold" Foreground="#DDE8A840"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9" FontSize="10"/>
          </StackPanel>

          <!-- CAST button (15% bigger + higher position) -->
          <StackPanel HorizontalAlignment="Center" Opacity="{Binding idleCastBtnOpacity}" Margin="10,0,10,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding idleCastBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="100" Height="100" Margin="0,-10,0,2"
                    Command="{Binding events.onFloaterCastStart}"
                    IsEnabled="{Binding idleCastBtnEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="50"
                          Width="100" Height="100">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_bg_cast.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="CAST" FontWeight="Bold" Foreground="#DDCDD6DC"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>

          <!-- JOURNAL button -->
          <StackPanel HorizontalAlignment="Center" Opacity="{Binding idleJournalBtnOpacity}" Margin="10,0,10,0">
            <StackPanel.RenderTransform>
              <TranslateTransform Y="{Binding idleJournalBtnTranslateY}" />
            </StackPanel.RenderTransform>
            <Button Width="87" Height="87" Margin="0,0,0,2"
                    Command="{Binding events.onJournalOpen}"
                    IsEnabled="{Binding idleJournalBtnEnabled}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="44"
                          Width="87" Height="87">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_bg_journal.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <TextBlock Text="JOURNAL" FontWeight="Bold" Foreground="#DD48C8B0"
                       HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="1" Opacity="0.9"/>
          </StackPanel>
        </StackPanel>
      </Grid>

      <!-- Layer 6: Title Screen -->
      <Grid x:Name="TitleScreen" Visibility="{Binding titleVisible, Converter={StaticResource BoolToVis}}">
        <Button Content="Start" Width="200" Height="54" FontSize="20" FontWeight="Bold"
                Foreground="#FFFFFF" BorderThickness="0"
                VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,60"
                Command="{Binding events.onFloaterStartGame}" d:IsHidden="True">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border x:Name="OuterGlow" BorderBrush="#884A627A" BorderThickness="2" CornerRadius="12" Padding="0">
                <Border x:Name="RootBorder" CornerRadius="10" Padding="10,4"
                        BorderBrush="#66799AB0" BorderThickness="1">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#344A627A" Offset="0" />
                      <GradientStop Color="#4A627A" Offset="0.5" />
                      <GradientStop Color="#5E7A94" Offset="1" />
                    </LinearGradientBrush>
                  </Border.Background>
                  <Border.RenderTransform>
                    <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                  </Border.RenderTransform>
                  <Border.RenderTransformOrigin>
                    <Point X="0.5" Y="0.5" />
                  </Border.RenderTransformOrigin>
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="PressScale" Property="ScaleX" Value="0.94" />
                  <Setter TargetName="PressScale" Property="ScaleY" Value="0.94" />
                  <Setter TargetName="OuterGlow" Property="BorderBrush" Value="#AA4A627A" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Button.Template>
        </Button>
        <Image x:Name="rod" Source="/Root;component/sprites/rod.png" RenderTransformOrigin="0.5,0.5">
          <Image.RenderTransform>
            <TransformGroup>
              <ScaleTransform/>
              <SkewTransform/>
              <RotateTransform Angle="42"/>
              <TranslateTransform Y="113" X="188"/>
            </TransformGroup>
          </Image.RenderTransform>
        </Image>
      </Grid>

      <!-- Layer 7: Departure overlay -->
      <Grid x:Name="DepartureOverlay" Visibility="{Binding departureVisible, Converter={StaticResource BoolToVis}}"
            Background="#AA080D14" d:IsHidden="True">
        <TextBlock Text="{Binding departureText}" FontSize="18" FontFamily="Roboto"
                   Foreground="#C8D8E8" HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextWrapping="Wrap" TextAlignment="Center" Margin="40" />
      </Grid>

      <!-- Layer 7b: Tier Transition Notification -->
      <Border x:Name="TierNotification" Visibility="{Binding tierTransitionVisible, Converter={StaticResource BoolToVis}}"
              Background="#CC0D1520" BorderBrush="#9B7FCC" BorderThickness="1"
              CornerRadius="12" Padding="20,12"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              MaxWidth="320" d:IsHidden="True">
        <TextBlock Text="{Binding tierTransitionText}"
                   Foreground="#E8EAD8" FontSize="16" FontFamily="Roboto"
                   TextAlignment="Center" TextWrapping="Wrap" />
      </Border>

      <!-- Layer 7c: No-Lure Warning -->

      <!-- Layer 7d: Ending Overlay -->
      <Grid x:Name="EndingOverlay" Visibility="{Binding endingVisible, Converter={StaticResource BoolToVis}}"
            Background="#EE080D14" Opacity="{Binding endingOverlayOpacity}" d:IsHidden="True">
        <TextBlock Text="{Binding endingText}" FontSize="16" FontFamily="Roboto"
                   Foreground="#C8D8E8" HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextWrapping="Wrap" TextAlignment="Center" Margin="40"
                   LineHeight="24" />
        <TextBlock Text="Tap to continue" FontSize="13" FontFamily="Roboto"
                   Foreground="#6888A8" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   Margin="0,0,0,48"
                   Visibility="{Binding endingTapVisible, Converter={StaticResource BoolToVis}}" />
      </Grid>

      <!-- Layer 8: Idle (between casts) -->
      <Grid x:Name="IdleOverlay" Visibility="{Binding idleVisible, Converter={StaticResource BoolToVis}}"
            Background="#88080D14" d:IsHidden="True">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
          <TextBlock Text="{Binding idlePromptText}" FontSize="18" FontFamily="Roboto"
                     Foreground="#C8D8E8" HorizontalAlignment="Center" Margin="0,0,0,20" />
          <Button Content="Cast Again" Style="{StaticResource CastButtonStyle}"
                  Width="180" Height="50" FontSize="18"
                  Command="{Binding events.onFloaterNewCast}" />
        </StackPanel>
      </Grid>

      <!-- Layer 9: Inventory (Tackle Box) Overlay - Simplified Grid Layout -->
      <Grid x:Name="InventoryOverlay" Visibility="{Binding inventoryVisible, Converter={StaticResource BoolToVis}}"
            Background="#F5080D14" d:IsHidden="True">
        <Grid Margin="12,36,12,36">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Title + subtitle -->
          <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,6">
            <TextBlock Text="Tackle Box" FontSize="28" FontWeight="Bold"
                       Foreground="#E8A84C" FontFamily="Teko" HorizontalAlignment="Center" />
            <TextBlock Text="Tap a lure to equip" FontSize="11"
                       Foreground="#8A9AB0" FontFamily="Roboto" HorizontalAlignment="Center"
                       Margin="0,2,0,0" />
          </StackPanel>

          <!-- Gold separator -->
          <Border Grid.Row="1" Height="1" Margin="20,0,20,10">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#00E8A84C" Offset="0" />
                <GradientStop Color="#AAE8A84C" Offset="0.5" />
                <GradientStop Color="#00E8A84C" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>

          <!-- Lure Grid: 3 columns, tap to equip directly -->
          <Border Grid.Row="2" Background="#D90D1520" BorderBrush="#2A4060" BorderThickness="1" VerticalAlignment="Top"
                  CornerRadius="12" Padding="10,14">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- None -->
              <Button Grid.Column="0" Grid.Row="0" Margin="4,4"
                      Command="{Binding events.onInventoryEquip}" CommandParameter="none">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <StackPanel HorizontalAlignment="Center">
                      <Grid Width="74" Height="74" HorizontalAlignment="Center">
                        <!-- Equipped border (gold, only visible when this lure is equipped) -->
                        <Border Width="74" Height="74" CornerRadius="37"
                                BorderBrush="#E8A84C" BorderThickness="3"
                                Visibility="{Binding lureNoneEquipped, Converter={StaticResource BoolToVis}}" />
                        <!-- Main circle -->
                        <Border Width="70" Height="70" CornerRadius="35" ClipToBounds="True"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                              <GradientStop Color="#1A2A3A" Offset="0" />
                              <GradientStop Color="#0D1520" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                          <Grid Margin="-2,-2,-2,-2">
                            <Grid.Clip>
                              <EllipseGeometry Center="35,35" RadiusX="33" RadiusY="33" />
                            </Grid.Clip>
                            <Image Stretch="UniformToFill" Width="50" Height="50"
                                   Source="sprites/lure_none.png"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                      </Grid>
                      <TextBlock Text="None" FontSize="11" FontWeight="Bold"
                                 Foreground="#8A9AB0" HorizontalAlignment="Center" Margin="0,5,0,0" />
                    </StackPanel>
                  </ControlTemplate>
                </Button.Template>
              </Button>

              <!-- Red Spinner -->
              <Button Grid.Column="1" Grid.Row="0" Margin="4,4"
                      Command="{Binding events.onInventoryEquip}" CommandParameter="red_spinner">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <StackPanel HorizontalAlignment="Center">
                      <Grid Width="74" Height="74" HorizontalAlignment="Center">
                        <Border Width="74" Height="74" CornerRadius="37"
                                BorderBrush="#E8A84C" BorderThickness="3"
                                Visibility="{Binding lureRedSpinnerEquipped, Converter={StaticResource BoolToVis}}" />
                        <Border Width="70" Height="70" CornerRadius="35" ClipToBounds="True"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                              <GradientStop Color="#1A2A3A" Offset="0" />
                              <GradientStop Color="#0D1520" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                          <Grid Margin="-2,-2,-2,-2">
                            <Grid.Clip>
                              <EllipseGeometry Center="35,35" RadiusX="33" RadiusY="33" />
                            </Grid.Clip>
                            <Image Stretch="UniformToFill" Width="50" Height="50"
                                   Source="sprites/lure_red_spinner.png"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                      </Grid>
                      <TextBlock Text="Red Spinner" FontSize="11" FontWeight="Bold"
                                 Foreground="#C8D8E8" HorizontalAlignment="Center" Margin="0,5,0,0" />
                    </StackPanel>
                  </ControlTemplate>
                </Button.Template>
              </Button>

              <!-- Gold Teardrop -->
              <Button Grid.Column="2" Grid.Row="0" Margin="4,4"
                      Command="{Binding events.onInventoryEquip}" CommandParameter="gold_teardrop">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <StackPanel HorizontalAlignment="Center">
                      <Grid Width="74" Height="74" HorizontalAlignment="Center">
                        <Border Width="74" Height="74" CornerRadius="37"
                                BorderBrush="#E8A84C" BorderThickness="3"
                                Visibility="{Binding lureGoldTeardropEquipped, Converter={StaticResource BoolToVis}}" />
                        <Border Width="70" Height="70" CornerRadius="35" ClipToBounds="True"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                              <GradientStop Color="#1A2A3A" Offset="0" />
                              <GradientStop Color="#0D1520" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                          <Grid Margin="-2,-2,-2,-2">
                            <Grid.Clip>
                              <EllipseGeometry Center="35,35" RadiusX="33" RadiusY="33" />
                            </Grid.Clip>
                            <Image Stretch="UniformToFill" Width="50" Height="50"
                                   Source="sprites/lure_gold_teardrop.png"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                      </Grid>
                      <TextBlock Text="Gold Teardrop" FontSize="11" FontWeight="Bold"
                                 Foreground="#C8D8E8" HorizontalAlignment="Center" Margin="0,5,0,0" />
                    </StackPanel>
                  </ControlTemplate>
                </Button.Template>
              </Button>

              <!-- Feather Fly -->
              <Button Grid.Column="0" Grid.Row="1" Margin="4,4"
                      Command="{Binding events.onInventoryEquip}" CommandParameter="feather_fly">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <StackPanel HorizontalAlignment="Center">
                      <Grid Width="74" Height="74" HorizontalAlignment="Center">
                        <Border Width="74" Height="74" CornerRadius="37"
                                BorderBrush="#E8A84C" BorderThickness="3"
                                Visibility="{Binding lureFeatherFlyEquipped, Converter={StaticResource BoolToVis}}" />
                        <Border Width="70" Height="70" CornerRadius="35" ClipToBounds="True"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                              <GradientStop Color="#1A2A3A" Offset="0" />
                              <GradientStop Color="#0D1520" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                          <Grid Margin="-2,-2,-2,-2">
                            <Grid.Clip>
                              <EllipseGeometry Center="35,35" RadiusX="33" RadiusY="33" />
                            </Grid.Clip>
                            <Image Stretch="UniformToFill" Width="50" Height="50"
                                   Source="sprites/lure_feather_fly.png"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                      </Grid>
                      <TextBlock Text="Feather Fly" FontSize="11" FontWeight="Bold"
                                 Foreground="#C8D8E8" HorizontalAlignment="Center" Margin="0,5,0,0" />
                    </StackPanel>
                  </ControlTemplate>
                </Button.Template>
              </Button>
            </Grid>
          </Border> 

          <!-- Equipped status card (with checkmark, name, and description) -->
          <Border Grid.Row="3" Background="#D90D1520" BorderBrush="#E8A84C" BorderThickness="1"
                  CornerRadius="12" Padding="14,12" Margin="0,10,0,0">
            <StackPanel HorizontalAlignment="Center">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="&#x2714;" FontSize="14" Foreground="#E8A84C"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Text="Equipped:" FontSize="13" Foreground="#8A9AB0"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding equippedLureName}" FontSize="14" FontWeight="Bold"
                           Foreground="#E8A84C" VerticalAlignment="Center" Margin="6,0,0,0" />
              </StackPanel>
              <TextBlock Text="{Binding equippedLureDesc}" FontSize="12" FontStyle="Italic"
                         Foreground="#8A9AB0" TextWrapping="Wrap" Margin="0,6,0,0"
                         HorizontalAlignment="Center" TextAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- Close button -->
          <StackPanel Grid.Row="4" Margin="0,10,0,0" HorizontalAlignment="Center">
            <Button Width="56" Height="56"
                    Command="{Binding events.onInventoryClose}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="28" Width="56" Height="56">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_bg_back.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </StackPanel>
        </Grid>
      </Grid>

      <!-- Layer 10: Journal Overlay (Redesigned - 3 tabs: Fish, Collection, Stats) -->
      <Grid x:Name="JournalOverlay" Visibility="{Binding journalVisible, Converter={StaticResource BoolToVis}}"
            Background="#F5080D14" d:IsHidden="True">
        <Grid Margin="12,36,12,36">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Journal title + met counter -->
          <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,6">
            <TextBlock Text="Journal" FontSize="28" FontWeight="Bold"
                       Foreground="#E8A84C" FontFamily="Teko" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding journalMetCounter}" FontSize="11"
                       Foreground="#8A9AB0" FontFamily="Roboto" HorizontalAlignment="Center"
                       Margin="0,2,0,0" />
          </StackPanel>

          <!-- Tab bar (3 tabs: Fish, Collection, Stats) -->
          <Border Grid.Row="1" Background="#0D1520" CornerRadius="10" Padding="4,4" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <Button Content="Fishes" Width="110" Height="32" Margin="4,0"
                      Command="{Binding events.onJournalTabSwitch}" CommandParameter="0"
                      Foreground="{Binding journalTab1Color}"
                      Style="{StaticResource MenuButtonStyle}" FontSize="13" />
              <Button Content="Collection" Width="110" Height="32" Margin="4,0"
                      Command="{Binding events.onJournalTabSwitch}" CommandParameter="1"
                      Foreground="{Binding journalTab2Color}"
                      Style="{StaticResource MenuButtonStyle}" FontSize="13" />
              <Button Content="Stats" Width="110" Height="32" Margin="4,0"
                      Command="{Binding events.onJournalTabSwitch}" CommandParameter="2"
                      Foreground="{Binding journalTab3Color}"
                      Style="{StaticResource MenuButtonStyle}" FontSize="13" />
            </StackPanel>
          </Border>

          <!-- Gold separator -->
          <Border Grid.Row="2" Height="1" Margin="20,0,20,8">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#00E8A84C" Offset="0" />
                <GradientStop Color="#AAE8A84C" Offset="0.5" />
                <GradientStop Color="#00E8A84C" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>

          <!-- Tab content area -->
          <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <Grid>
              <!-- Tab 1: Fishes — Portrait grid (registry-driven, ItemsControl) -->
              <StackPanel Visibility="{Binding journalTab1Visible, Converter={StaticResource BoolToVis}}">
                <Border Background="#D90D1520" BorderBrush="#2A4060" BorderThickness="1"
                        CornerRadius="12" Padding="10,14">
                  <ItemsControl ItemsSource="{Binding characterCards}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Margin="4,4"
                                Command="{Binding DataContext.events.onCharacterDetailOpen, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding id}"
                                IsEnabled="{Binding unlocked}">
                          <Button.Template>
                            <ControlTemplate TargetType="Button">
                              <StackPanel HorizontalAlignment="Center">
                                <!-- Portrait with diagonal "Complete" overlay -->
                                <Grid Width="70" Height="70" HorizontalAlignment="Center">
                                  <Border Width="70" Height="70" CornerRadius="35"
                                          BorderBrush="{Binding accentColor}" BorderThickness="2" ClipToBounds="True">
                                    <Border.Background>
                                      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#1A3A5C" Offset="0" />
                                        <GradientStop Color="#0D1E35" Offset="1" />
                                      </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid Margin="-2,-2,-2,-2">
                                      <Grid.Clip>
                                        <EllipseGeometry Center="35,35" RadiusX="33" RadiusY="33" />
                                      </Grid.Clip>
                                      <TextBlock Text="?" FontSize="28" FontWeight="Bold" Foreground="#3A4A5A"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                                      <Image Stretch="UniformToFill"
                                             Width="70" Height="70" Margin="0,8,0,0"
                                             Visibility="{Binding unlocked, Converter={StaticResource BoolToVis}}">
                                        <Image.Source>
                                          <Binding Path="texture" />
                                        </Image.Source>
                                      </Image>
                                    </Grid>
                                  </Border>
                                  <!-- Diagonal "Complete" banner overlaid on portrait -->
                                  <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Background="#CC000000" CornerRadius="3" Padding="6,2"
                                          Visibility="{Binding completed, Converter={StaticResource BoolToVis}}"
                                          RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                      <RotateTransform Angle="-30" />
                                    </Border.RenderTransform>
                                    <TextBlock Text="★ Complete" FontSize="9" FontWeight="Bold"
                                               Foreground="#E8A84C" HorizontalAlignment="Center" />
                                  </Border>
                                </Grid>
                                <TextBlock Text="{Binding name}" FontSize="13" FontWeight="Bold"
                                           Foreground="{Binding accentColor}" HorizontalAlignment="Center" Margin="0,6,0,0" />
                              </StackPanel>
                            </ControlTemplate>
                          </Button.Template>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>
              </StackPanel>

              <!-- Tab 2: Collection (CG Gallery — registry-driven ItemsControl) -->
              <StackPanel Visibility="{Binding journalTab2Visible, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding cgCollectionProgress}" FontSize="14" FontWeight="Bold"
                           Foreground="#E8A84C" Margin="0,0,0,10" />

                <ItemsControl ItemsSource="{Binding cgCards}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Margin="4,4"
                              Command="{Binding DataContext.events.onCGItemTapped, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                              CommandParameter="{Binding id}"
                              IsEnabled="{Binding unlocked}">
                        <Button.Template>
                          <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" ClipToBounds="True"
                                    Background="#0D1520" BorderBrush="#2A4060" BorderThickness="1">
                              <Grid>
                                <Grid.RowDefinitions>
                                  <RowDefinition Height="*" />
                                  <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Height="120" Background="#0D1520" CornerRadius="9,9,0,0" ClipToBounds="True">
                                  <Grid Margin="8,8,8,4">
                                    <TextBlock Text="?" FontSize="32" FontWeight="Bold" Foreground="#3A4A5A"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Image Stretch="UniformToFill"
                                           Visibility="{Binding unlocked, Converter={StaticResource BoolToVis}}">
                                      <Image.Source>
                                        <Binding Path="texture" />
                                      </Image.Source>
                                    </Image>
                                  </Grid>
                                </Border>
                                <Border Grid.Row="1" Background="#0D1520" Padding="4,6" CornerRadius="0,0,9,9">
                                  <TextBlock Text="{Binding name}" FontSize="13" FontWeight="SemiBold"
                                             Foreground="#C8D8E8" HorizontalAlignment="Center"
                                             TextTrimming="CharacterEllipsis" />
                                </Border>
                              </Grid>
                            </Border>
                          </ControlTemplate>
                        </Button.Template>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- Tab 3: Stats & Badges (Polished) -->
              <StackPanel Visibility="{Binding journalTab3Visible, Converter={StaticResource BoolToVis}}">
                <!-- === Statistics Section === -->
                <Border Background="#D90D1520" BorderBrush="#2A4060" BorderThickness="1"
                        CornerRadius="12" Padding="14,12" Margin="0,0,0,12">
                  <StackPanel>
                    <TextBlock Text="&#x1F4CA; Statistics" FontSize="15" FontWeight="Bold"
                               Foreground="#E8A84C" Margin="0,0,0,10" />
                    <!-- Stat rows via ItemsControl -->
                    <ItemsControl ItemsSource="{Binding statItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="#110D1E35" CornerRadius="8" Padding="10,8" Margin="0,3">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <TextBlock Grid.Column="0" Text="{Binding icon}" FontSize="16"
                                         VerticalAlignment="Center" HorizontalAlignment="Center" />
                              <TextBlock Grid.Column="1" Text="{Binding label}" FontSize="13"
                                         Foreground="#C8D8E8" VerticalAlignment="Center" Margin="6,0,0,0" />
                              <TextBlock Grid.Column="2" Text="{Binding value}" FontSize="14" FontWeight="Bold"
                                         Foreground="{Binding valueColor}" VerticalAlignment="Center" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <!-- === Badges Section === -->
                <Border Background="#D90D1520" BorderBrush="#2A4060" BorderThickness="1"
                        CornerRadius="12" Padding="14,12">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                      <TextBlock Text="&#x1F3C6; Badges" FontSize="15" FontWeight="Bold"
                                 Foreground="#E8A84C" />
                      <TextBlock Text="{Binding badgeProgressText}" FontSize="11"
                                 Foreground="#8A9AB0" VerticalAlignment="Center" Margin="10,2,0,0" />
                    </StackPanel>
                    <!-- Badge cards via ItemsControl (wrapping 2-col grid) -->
                    <ItemsControl ItemsSource="{Binding badgeItems}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Width="195" Margin="4,4"
                                  Background="{Binding bgColor}"
                                  BorderBrush="{Binding borderColor}" BorderThickness="1.5"
                                  CornerRadius="10" Padding="10,8">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                              </Grid.ColumnDefinitions>
                              <TextBlock Grid.Column="0" Text="{Binding icon}" FontSize="18"
                                         VerticalAlignment="Center" HorizontalAlignment="Center" />
                              <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding name}" FontSize="12" FontWeight="Bold"
                                           Foreground="{Binding nameColor}" />
                                <TextBlock Text="{Binding description}" FontSize="9.5"
                                           Foreground="#6A7A8A" TextTrimming="CharacterEllipsis" />
                              </StackPanel>
                              <TextBlock Grid.Column="2" Text="{Binding statusIcon}" FontSize="13"
                                         VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <!-- Reset Save button (only visible in Stats tab) -->
                <Button Content="Reset Save" Width="110" Height="28"
                        Command="{Binding events.onResetSavePressed}" Margin="0,14,0,0"
                        Background="#44661111" Foreground="#CC9999" FontSize="10"
                        BorderThickness="1" BorderBrush="#663333"
                        HorizontalAlignment="Center" />
              </StackPanel>
            </Grid>
          </ScrollViewer>

          <StackPanel Grid.Row="4" Margin="0,10,0,0" HorizontalAlignment="Center">
            <Button Width="56" Height="56"
                    Command="{Binding events.onJournalClose}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="BtnBorder" CornerRadius="28" Width="56" Height="56">
                    <Border.Background>
                      <ImageBrush ImageSource="sprites/action_bg_back.png" Stretch="UniformToFill" />
                    </Border.Background>
                    <Border.RenderTransform>
                      <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Border.RenderTransformOrigin>
                      <Point X="0.5" Y="0.5" />
                    </Border.RenderTransformOrigin>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                      <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                      <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </StackPanel>
        </Grid>
      </Grid>

      <!-- Layer 10a: Character Detail Overlay -->
      <Grid x:Name="CharacterDetailOverlay" Visibility="{Binding charDetailVisible, Converter={StaticResource BoolToVis}}"
            Background="#F5080D14" d:IsHidden="True">
        <Grid Margin="20,50,20,50">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Header: Large portrait + name/species -->
          <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,14">
            <!-- Large circular portrait -->
            <Border Width="90" Height="90" CornerRadius="45"
                    BorderBrush="{Binding charDetailAccentColor}" BorderThickness="3"
                    HorizontalAlignment="Center" ClipToBounds="True">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Color="#1A3A5C" Offset="0" />
                  <GradientStop Color="#0D1E35" Offset="1" />
                </LinearGradientBrush>
              </Border.Background>
              <Grid Margin="-3,-3,-3,-3">
                <Grid.Clip>
                  <EllipseGeometry Center="45,45" RadiusX="42" RadiusY="42" />
                </Grid.Clip>
                <Image Stretch="UniformToFill"
                       Width="90" Height="90" Margin="0,12,0,0">
                  <Image.Source>
                    <Binding Path="charDetailPortrait" />
                  </Image.Source>
                </Image>
              </Grid>
            </Border>
            <TextBlock Text="{Binding charDetailName}" FontSize="22" FontWeight="Bold"
                       Foreground="{Binding charDetailAccentColor}" HorizontalAlignment="Center" Margin="0,8,0,0" />
            <TextBlock Text="{Binding charDetailSpecies}" FontSize="13"
                       Foreground="#8A9AB0" HorizontalAlignment="Center" Margin="0,2,0,0" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
              <TextBlock Text="♡ " FontSize="12" Foreground="{Binding charDetailTierColor}" />
              <TextBlock Text="{Binding charDetailTierName}" FontSize="12"
                         Foreground="{Binding charDetailTierColor}" FontWeight="SemiBold" />
              <TextBlock Text="  ·  " FontSize="12" Foreground="#5A6A7A" />
              <TextBlock Text="{Binding charDetailCasts}" FontSize="12" Foreground="#8A9AB0" />
              <TextBlock Text=" casts" FontSize="12" Foreground="#8A9AB0" />
            </StackPanel>
          </StackPanel>

          <!-- Scrollable content -->
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <!-- Observations -->
              <Border Background="#D90D1520" BorderBrush="#2A4060" BorderThickness="1"
                      CornerRadius="12" Padding="14,10" Margin="0,0,0,10">
                <StackPanel>
                  <TextBlock Text="🔍 Observations" FontSize="13" FontWeight="Bold"
                             Foreground="#E8A84C" Margin="0,0,0,6" />
                  <TextBlock Text="{Binding charDetailObservations}"
                             Foreground="#C8D8E8" FontSize="12" FontFamily="Roboto"
                             TextWrapping="Wrap" LineHeight="18" />
                </StackPanel>
              </Border>
              <!-- Quest -->
              <Border Background="#D90D1520" BorderBrush="#2A4060" BorderThickness="1"
                      CornerRadius="12" Padding="14,10">
                <StackPanel>
                  <TextBlock Text="📜 Personal Quest" FontSize="13" FontWeight="Bold"
                             Foreground="#E8A84C" Margin="0,0,0,4" />
                  <TextBlock Text="{Binding charDetailQuestName}" FontSize="12"
                             Foreground="#C8D8E8" FontWeight="SemiBold" Margin="0,0,0,4" />
                  <TextBlock Text="{Binding charDetailQuestHint}"
                             Foreground="#8A9AB0" FontSize="11" FontFamily="Roboto"
                             TextWrapping="Wrap" FontStyle="Italic" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <!-- Back button -->
          <Button Grid.Row="2" Width="56" Height="56"
                  Command="{Binding events.onCharacterDetailClose}"
                  HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border x:Name="BtnBorder" CornerRadius="28" Width="56" Height="56">
                  <Border.Background>
                    <ImageBrush ImageSource="sprites/action_bg_back.png" Stretch="UniformToFill" />
                  </Border.Background>
                  <Border.RenderTransform>
                    <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                  </Border.RenderTransform>
                  <Border.RenderTransformOrigin>
                    <Point X="0.5" Y="0.5" />
                  </Border.RenderTransformOrigin>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                    <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </Grid>
      </Grid>

      <!-- Layer 10b: Reset Save Confirmation Overlay -->
      <Grid x:Name="ResetConfirmOverlay" Visibility="{Binding resetConfirmVisible, Converter={StaticResource BoolToVis}}"
            Background="#DD080D14" d:IsHidden="True">
        <Border Background="#FF1A1020" BorderBrush="#9B7FCC" BorderThickness="2"
                CornerRadius="12" Padding="24,20"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="320">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="Reset Save Data?" FontSize="20" FontWeight="Bold"
                       Foreground="#E8EAD8" HorizontalAlignment="Center" Margin="0,0,0,12" />
            <TextBlock Text="This will permanently erase all progress, affection, journal entries, and unlocks. Your CG collection will be preserved. This cannot be undone."
                       FontSize="13" Foreground="#AA9999" TextWrapping="Wrap"
                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <Button Content="Cancel" Width="110" Height="38" Margin="0,0,12,0"
                      Command="{Binding events.onResetSaveCancel}"
                      Background="#333344" Foreground="#E8EAD8" FontSize="14" BorderThickness="0" />
              <Button Content="Reset" Width="110" Height="38"
                      Command="{Binding events.onResetSaveConfirm}"
                      Background="#661111" Foreground="#FF6666" FontSize="14" FontWeight="Bold" BorderThickness="0" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
      <!-- Layer 11: CG Fullscreen Viewer -->
      <Grid x:Name="CGViewerOverlay" Visibility="{Binding cgViewerVisible, Converter={StaticResource BoolToVis}}"
            Background="#EE000000" d:IsHidden="True">
        <!-- Tap outside to close -->
        <Button Width="480" Height="800" Opacity="0"
                Command="{Binding events.onCGViewerDismiss}" />
        <!-- Single image with dynamic Source binding -->
        <Image Stretch="Uniform"
               HorizontalAlignment="Center" VerticalAlignment="Center"
               Width="440" Margin="20,60,20,80">
          <Image.Source>
            <Binding Path="cgViewerImage"/>
          </Image.Source>
        </Image>
        <!-- Close button -->
        <Button Width="56" Height="56"
                Command="{Binding events.onCGViewerDismiss}"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,30">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border x:Name="BtnBorder" CornerRadius="28" Width="56" Height="56">
                <Border.Background>
                  <ImageBrush ImageSource="sprites/action_bg_back.png" Stretch="UniformToFill" />
                </Border.Background>
                <Border.RenderTransform>
                  <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>
                  <Point X="0.5" Y="0.5" />
                </Border.RenderTransformOrigin>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="PressScale" Property="ScaleX" Value="0.85" />
                  <Setter TargetName="PressScale" Property="ScaleY" Value="0.85" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Button.Template>
        </Button>
      </Grid>

    </Grid>
  </Viewbox>
</Grid>
